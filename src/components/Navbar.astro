---
/**
 * Navbar.astro — Barra de navegación fija.
 * La clase "active" se aplica al enlace cuyo href coincide con la URL actual.
 */
import LogoIcon from '~icons/wsh/logo';

interface NavLink {
  href: string;
  label: string;
  key?: string;
  i18n?: string;
  dropdown?: { href: string; label: string; i18n: string }[];
}

interface Props {
  activePage?: string; // 'inicio' | 'materiales' | 'mapa' | 'directorio' | 'blog'
}
const { activePage = '' } = Astro.props;

const navLinks: NavLink[] = [
  { href: '/index.html', label: 'Inicio', key: 'inicio', i18n: 'nav.inicio' },
  { href: '/canteras.html', label: 'Canteras', key: 'canteras', i18n: 'nav.canteras' },
  { href: '/materiales.html', label: 'Materiales', key: 'materiales', i18n: 'nav.materiales' },
  { href: '/mapa.html', label: 'Mapa', key: 'mapa', i18n: 'nav.mapa' },
  {
    href: '/proveedores.html',
    label: 'Directorio',
    key: 'directorio',
    i18n: 'nav.directorio',
    dropdown: [
      { href: '/proveedores.html', label: 'Todos los proveedores', i18n: 'nav.todosProveedores' },
      {
        href: '/sector.html?id=distribuidores',
        label: 'Distribuidores',
        i18n: 'nav.distribuidores',
      },
      { href: '/sector.html?id=fabricantes', label: 'Fabricantes', i18n: 'nav.fabricantes' },
      { href: '/sector.html?id=arquitectura', label: 'Arquitectura', i18n: 'nav.arquitectura' },
      { href: '/sector.html?id=constructoras', label: 'Constructoras', i18n: 'nav.constructoras' },
      { href: '/sector.html?id=maquinaria', label: 'Maquinaria', i18n: 'nav.maquinaria' },
      { href: '/sector.html?id=laboratorios', label: 'Laboratorios', i18n: 'nav.laboratorios' },
      { href: '/sector.html?id=logistica', label: 'Logística', i18n: 'nav.logistica' },
    ],
  },
  { href: '/blog.html', label: 'Blog', key: 'blog' },
];

const languages: { code: string; label: string }[] = [
  { code: 'es', label: 'ES' },
  { code: 'en', label: 'EN' },
];
---

<nav>
  <a href="/index.html" class="logo" aria-label="World Stone Hub">
    <LogoIcon class="w-64 h-10" />
  </a>

  <ul class="nav-links">
    {
      navLinks.map((link) => (
        <li class:list={[{ 'nav-dropdown': link.dropdown }]}>
          <a
            href={link.href}
            class:list={[{ active: link.key && activePage === link.key }]}
            data-i18n={link.i18n}
          >
            {link.label}
          </a>
          {link.dropdown && (
            <ul class="dropdown-menu">
              {link.dropdown.map((item) => (
                <li>
                  <a href={item.href} data-i18n={item.i18n}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }

    <!-- Auth item inyectado por auth-nav.js -->
    <li id="nav-auth-item"></li>
  </ul>

  <div class="lang-switcher" role="group" aria-label="Seleccionar idioma">
    {
      languages.map((lang, idx) => (
        <>
          {idx > 0 && <span class="lang-sep" aria-hidden="true" />}
          <button
            class:list={['lang-btn', { active: lang.code === 'es' }]}
            data-lang={lang.code}
            aria-pressed={lang.code === 'es' ? 'true' : 'false'}
            data-i18n-attr={`aria-label:lang.${lang.code}`}
          >
            {lang.label}
          </button>
        </>
      ))
    }
  </div>
</nav>

<script>
  // Dropdown hover con delay (evita cierre accidental)
  (function () {
    let closeTimer: ReturnType<typeof setTimeout> | null = null;
    document.querySelectorAll('.nav-dropdown').forEach((el) => {
      el.addEventListener('mouseenter', () => {
        if (closeTimer) {
          clearTimeout(closeTimer);
          closeTimer = null;
        }
        el.classList.add('open');
      });
      el.addEventListener('mouseleave', () => {
        closeTimer = setTimeout(() => el.classList.remove('open'), 250);
      });
      const menu = el.querySelector('.dropdown-menu');
      if (menu) {
        menu.addEventListener('mouseenter', () => {
          if (closeTimer) {
            clearTimeout(closeTimer);
            closeTimer = null;
          }
        });
        menu.addEventListener('mouseleave', () => {
          closeTimer = setTimeout(() => el.classList.remove('open'), 250);
        });
      }
    });
  })();
</script>

<style>
  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 900;
    padding: 16px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: var(--font-ui);
    letter-spacing: 6px;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
    align-items: center;
    margin-left: auto;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #4a4845;
    text-decoration: none;
    transition: color 0.3s;
    position: relative;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--gold);
  }

  .nav-links a.active::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }

  .nav-cta {
    background: var(--gold) !important;
    color: var(--bg-soft) !important;
    padding: 10px 24px;
    font-weight: 500 !important;
  }

  .nav-cta:hover {
    background: var(--ink) !important;
  }

  .nav-auth-sep {
    display: inline-block;
    width: 1px;
    height: 14px;
    background: var(--border2);
    opacity: 0.5;
    margin: 0 16px 0 4px;
    vertical-align: middle;
  }

  .nav-auth-link {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.25s;
    vertical-align: middle;
  }
  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #fff;
    border: 1px solid var(--border);
    min-width: 210px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    z-index: 9999;
    padding: 0;
    list-style: none;
  }

  .dropdown-menu::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
  }

  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown.open .dropdown-menu {
    display: block;
  }

  .dropdown-menu li {
    list-style: none;
  }

  .dropdown-menu li a {
    display: flex !important;
    align-items: center;
    padding: 10px 20px;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #4a4845 !important;
    text-decoration: none;
    transition:
      background 0.15s,
      color 0.15s;
    border-bottom: 1px solid var(--bg-mid);
    white-space: nowrap;
  }

  .dropdown-menu li:last-child a {
    border-bottom: none;
  }

  .dropdown-menu li a:hover {
    background: var(--bg-soft) !important;
    color: var(--gold) !important;
  }
</style>
