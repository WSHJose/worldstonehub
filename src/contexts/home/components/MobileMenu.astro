---

---

<button
  class="nav-burger"
  id="navBurger"
  aria-label="Abrir menú de navegación"
  aria-expanded="false"
  aria-controls="mobileMenu"
  style="position:fixed;top:16px;right:20px;z-index:1001;"
>
  <span></span><span></span><span></span>
</button>

<div
  class="mobile-menu"
  id="mobileMenu"
  aria-hidden="true"
  role="navigation"
  aria-label="Menú principal móvil"
>
  <ul class="mobile-menu-links">
    <li><a href="/index.html">Inicio</a></li>
    <li><a href="/materiales.html">Materiales</a></li>
    <li><a href="/proveedores.html">Directorio de empresas</a></li>
    <li><a href="/mapa.html">Mapa de canteras</a></li>
  </ul>
  <div class="mobile-menu-cta">
    <a href="/canteras.html" class="mm-cta-primary">Explorar directorio →</a>
    <a href="/registro.html" class="mm-cta-secondary">Publicar mi empresa →</a>
  </div>
  <div class="mobile-menu-langs">
    <button
      class="active"
      onclick="document.querySelector('.lang-btn[data-lang=es]').click();document.getElementById('mobileMenu').classList.remove('open');"
      >ES</button
    >
    <button
      onclick="document.querySelector('.lang-btn[data-lang=en]').click();document.getElementById('mobileMenu').classList.remove('open');"
      >EN</button
    >
  </div>
</div>

<style>
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 6px;
    margin-left: 12px;
    z-index: 1001;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #1a1917;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .nav-burger.open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger.open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-burger.open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }
  @media (max-width: 1024px) {
    .nav-burger {
      display: flex;
    }
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: #fff;
    z-index: 799;
    overflow-y: auto;
    padding: 16px 24px 48px;
    border-top: 1px solid #e2e0dc;
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu-links {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .mobile-menu-links > li > a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 0;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #4a4845;
    border-bottom: 1px solid #f0efed;
    text-decoration: none;
    cursor: pointer;
  }
  .mobile-menu-links > li > a:hover {
    color: #a67c52;
  }
  .mobile-menu-cta {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .mobile-menu-cta a {
    display: block;
    text-align: center;
    padding: 13px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'Instrument Sans', sans-serif;
  }
  .mobile-menu-cta .mm-cta-primary {
    background: #1a1917;
    color: #fff;
  }
  .mobile-menu-cta .mm-cta-primary:hover {
    background: #a67c52;
  }
  .mobile-menu-cta .mm-cta-secondary {
    border: 1px solid #c8c5bf;
    color: #1a1917;
  }
  .mobile-menu-cta .mm-cta-secondary:hover {
    border-color: #a67c52;
    color: #a67c52;
  }
  .mobile-menu-langs {
    display: flex;
    gap: 16px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #f0efed;
  }
  .mobile-menu-langs button {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8a8784;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 0;
  }
  .mobile-menu-langs button.active {
    color: #a67c52;
  }
</style>

<script>
  const burger = document.getElementById('navBurger');
  const menu = document.getElementById('mobileMenu');
  if (burger && menu) {
    burger.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('open');
      burger.classList.toggle('open', isOpen);
      burger.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });
    menu.addEventListener('click', (e) => {
      if (e.target === menu) {
        menu.classList.remove('open');
        burger.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    });
  }
</script>
