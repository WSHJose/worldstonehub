---
import { readFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { resolve, dirname } from 'path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const iconsDir = resolve(__dirname, '../../../assets/icons');
const readIcon = (name: string) => readFileSync(resolve(iconsDir, `${name}.svg`), 'utf-8');

interface ProCard {
  icon: string;
  title: string;
  desc: string;
  link: string;
  linkText: string;
}

const suppliers: ProCard[] = [
  {
    icon: readIcon('canteras'),
    title: 'Canteras',
    desc: 'Extractores y productores de piedra natural en origen, con fichas técnicas, capacidad y certificaciones.',
    link: '/canteras.html',
    linkText: 'Ver canteras →',
  },
  {
    icon: readIcon('fabricantes'),
    title: 'Fabricantes y talleres',
    desc: 'Serrerías, talleres y fábricas que transforman el bloque en producto acabado para obra e interiorismo.',
    link: '/sector.html?id=fabricantes',
    linkText: 'Ver fabricantes →',
  },
  {
    icon: readIcon('distribuidores'),
    title: 'Distribuidores',
    desc: 'Red de distribución internacional que conecta productores con arquitectos, interioristas y constructores.',
    link: '/sector.html?id=distribuidores',
    linkText: 'Ver distribuidores →',
  },
  {
    icon: readIcon('agentes'),
    title: 'Agentes y representantes',
    desc: 'Agentes comerciales e intermediarios que facilitan el acceso a mercados y productores en todo el mundo.',
    link: '/proveedores.html',
    linkText: 'Ver agentes →',
  },
  {
    icon: readIcon('logistica'),
    title: 'Logística y transporte',
    desc: 'Operadores logísticos, transportistas y agentes de aduanas especializados en el movimiento de piedra natural.',
    link: '/sector.html?id=logistica',
    linkText: 'Ver logística →',
  },
  {
    icon: readIcon('laboratorios'),
    title: 'Laboratorios y certificación',
    desc: 'Laboratorios de ensayo, organismos de certificación y entidades normativas del sector de la piedra.',
    link: '/sector.html?id=laboratorios',
    linkText: 'Ver laboratorios →',
  },
  {
    icon: readIcon('maquinaria'),
    title: 'Maquinaria industrial',
    desc: 'Fabricantes y distribuidores de maquinaria especializada en extracción, corte y transformación de piedra.',
    link: '/sector.html?id=maquinaria',
    linkText: 'Ver maquinaria →',
  },
  {
    icon: readIcon('embalaje'),
    title: 'Embalaje y palets',
    desc: 'Proveedores de soluciones de embalaje, palets y protección especializados para el transporte de piedra natural.',
    link: '/proveedores.html',
    linkText: 'Ver proveedores →',
  },
];

const buyers: ProCard[] = [
  {
    icon: readIcon('arquitectos'),
    title: 'Arquitectos e Interioristas',
    desc: 'Estudios que prescriben y especifican piedra natural en proyectos residenciales, hoteleros y comerciales.',
    link: '/sector.html?id=arquitectura',
    linkText: 'Ver directorio →',
  },
  {
    icon: readIcon('constructoras'),
    title: 'Constructoras',
    desc: 'Empresas constructoras que trabajan con piedra natural y necesitan proveedores cualificados para sus proyectos.',
    link: '/sector.html?id=constructoras',
    linkText: 'Ver directorio →',
  },
  {
    icon: readIcon('compradores'),
    title: 'Compradores corporativos',
    desc: 'Cadenas hoteleras, promotoras y grandes grupos que incorporan piedra natural en sus proyectos e instalaciones.',
    link: '/proveedores.html',
    linkText: 'Ver directorio →',
  },
  {
    icon: readIcon('instaladores'),
    title: 'Instaladores',
    desc: 'Especialistas en colocación y acabados de piedra natural en obra, con acceso a catálogos y contacto directo con fabricantes.',
    link: '/proveedores.html',
    linkText: 'Ver directorio →',
  },
];
---

<section class="professionals">
  <div style="margin-bottom:0">
    <div class="section-eyebrow">Ecosistema completo</div>
    <h2 class="section-title"><span>Todos los actores</span><br /><em>del sector</em></h2>
    <p
      style="font-family:'Cormorant Garamond',serif;font-size:17px;font-style:italic;font-weight:300;color:#8a8784;line-height:1.7;margin-top:20px;padding-top:20px;border-top:1px solid #e2e0dc;max-width:580px;letter-spacing:0.1px;"
    >
      De la cantera al proyecto final — todos los eslabones de la cadena de valor de la piedra
      natural, en un único directorio global.
    </p>
  </div>

  <div class="pro-group-label">Proveedores &amp; Servicios</div>
  <div class="pro-grid">
    {
      suppliers.map((card) => (
        <a class="pro-card" href={card.link}>
          <div class="pro-icon">
            <Fragment set:html={card.icon} />
          </div>
          <div class="pro-title">{card.title}</div>
          <div class="pro-desc">{card.desc}</div>
          <span class="pro-link">{card.linkText}</span>
        </a>
      ))
    }
  </div>

  <div class="pro-group-label pro-group-label--buyers" style="margin-top:32px;">
    Compradores &amp; Prescriptores
    <span class="pro-group-badge">Acceso gratuito</span>
  </div>
  <div class="pro-grid pro-grid--buyers">
    {
      buyers.map((card) => (
        <a class="pro-card pro-card--buyer" href={card.link}>
          <div class="pro-icon">
            <Fragment set:html={card.icon} />
          </div>
          <div class="pro-title">{card.title}</div>
          <div class="pro-desc">{card.desc}</div>
          <span class="pro-link">{card.linkText}</span>
        </a>
      ))
    }
  </div>

  <div class="pro-count" id="proCount">— operadores activos</div>
</section>

<style>
  .professionals {
    padding: 72px 60px;
    background: #f8f7f5;
  }
  .pro-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(30, 25, 20, 0.06);
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .pro-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 500px) {
    .pro-grid {
      grid-template-columns: 1fr;
    }
  }
  .pro-card {
    background: #ffffff;
    border: 1px solid #e2e0dc;
    padding: 32px 24px 28px;
    text-align: center;
    transition: background 0.3s;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .pro-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #a67c52;
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .pro-card:hover {
    background: #f2ede8;
    border-top: 2px solid #a67c52 !important;
  }
  .pro-card:hover::after {
    transform: scaleX(1);
  }
  .pro-icon {
    font-size: 36px;
    margin-bottom: 12px;
    display: block;
  }
  .pro-icon :global(svg) {
    width: 36px;
    height: 36px;
    display: block;
    margin: 0 auto;
  }
  .pro-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    color: #1a1917;
    margin: 10px 0 8px;
    line-height: 1.2;
  }
  .pro-desc {
    font-size: 12px;
    color: #8a8784;
    line-height: 1.5;
  }
  .pro-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #a67c52 !important;
    text-decoration: none !important;
    font-family: 'Instrument Sans', sans-serif;
    transition: opacity 0.2s;
  }
  .pro-link:hover {
    opacity: 0.7;
  }
  .pro-count {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #8a8784;
    margin-top: 40px;
  }
  .pro-group-label {
    font-family: 'DM Mono', monospace;
    font-size: 16px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #8a8784;
    margin-bottom: 18px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .pro-group-badge {
    background: rgba(166, 124, 82, 0.08);
    border: 1px solid rgba(166, 124, 82, 0.28);
    color: #9c8571;
    font-family: 'DM Mono', monospace;
    font-size: 7px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 10px;
  }
  .pro-card--buyer {
    border: 1px solid #e8e6e2 !important;
    background: #f5f2ed !important;
    position: relative;
  }
  .pro-card--buyer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(201, 185, 154, 0.7), rgba(201, 185, 154, 0.15));
    pointer-events: none;
  }
  .pro-grid--buyers {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 900px) {
    .pro-grid--buyers {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 1024px) {
    .professionals {
      padding: 72px 30px;
    }
  }
</style>
