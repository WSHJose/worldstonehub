---
import IconCanteras from '~icons/wsh/canteras';
import IconFabricantes from '~icons/wsh/fabricantes';
import IconDistribuidores from '~icons/wsh/distribuidores';
import IconAgentes from '~icons/wsh/agentes';
import IconLogistica from '~icons/wsh/logistica';
import IconLaboratorios from '~icons/wsh/laboratorios';
import IconMaquinaria from '~icons/wsh/maquinaria';
import IconEmbalaje from '~icons/wsh/embalaje';
import IconArquitectos from '~icons/wsh/arquitectos';
import IconConstructoras from '~icons/wsh/constructoras';
import IconCompradores from '~icons/wsh/compradores';
import IconInstaladores from '~icons/wsh/instaladores';

interface ProCard {
  icon: typeof IconCanteras;
  title: string;
  desc: string;
  link: string;
  linkText: string;
}

const suppliers: ProCard[] = [
  {
    icon: IconCanteras,
    title: 'Canteras',
    desc: 'Extractores y productores de piedra natural en origen, con fichas técnicas, capacidad y certificaciones.',
    link: '/canteras.html',
    linkText: 'Ver canteras →',
  },
  {
    icon: IconFabricantes,
    title: 'Fabricantes y talleres',
    desc: 'Serrerías, talleres y fábricas que transforman el bloque en producto acabado para obra e interiorismo.',
    link: '/sector.html?id=fabricantes',
    linkText: 'Ver fabricantes →',
  },
  {
    icon: IconDistribuidores,
    title: 'Distribuidores',
    desc: 'Red de distribución internacional que conecta productores con arquitectos, interioristas y constructores.',
    link: '/sector.html?id=distribuidores',
    linkText: 'Ver distribuidores →',
  },
  {
    icon: IconAgentes,
    title: 'Agentes y representantes',
    desc: 'Agentes comerciales e intermediarios que facilitan el acceso a mercados y productores en todo el mundo.',
    link: '/proveedores.html',
    linkText: 'Ver agentes →',
  },
  {
    icon: IconLogistica,
    title: 'Logística y transporte',
    desc: 'Operadores logísticos, transportistas y agentes de aduanas especializados en el movimiento de piedra natural.',
    link: '/sector.html?id=logistica',
    linkText: 'Ver logística →',
  },
  {
    icon: IconLaboratorios,
    title: 'Laboratorios y certificación',
    desc: 'Laboratorios de ensayo, organismos de certificación y entidades normativas del sector de la piedra.',
    link: '/sector.html?id=laboratorios',
    linkText: 'Ver laboratorios →',
  },
  {
    icon: IconMaquinaria,
    title: 'Maquinaria industrial',
    desc: 'Fabricantes y distribuidores de maquinaria especializada en extracción, corte y transformación de piedra.',
    link: '/sector.html?id=maquinaria',
    linkText: 'Ver maquinaria →',
  },
  {
    icon: IconEmbalaje,
    title: 'Embalaje y palets',
    desc: 'Proveedores de soluciones de embalaje, palets y protección especializados para el transporte de piedra natural.',
    link: '/proveedores.html',
    linkText: 'Ver proveedores →',
  },
];

const buyers: ProCard[] = [
  {
    icon: IconArquitectos,
    title: 'Arquitectos e Interioristas',
    desc: 'Estudios que prescriben y especifican piedra natural en proyectos residenciales, hoteleros y comerciales.',
    link: '/sector.html?id=arquitectura',
    linkText: 'Ver directorio →',
  },
  {
    icon: IconConstructoras,
    title: 'Constructoras',
    desc: 'Empresas constructoras que trabajan con piedra natural y necesitan proveedores cualificados para sus proyectos.',
    link: '/sector.html?id=constructoras',
    linkText: 'Ver directorio →',
  },
  {
    icon: IconCompradores,
    title: 'Compradores corporativos',
    desc: 'Cadenas hoteleras, promotoras y grandes grupos que incorporan piedra natural en sus proyectos e instalaciones.',
    link: '/proveedores.html',
    linkText: 'Ver directorio →',
  },
  {
    icon: IconInstaladores,
    title: 'Instaladores',
    desc: 'Especialistas en colocación y acabados de piedra natural en obra, con acceso a catálogos y contacto directo con fabricantes.',
    link: '/proveedores.html',
    linkText: 'Ver directorio →',
  },
];
---

<section class="bg-surface-1 px-15 py-18 max-lg:px-[30px]">
  <div>
    <div class="section-eyebrow">Ecosistema completo</div>
    <h2 class="section-title"><span>Todos los actores</span><br /><em>del sector</em></h2>
    <p
      class="font-display text-[17px] italic font-light text-text-muted leading-[1.7] mt-5 pt-5 border-t border-border max-w-[580px] tracking-[0.1px]"
    >
      De la cantera al proyecto final — todos los eslabones de la cadena de valor de la piedra
      natural, en un único directorio global.
    </p>
  </div>

  <div
    class="font-mono text-[16px] tracking-[3px] uppercase text-text-muted mb-[18px] mt-2 flex items-center gap-3"
  >
    Proveedores &amp; Servicios
  </div>
  <div class="pro-grid mt-12">
    {
      suppliers.map((card) => (
        <a class="pro-card" href={card.link}>
          <div class="pro-icon">
            <card.icon />
          </div>
          <div class="font-display text-[20px] text-text-primary mt-[10px] mb-2 leading-[1.2]">
            {card.title}
          </div>
          <div class="text-[12px] text-text-muted leading-[1.5]">{card.desc}</div>
          <span class="pro-link">{card.linkText}</span>
        </a>
      ))
    }
  </div>

  <div
    class="font-mono text-[16px] tracking-[3px] uppercase text-text-muted mb-[18px] mt-8 flex items-center gap-3"
  >
    Compradores &amp; Prescriptores
    <span
      class="bg-ochre/8 border border-ochre/28 text-[#9c8571] font-mono text-[7px] tracking-[2px] uppercase px-[10px] py-[3px]"
    >
      Acceso gratuito
    </span>
  </div>
  <div class="pro-grid pro-grid--buyers">
    {
      buyers.map((card) => (
        <a class="pro-card pro-card--buyer" href={card.link}>
          <div class="pro-icon">
            <card.icon />
          </div>
          <div class="font-display text-[20px] text-text-primary mt-[10px] mb-2 leading-[1.2]">
            {card.title}
          </div>
          <div class="text-[12px] text-text-muted leading-[1.5]">{card.desc}</div>
          <span class="pro-link">{card.linkText}</span>
        </a>
      ))
    }
  </div>

  <div id="proCount" class="font-mono text-[10px] tracking-[4px] uppercase text-text-muted mt-10">
    — operadores activos
  </div>
</section>

<style>
  .pro-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(30, 25, 20, 0.06);
  }
  @media (max-width: 900px) {
    .pro-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 500px) {
    .pro-grid {
      grid-template-columns: 1fr;
    }
  }
  .pro-card {
    background: #ffffff;
    border: 1px solid #e2e0dc;
    padding: 32px 24px 28px;
    text-align: center;
    transition: background 0.25s ease-out;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .pro-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #a67c52;
    transform: scaleX(0);
    transition: transform 0.25s ease-out;
  }
  .pro-card:hover {
    background: #f2ede8;
    border-top: 2px solid #a67c52 !important;
  }
  .pro-card:hover::after {
    transform: scaleX(1);
  }
  .pro-icon {
    font-size: 36px;
    margin-bottom: 12px;
    display: block;
  }
  .pro-icon :global(svg) {
    width: 36px;
    height: 36px;
    display: block;
    margin: 0 auto;
  }
  .pro-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #a67c52 !important;
    text-decoration: none !important;
    font-family: 'Instrument Sans', sans-serif;
    transition: opacity 0.2s ease-out;
  }
  .pro-link:hover {
    opacity: 0.7;
  }
  .pro-card--buyer {
    border: 1px solid #e8e6e2 !important;
    background: #f5f2ed !important;
    position: relative;
  }
  .pro-card--buyer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(201, 185, 154, 0.7), rgba(201, 185, 154, 0.15));
    pointer-events: none;
  }
  .pro-grid--buyers {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 900px) {
    .pro-grid--buyers {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
