<style>
  .professionals {
    padding: 72px 60px;
    background: #f8f7f5;
  }
  .pro-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(30, 25, 20, 0.06);
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .pro-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 500px) {
    .pro-grid {
      grid-template-columns: 1fr;
    }
  }
  .pro-card {
    background: #ffffff;
    border: 1px solid #e2e0dc;
    padding: 32px 24px 28px;
    text-align: center;
    transition: background 0.3s;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .pro-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #a67c52;
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .pro-card:hover {
    background: #f2ede8;
    border-top: 2px solid #a67c52 !important;
  }
  .pro-card:hover::after {
    transform: scaleX(1);
  }
  .pro-icon {
    font-size: 36px;
    margin-bottom: 12px;
    display: block;
  }
  .pro-icon svg {
    width: 36px;
    height: 36px;
    display: block;
    margin: 0 auto;
  }
  .pro-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    color: #1a1917;
    margin: 10px 0 8px;
    line-height: 1.2;
  }
  .pro-desc {
    font-size: 12px;
    color: #8a8784;
    line-height: 1.5;
  }
  .pro-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #a67c52 !important;
    text-decoration: none !important;
    font-family: 'Instrument Sans', sans-serif;
    transition: opacity 0.2s;
  }
  .pro-link:hover {
    opacity: 0.7;
  }
  .pro-count {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #8a8784;
    margin-top: 40px;
  }
  .pro-group-label {
    font-family: 'DM Mono', monospace;
    font-size: 8.5px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #8a8784;
    margin-bottom: 18px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .pro-group-badge {
    background: rgba(166, 124, 82, 0.08);
    border: 1px solid rgba(166, 124, 82, 0.28);
    color: #9c8571;
    font-family: 'DM Mono', monospace;
    font-size: 7px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 10px;
  }
  .pro-card--buyer {
    border: 1px solid #e8e6e2 !important;
    background: #f5f2ed !important;
    position: relative;
  }
  .pro-card--buyer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(201, 185, 154, 0.7), rgba(201, 185, 154, 0.15));
    pointer-events: none;
  }
  .pro-grid--buyers {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 900px) {
    .pro-grid--buyers {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 1024px) {
    .professionals {
      padding: 72px 30px;
    }
  }
</style>
