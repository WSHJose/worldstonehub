---
import GlobalSearch from './GlobalSearch.vue';
---

<div class="search-preview">
  <div class="sp-inner">
    <GlobalSearch client:load />
  </div>
</div>

<style is:global>
  .search-preview {
    background: #f8f7f5;
    border-top: 1px solid #e8e6e2;
    padding: 64px 60px 44px;
    position: relative;
    overflow: hidden;
  }
  .search-preview::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 50% 30%,
      rgba(160, 120, 60, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .sp-inner {
    max-width: 740px;
    margin: 0 auto;
    position: relative;
  }
  @media (max-width: 1024px) {
    .search-preview {
      padding: 64px 30px 44px;
    }
  }
</style>
