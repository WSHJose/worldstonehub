---
import GlobalSearch from './GlobalSearch.vue';
---

<div class="search-preview">
  <div class="sp-inner">
    <GlobalSearch client:load />
  </div>
</div>

<style is:global>
  .search-preview {
    background: #f8f7f5;
    border-top: 1px solid #e8e6e2;
    padding: 64px 60px 44px;
    position: relative;
    overflow: hidden;
  }
  .search-preview::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 50% 30%,
      rgba(160, 120, 60, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .sp-inner {
    max-width: 740px;
    margin: 0 auto;
    position: relative;
  }
  .sp-header {
    text-align: center;
    margin-bottom: 32px;
  }
  .sp-subtitle {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8a8784;
    margin-top: 12px;
  }
  .sp-bar-wrap {
    position: relative;
    margin-bottom: 16px;
  }
  .sp-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 20px;
    color: #a67c52;
    pointer-events: none;
    z-index: 2;
  }
  .sp-input {
    width: 100%;
    background: #ffffff;
    border: 1px solid #e2e0dc;
    border-radius: 0;
    color: #1a1917;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 16px;
    padding: 18px 120px 18px 52px;
    outline: none;
    transition:
      border-color 0.3s,
      box-shadow 0.3s;
    letter-spacing: 0.3px;
  }
  .sp-input:focus {
    border-color: #a67c52;
    box-shadow: 0 0 0 3px rgba(166, 124, 82, 0.1);
  }
  .sp-input::placeholder {
    color: #8a8784;
    font-size: 14px;
  }
  .sp-kbd {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8a8784;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .sp-input:focus ~ .sp-kbd {
    opacity: 1;
  }
  .sp-trending {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid rgba(30, 25, 20, 0.07);
  }
  .sp-trending-label {
    font-size: 9px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #8a8784;
    margin-bottom: 10px;
  }
  .sp-trending-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .sp-trending-tag {
    font-size: 11px;
    letter-spacing: 1px;
    padding: 6px 14px;
    border: 1px solid rgba(30, 25, 20, 0.1);
    color: #a67c52;
    cursor: pointer;
    transition: all 0.2s;
    background: transparent;
    font-family: 'Instrument Sans', sans-serif;
  }
  .sp-trending-tag:hover {
    border-color: #a67c52;
    background: rgba(160, 120, 60, 0.04);
  }
  .sp-results-wrap {
    margin-top: 4px;
  }
  .sp-results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(30, 25, 20, 0.07);
  }
  .sp-results-count {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #a67c52;
  }
  .sp-results-hint {
    font-size: 10px;
    color: #8a8784;
    letter-spacing: 1px;
  }
  .sp-results-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sp-card {
    display: flex;
    align-items: stretch;
    background: #ffffff;
    border: 1px solid #e2e0dc;
    cursor: pointer;
    transition:
      background 0.2s,
      border-color 0.2s,
      transform 0.15s;
    text-decoration: none;
    color: inherit;
    animation: spFadeIn 0.2s ease both;
  }
  .sp-card:hover {
    background: #f8f7f5;
    border-color: rgba(166, 124, 82, 0.35);
    transform: translateX(4px);
  }
  @keyframes spFadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .sp-card-thumb {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.3);
    align-self: stretch;
    display: flex;
    align-items: center;
  }
  .sp-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.9);
    transition: filter 0.2s;
  }
  .sp-card:hover .sp-card-thumb img {
    filter: brightness(1);
  }
  .sp-card-body {
    padding: 14px 16px;
    flex: 1;
    min-width: 0;
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .sp-card-main {
    flex: 1;
    min-width: 0;
  }
  .sp-card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    color: #1a1917;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sp-results-more {
    text-align: center;
    margin-top: 12px;
  }
  .sp-empty {
    text-align: center;
    padding: 32px 0;
  }
  .sp-empty-icon {
    font-size: 24px;
    color: #8a8784;
    margin-bottom: 8px;
    opacity: 0.4;
  }
  .sp-empty-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    color: #a67c52;
    margin-bottom: 6px;
  }
  .sp-empty-sub {
    font-size: 12px;
    color: #8a8784;
  }
  @media (max-width: 1024px) {
    .search-preview {
      padding: 64px 30px 44px;
    }
  }
</style>
