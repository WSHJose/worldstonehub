    white-space: nowrap;
    height: 36px;
  }
  .marquee-item {
    color: rgba(255, 255, 255, 0.9);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    padding: 0 32px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    height: 36px;
    line-height: 1;
  }
  .marquee-item::after {
    content: '·';
    margin-left: 32px;
    opacity: 0.45;
  }
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
