---

---

<section class="grid-section">
  <div class="grid-inner">
    <div id="gridContainer">
      <div class="loading-state">
        <div class="spinner"></div>
        <p data-i18n="materiales.loading">Cargando materiales</p>
      </div>
    </div>
    <div id="loadMoreWrap" style="display:none;text-align:center;padding:40px 0 16px;">
      <button
        id="loadMoreBtn"
        style="background:none;border:1px solid #c8c5bf;padding:13px 40px;font-family:'Instrument Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;cursor:pointer;color:#4a4845;transition:all .2s;"
        onmouseover="this.style.borderColor='#A67C52';this.style.color='#A67C52'"
        onmouseout="this.style.borderColor='#c8c5bf';this.style.color='#4a4845'"
      >
        Cargar más materiales
      </button>
      <div
        id="loadMoreInfo"
        style="margin-top:10px;font-size:11px;color:#8a8784;letter-spacing:.05em;"
      >
      </div>
    </div>
  </div>
</section>

<style is:global>
  .grid-section {
    padding: 36px 48px 80px;
  }
  .grid-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  /* ── CARD ── */
  .material-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition:
      box-shadow 0.25s,
      transform 0.2s,
      border-color 0.2s;
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }
  .material-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--border-md);
  }
  .card-swatch {
    height: 200px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-swatch::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  .card-cat-pill {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.88);
    color: var(--ink-2);
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    backdrop-filter: blur(4px);
  }
  .card-disp-dot {
    position: absolute;
    top: 10px;
    left: 10px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
  }
  .card-disp-dot.dot-alta {
    background: var(--gold);
  }
  .card-disp-dot.dot-media {
    background: #c9b99a;
  }
  .card-disp-dot.dot-baja {
    background: #8a8784;
  }
  .card-disp-dot.dot-pedido {
    background: var(--border2);
  }
  .card-disp-dot.dot-default {
    background: var(--border2);
  }
  .card-accent-stripe {
    height: 3px;
    width: 100%;
    display: block;
    flex-shrink: 0;
    opacity: 0.7;
  }
  .card-body {
    padding: 18px 20px 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .card-nombre {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--ink);
  }
  .card-subcat {
    font-size: 11px;
    color: var(--ink-4);
    font-style: italic;
    line-height: 1.3;
  }
  .card-origen {
    font-size: 11px;
    color: var(--ink-3);
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
    margin-top: 2px;
  }
  .card-flag {
    font-size: 15px;
    line-height: 1;
  }
  .card-origen-sep {
    color: var(--border-md);
  }
  .card-acabados {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }
  .acabado-pill {
    font-size: 8px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 2px 7px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 2px;
    font-family: 'Instrument Sans', sans-serif;
  }
  .acabado-more {
    font-size: 8px;
    letter-spacing: 1px;
    color: var(--ink-4);
    padding: 2px 4px;
    font-style: italic;
  }
  .card-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
    opacity: 0.55;
    transition: opacity 0.2s;
  }
  .material-card:hover .card-specs {
    opacity: 1;
  }
  .spec-item {
    font-size: 9px;
    letter-spacing: 0.5px;
    color: var(--ink-4);
    font-family: 'DM Mono', monospace;
  }
  .spec-k {
    color: var(--gold);
    font-weight: 500;
    margin-right: 2px;
  }
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
    margin-top: auto;
  }
  .card-precio {
    font-size: 10px;
    color: var(--ink-4);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.5px;
  }
  .card-ver-btn {
    font-size: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    padding: 6px 12px;
    border: 1px solid rgba(166, 124, 82, 0.3);
    border-radius: var(--radius);
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s,
      border-color 0.2s;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    white-space: nowrap;
  }
  .card-ver-btn:hover {
    background: var(--gold);
    color: #fff;
    border-color: var(--gold);
  }
  .card-quality-badge {
    font-size: 9px;
    letter-spacing: 1px;
    padding: 4px 8px;
    border-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-weight: 400;
    flex-shrink: 0;
    line-height: 1;
  }
  .card-quality-full {
    background: linear-gradient(135deg, #c9a84c22, #a67c5222);
    color: #a67c52;
    border: 1px solid rgba(166, 124, 82, 0.35);
  }
  .card-quality-mid {
    background: var(--bg-mid);
    color: var(--ink-3, #8a8784);
    border: 1px solid var(--border);
  }

  /* ── EMPTY / LOADING ── */
  .empty-state {
    padding: 80px 0;
    text-align: center;
  }
  .empty-state svg {
    opacity: 0.15;
    margin-bottom: 20px;
  }
  .empty-state p {
    font-size: 18px;
    color: var(--ink-4);
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
  }
  .empty-state small {
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--ink-4);
    display: block;
    margin-top: 10px;
  }
  .loading-state {
    padding: 80px 0;
    text-align: center;
  }
  .spinner {
    width: 28px;
    height: 28px;
    border: 2px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .loading-state p {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ink-4);
  }

  @media (max-width: 960px) {
    .grid-section {
      padding-left: 24px;
      padding-right: 24px;
    }
  }
  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
