---

---

<header class="page-header">
  <div class="ph-left">
    <div>
      <p class="ph-eyebrow" data-i18n="hero.materiales.eyebrow">Directorio técnico</p>
      <h1>
        <span data-i18n="hero.materiales.title">Materiales de</span><br /><em
          data-i18n="hero.materiales.titleItalic">Piedra Natural</em
        >
      </h1>
      <p class="ph-desc" data-i18n="hero.materiales.desc">
        Fichas técnicas completas de materiales de piedra natural y superficies. Propiedades,
        acabados, formatos, origen y proyectos de referencia.
      </p>
    </div>
    <div class="ph-stats">
      <div class="stat-block">
        <span class="stat-n" id="statMateriales">—</span>
        <span class="stat-l" data-i18n="stats.materiales">Materiales</span>
      </div>
      <div class="stat-block">
        <span class="stat-n">16</span>
        <span class="stat-l" data-i18n="stats.categorias">Categorías</span>
      </div>
      <div class="stat-block">
        <span class="stat-n" id="statPaises">—</span>
        <span class="stat-l" data-i18n="stats.paises">Países</span>
      </div>
      <div class="stat-block">
        <span class="stat-n" id="statColores">—</span>
        <span class="stat-l" data-i18n="stats.colores">Colores</span>
      </div>
    </div>
  </div>
  <div class="ph-right" id="featuredPanel">
    <div class="featured-stone-loading" id="featuredLoading">
      <div class="spinner"></div>
    </div>
    <div id="featuredSlot" style="position:absolute;inset:0;"></div>
  </div>
</header>

<style is:global>
  .page-header {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 280px;
    margin-top: 70px;
  }
  .ph-left {
    padding: 52px 56px 44px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 1px solid var(--border);
  }
  .ph-eyebrow {
    font-size: 9px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    font-family: 'DM Mono', monospace;
  }
  .ph-left h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -1px;
    color: var(--ink);
  }
  .ph-left h1 em {
    font-style: italic;
    color: var(--gold);
  }
  .ph-desc {
    margin-top: 12px;
    font-size: 13px;
    color: var(--ink-3);
    max-width: 420px;
    line-height: 1.75;
    flex: 1;
    padding-top: 12px;
  }
  .ph-stats {
    display: flex;
    gap: 0;
    margin-top: 32px;
    border-top: 1px solid var(--border);
  }
  .stat-block {
    flex: 1;
    padding: 16px 20px 0;
    border-right: 1px solid var(--border);
  }
  .stat-block:last-child {
    border-right: none;
  }
  .stat-n {
    font-family: 'DM Mono', monospace;
    font-size: 24px;
    font-weight: 400;
    color: var(--ink);
    display: block;
    line-height: 1;
  }
  .stat-l {
    font-size: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ink-4);
    display: block;
    margin-top: 5px;
  }

  /* ── FEATURED STONE ── */
  .ph-right {
    position: relative;
    overflow: hidden;
    background: #1a1917;
  }
  .featured-stone {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .featured-stone > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }
  .ph-right:hover .featured-stone > img {
    transform: scale(1.04);
  }
  .featured-stone-origin img {
    width: 18px !important;
    height: 18px !important;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .featured-stone-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.18) 55%,
      transparent 100%
    );
  }
  .featured-stone-badge {
    position: absolute;
    top: 18px;
    right: 18px;
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--ink-2);
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    backdrop-filter: blur(4px);
  }
  .featured-stone-eyebrow {
    position: absolute;
    top: 20px;
    left: 22px;
    font-size: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    font-family: 'DM Mono', monospace;
  }
  .featured-stone-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 22px 26px 26px;
  }
  .featured-stone-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 7px;
  }
  .featured-stone-origin {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.65);
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 16px;
  }
  .featured-stone-cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.45);
    padding: 9px 18px;
    transition: all 0.2s;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
  }
  .featured-stone-cta:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #fff;
  }
  .featured-stone-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a1917;
  }

  @media (max-width: 960px) {
    .page-header {
      grid-template-columns: 1fr;
      padding-left: 24px;
      padding-right: 24px;
    }
    .ph-right {
      min-height: 200px;
      border-top: 1px solid var(--border);
    }
    .ph-left {
      border-right: none;
    }
  }
  @media (max-width: 640px) {
    .ph-left h1 {
      font-size: 36px;
    }
    .ph-stats {
      flex-wrap: wrap;
    }
    .stat-block {
      flex: 0 0 50%;
    }
  }
</style>
