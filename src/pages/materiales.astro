          filteredList.length +
          " materiales";
      } else moreWrap.style.display = "none";
    }
    document
      .getElementById("loadMoreBtn")
      .addEventListener("click", function () {
        currentPage++;
        renderGrid(null, false);
        var grid = document.querySelector(".cards-grid");
        if (grid) {
          var lastCard = grid.children[(currentPage - 1) * PAGE_SIZE];
          if (lastCard)
            lastCard.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    function applyFilters() {
      var q = searchQuery.trim().toLowerCase(),
        fc = activeFilters.cat,
        fcolor = activeFilters.color;
      var CAT_NORM = {
        bluestone: "piedra azul",
        "blue stone": "piedra azul",
        esquisto: "pizarra",
        phyllite: "pizarra",
        filita: "pizarra",
        gneis: "granito",
        gneiss: "granito",
        felsite: "basalto",
        rhyolite: "basalto",
        soapstone: "pizarra",
        cantera: "caliza",
        limestone: "caliza",
        jade: "ónix",
        serpentinite: "ónix",
        mármol: "mármol",
        marble: "mármol",
        granite: "granito",
        sandstone: "arenisca",
        quartzite: "cuarcita",
        slate: "pizarra",
        travertine: "travertino",
        onyx: "ónix",
        basalt: "basalto",
        alabaster: "alabastro",
        andesite: "andesita",
        porphyry: "pórfido",
        tuff: "toba",
        "toba volcánica": "toba",
      };
      var result = DB.filter(function (m) {
        if (fc) {
          var catRaw = (m.categoria || "").toLowerCase();
          var catNorm = CAT_NORM[catRaw] || catRaw;
          if (catNorm !== fc) return false;
        }
        if (fcolor && getColorGroup(m.color_principal) !== fcolor) return false;
        if (q) {
          var names = arr(m.nombres_alternativos).join(" "),
            usos = arr(m.usos_recomendados).join(" ");
          var acab = arr(m.acabados_disponibles).join(" "),
            pais = arr(m.origen_pais).join(" ");
          var reg = getRegionDisplay(m.origen_region),
            tags = arr(m.tags_busqueda).join(" ");
          var hay = [
            m.nombre_comercial,
            names,
            m.categoria,
            m.color_principal,
            m.color_acento,
            pais,
            reg,
            usos,
            acab,
            tags,
          ]
            .join(" ")
            .toLowerCase();
          if (hay.indexOf(q) === -1) return false;
        }
        return true;
      });
      result.sort(function (a, b) {
        if (activeSort === "calidad") {
          var sa = a.content_score || 0,
            sb = b.content_score || 0;
          return (
            sb - sa ||
            (a.nombre_comercial || "").localeCompare(
              b.nombre_comercial || "",
              "es",
            )
          );
        }
        if (activeSort === "za")
          return (b.nombre_comercial || "").localeCompare(
            a.nombre_comercial || "",
            "es",
          );
        if (activeSort === "pais") {
          var pa = arr(a.origen_pais)[0] || "",
            pb = arr(b.origen_pais)[0] || "";
          return (
            pa.localeCompare(pb, "es") ||
            (a.nombre_comercial || "").localeCompare(
              b.nombre_comercial || "",
              "es",
            )
          );
        }
        if (activeSort === "cat")
          return (
            (a.categoria || "").localeCompare(b.categoria || "", "es") ||
            (a.nombre_comercial || "").localeCompare(
              b.nombre_comercial || "",
              "es",
            )
          );
        if (activeSort === "precio_asc" || activeSort === "precio_desc") {
          function extractP(s) {
            if (!s) return activeSort === "precio_asc" ? Infinity : -1;
            var mx = (s + "").match(/[\d]+([.,]\d+)?/);
            return mx
              ? parseFloat(mx[0].replace(",", "."))
              : activeSort === "precio_asc"
                ? Infinity
                : -1;
          }
          var pa = extractP(a.precio_orientativo),
            pb = extractP(b.precio_orientativo);
          return activeSort === "precio_asc" ? pa - pb : pb - pa;
        }
        return (a.nombre_comercial || "").localeCompare(
          b.nombre_comercial || "",
          "es",
        );
      });
      renderGrid(result, true);
      document.getElementById("resultsCount").textContent =
        result.length === DB.length
          ? DB.length + " materiales"
          : result.length + " de " + DB.length;
      updateActiveBanner();
    }
    document
      .getElementById("searchInput")
      .addEventListener("input", function () {
        searchQuery = this.value;
        applyFilters();
      });
    document.querySelectorAll(".filter-chip").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var group = this.dataset.group,
          val = this.dataset.val;
        if (activeFilters[group] === val) {
          activeFilters[group] = null;
          this.classList.remove("active");
        } else {
          document
            .querySelectorAll('[data-group="' + group + '"]')
            .forEach(function (b) {
              b.classList.remove("active");
            });
          activeFilters[group] = val;
          this.classList.add("active");
        }
        applyFilters();
      });
    });
    document
      .getElementById("clearFilters")
      .addEventListener("click", function () {
        clearAllFilters();
      });
    document
      .getElementById("sortSelect")
      .addEventListener("change", function () {
        activeSort = this.value;
        applyFilters();
      });
    function updateActiveBanner() {
      var banner = document.getElementById("activeBanner");
      if (!banner) return;
      var tags = [];
      if (activeFilters.cat)
        tags.push(
          '<span class="active-tag">' +
            esc(
              activeFilters.cat.charAt(0).toUpperCase() +
                activeFilters.cat.slice(1),
            ) +
            '<span class="active-tag-x" onclick="clearFilter(\'cat\')">×</span></span>',
        );
      if (activeFilters.color)
        tags.push(
          '<span class="active-tag">' +
            esc(activeFilters.color) +
            '<span class="active-tag-x" onclick="clearFilter(\'color\')">×</span></span>',
        );
      if (searchQuery.trim())
        tags.push(
          '<span class="active-tag">«' +
            esc(trunc(searchQuery.trim(), 24)) +
            '»<span class="active-tag-x" onclick="clearSearch()">×</span></span>',
        );
      if (tags.length) {
        banner.className = "active-banner visible";
        banner.innerHTML =
          tags.join("") +
          '<button class="active-banner-clear" onclick="clearAllFilters()">Limpiar todo ×</button>';
      } else {
        banner.className = "active-banner";
        banner.innerHTML = "";
      }
    }
    function clearFilter(group) {
      activeFilters[group] = null;
      document
        .querySelectorAll('[data-group="' + group + '"]')
        .forEach(function (b) {
          b.classList.remove("active");
        });
      applyFilters();
    }
    function clearSearch() {
      searchQuery = "";
      document.getElementById("searchInput").value = "";
      applyFilters();
    }
    function clearAllFilters() {
      activeFilters = { cat: null, color: null };
      searchQuery = "";
      document.getElementById("searchInput").value = "";
      document.querySelectorAll(".filter-chip").forEach(function (b) {
        b.classList.remove("active");
      });
      applyFilters();
    }
    function showFeaturedStone() {
      var loading = document.getElementById("featuredLoading"),
        slot = document.getElementById("featuredSlot");
      if (!slot) return;
      var pool = DB.filter(function (m) {
        return m.imagen_url_principal && (m.content_score || 0) >= 80;
      });
      if (!pool.length)
        pool = DB.filter(function (m) {
          return m.imagen_url_principal && (m.content_score || 0) >= 50;
        });
      if (!pool.length)
        pool = DB.filter(function (m) {
          return m.imagen_url_principal;
        }).slice(0, 200);
      if (!pool.length) {
        if (loading) loading.style.display = "none";
        return;
      }
      var m = pool[Math.floor(Math.random() * pool.length)];
      var flag = getFlag(arr(m.origen_pais)[0]),
        pais = arr(m.origen_pais)[0] || "";
      if (loading) loading.style.display = "none";
      slot.innerHTML =
        '<div class="featured-stone"><img src="' +
        esc(m.imagen_url_principal) +
        '" alt="' +
        esc(m.nombre_comercial || "") +
        '" loading="lazy"><div class="featured-stone-overlay"></div><span class="featured-stone-eyebrow">Piedra destacada</span><span class="featured-stone-badge">' +
        esc(m.categoria || "") +
        '</span><div class="featured-stone-body"><div class="featured-stone-name">' +
        esc(m.nombre_comercial || "") +
        "</div>" +
        (pais
          ? '<div class="featured-stone-origin">' +
            (flag || "") +
            "<span>" +
            esc(pais) +
            "</span></div>"
          : "") +
        (m.slug
          ? '<a class="featured-stone-cta" href="material.html?id=' +
            esc(m.slug) +
            '" onclick="event.stopPropagation()">Ver ficha →</a>'
          : "") +
        "</div></div>";
      if (m.slug) {
        document.getElementById("featuredPanel").style.cursor = "pointer";
        document.getElementById("featuredPanel").onclick = function (e) {
          if (!e.target.closest(".featured-stone-cta"))
            location.href = "material.html?id=" + encodeURIComponent(m.slug);
        };
      }
    }
    (function loadMateriales() {
      var SELECT =
        "slug,nombre_comercial,nombres_alternativos,categoria,origen_pais,origen_region,color_principal,color_acento,acabados_disponibles,usos_recomendados,propiedades_tecnicas,tags_busqueda,imagen_url_principal,activo,content_score,precio_orientativo";
      var BASE =
        SB_URL +
        "/rest/v1/materiales?select=" +
        SELECT +
        "&activo=eq.true&order=content_score.desc.nullslast,nombre_comercial.asc";
      var PAGE = 1000,
        allData = [];
      function fetchPage(offset) {
        return fetch(BASE, {
          headers: {
            apikey: SB_KEY,
            Authorization: "Bearer " + SB_KEY,
            Accept: "application/json",
            Range: offset + "-" + (offset + PAGE - 1),
          },
        }).then(function (r) {
          return r.json();
        });
      }
      function loadAll(offset) {
        fetchPage(offset)
          .then(function (data) {
            if (!Array.isArray(data)) {
              document.getElementById("gridContainer").innerHTML =
                '<div class="empty-state"><p>Error al cargar</p><small>' +
                JSON.stringify(data).slice(0, 120) +
                "</small></div>";
              return;
            }
            allData = allData.concat(data);
            if (data.length === PAGE) {
              loadAll(offset + PAGE);
            } else {
              DB = allData;
              var paises = {},
                colores = {};
              DB.forEach(function (m) {
                arr(m.origen_pais).forEach(function (p) {
                  if (p) paises[p] = 1;
                });
                if (m.color_principal) colores[m.color_principal] = 1;
              });
              document.getElementById("statMateriales").textContent = DB.length;
              document.getElementById("statPaises").textContent =
                Object.keys(paises).length;
              document.getElementById("statColores").textContent =
                Object.keys(colores).length;
              showFeaturedStone();
              applyFilters();
            }
          })
          .catch(function (err) {
            if (allData.length) {
              DB = allData;
              applyFilters();
            } else
              document.getElementById("gridContainer").innerHTML =
                '<div class="empty-state"><p>No se pudo conectar</p><small>' +
                err.message +
                "</small></div>";
          });
      }
      loadAll(0);
    })();
  </script>
</Page>
