---
import Page from '../layouts/Page.astro';
import MaterialesHeader from '../contexts/materials/components/MaterialesHeader.astro';
import MaterialesToolbar from '../contexts/materials/components/MaterialesToolbar.astro';
import MaterialesActiveBanner from '../contexts/materials/components/MaterialesActiveBanner.astro';
import MaterialesGrid from '../contexts/materials/components/MaterialesGrid.astro';
---

<Page
  title="Materiales de Piedra Natural — Fichas Técnicas · World Stone Hub"
  description="Base de datos de más de 200 materiales de piedra natural. Fichas técnicas con propiedades físicas, acabados, formatos, origen y proyectos de referencia. Mármol, granito, cuarcita, travertino y más."
  ogTitle="Materiales de Piedra Natural — World Stone Hub"
  ogDescription="Fichas técnicas completas de materiales de piedra natural: propiedades, acabados, formatos y origen."
  ogUrl="https://worldstonehub.com/materiales.html"
  activePage="materiales"
>
  <MaterialesHeader />
  <MaterialesToolbar />
  <MaterialesActiveBanner />
  <MaterialesGrid />

  <script>
    import { getAll as getMaterialesAll } from '@contexts/materials/services/http/materialsHttp';
    import type { Material } from '@contexts/materials/services/http/materialsHttp.types';
    import { getFlagImg } from '@contexts/shared/utils/flags';

    type FilterGroup = 'cat' | 'color';
    type SortKey = 'calidad' | 'az' | 'za' | 'precio_asc' | 'precio_desc' | 'pais' | 'cat';
    interface ActiveFilters {
      cat: string | null;
      color: string | null;
    }
    interface PropiedadesTecnicas {
      densidad_kg_m3?: number | string;
      absorcion_agua_pct?: number | string;
      resistencia_flexion_mpa?: number | string;
    }

    /* ── STATE ── */
    let DB: Material[] = [];
    let activeFilters: ActiveFilters = { cat: null, color: null };
    let searchQuery = '';
    let activeSort: SortKey = 'calidad';
    const PAGE_SIZE = 48;
    let currentPage = 1;
    let filteredList: Material[] = [];

    /* ── CONSTANTS: ACABADOS ── */
    const ACABADOS_ES: Record<string, string> = {
      Polished: 'Pulido',
      Honed: 'Apomazado',
      Brushed: 'Cepillado',
      Flamed: 'Flameado',
      Sandblasted: 'Arenado',
      'Bush Hammered': 'Abujardado',
      Tumbled: 'Envejecido',
      Antiqued: 'Envejecido',
      Split: 'Partido',
      Sawn: 'Aserrado',
      'Machine Cut': 'Corte máquina',
      'Natural Surface': 'Superficie natural',
      'Acid Washing': 'Lavado ácido',
      Leathered: 'Cuero',
      Filled: 'Relleno',
      Chiseled: 'Cincelado',
      Combed: 'Peinado',
      Grooved: 'Estriado',
      Hammered: 'Martillado',
      'Resin Treated': 'Tratado resina',
      'Water Jet': 'Chorro agua',
      'Sawn Cut': 'Serrado',
      'River Worn': 'Rodado',
      'Feature Rocks': 'Piedra decorativa',
      Rockfaced: 'Rústico',
      Sanded: 'Lijado',
      Pickling: 'Decapado',
      Lappato: 'Lappato',
      'Shot Blasted': 'Granallado',
      Leather: 'Cuero',
    };
    const _ACABADOS_LOWER: Record<string, string> = {};
    (function () {
      for (const k in ACABADOS_ES) _ACABADOS_LOWER[k.toLowerCase()] = ACABADOS_ES[k];
    })();
    function tradAcabado(a: string): string {
      if (!a) return a;
      return ACABADOS_ES[a] || _ACABADOS_LOWER[a.toLowerCase()] || a;
    }

    /* ── CONSTANTS: COLORS ── */
    const COLOR_MAP: Record<string, [string, string]> = {
      blanco: ['#f7f5f2', '#ece9e4'],
      negro: ['#2c2a27', '#1a1917'],
      antracita: ['#4a4845', '#2c2a27'],
      gris: ['#b0aaa4', '#8a8480'],
      plateado: ['#c8c4be', '#a8a49e'],
      beige: ['#d9c4a8', '#c4a87e'],
      crema: ['#f0e4cc', '#e0ccaa'],
      arena: ['#d8c498', '#c0a870'],
      miel: ['#d4a84c', '#b88830'],
      marrón: ['#9a7456', '#7a5438'],
      marron: ['#9a7456', '#7a5438'],
      chocolate: ['#6d4c3a', '#4e3428'],
      café: ['#8a6450', '#6a4438'],
      verde: ['#7ab07e', '#4a8a50'],
      esmeralda: ['#3a9a70', '#1a7a50'],
      rojo: ['#c06050', '#903838'],
      rosa: ['#d898a8', '#b86880'],
      burdeos: ['#8a3848', '#6a2030'],
      coral: ['#e08868', '#c06040'],
      azul: ['#6090c0', '#3060a0'],
      'azul celeste': ['#80b0e0', '#5090c8'],
      'azul imperial': ['#3050a0', '#183080'],
      amarillo: ['#e8d060', '#c8a830'],
      dorado: ['#c89830', '#a87010'],
      naranja: ['#e09050', '#c06820'],
      morado: ['#9060b0', '#703090'],
      violeta: ['#7858a8', '#503880'],
      lila: ['#b090c8', '#9068a8'],
      translúcido: ['#a8d8e0', '#78b8c8'],
      white: ['#f7f5f2', '#ece9e4'],
      ivory: ['#f0e8d8', '#e0d0b8'],
      'semi white': ['#f0eee8', '#e0dcd4'],
      black: ['#2c2a27', '#1a1917'],
      anthracite: ['#4a4845', '#2c2a27'],
      grey: ['#b0aaa4', '#8a8480'],
      gray: ['#b0aaa4', '#8a8480'],
      silver: ['#c8c4be', '#a8a49e'],
      cream: ['#f0e4cc', '#e0ccaa'],
      buff: ['#d8c498', '#c0a870'],
      sand: ['#d8c498', '#c0a870'],
      taupe: ['#c4b49a', '#a89878'],
      brown: ['#9a7456', '#7a5438'],
      coffee: ['#8a6450', '#6a4438'],
      walnut: ['#6d4c3a', '#4e3428'],
      green: ['#7ab07e', '#4a8a50'],
      emerald: ['#3a9a70', '#1a7a50'],
      forest: ['#3a7040', '#206030'],
      red: ['#c06050', '#903838'],
      pink: ['#d898a8', '#b86880'],
      rose: ['#d898a8', '#b86880'],
      burgundy: ['#8a3848', '#6a2030'],
      bordeaux: ['#8a3848', '#6a2030'],
      blue: ['#6090c0', '#3060a0'],
      navy: ['#2a4870', '#183058'],
      cobalt: ['#3060b0', '#1848a0'],
      yellow: ['#e8d060', '#c8a830'],
      gold: ['#c89830', '#a87010'],
      amber: ['#d08820', '#b06800'],
      orange: ['#e09050', '#c06820'],
      ochre: ['#c89040', '#a87020'],
      purple: ['#9060b0', '#703090'],
      violet: ['#7858a8', '#503880'],
      lilac: ['#b090c8', '#9068a8'],
      multicolor: ['#d4c4b0', '#b8a890'],
    };
    function getSwatchGradient(c: string | undefined): [string, string] {
      if (!c) return ['#c8c4be', '#a8a49e'];
      const cl = c.toLowerCase();
      const keys = Object.keys(COLOR_MAP);
      for (let i = 0; i < keys.length; i++) {
        if (cl.indexOf(keys[i]) !== -1) return COLOR_MAP[keys[i]];
      }
      return ['#c8c4be', '#a8a49e'];
    }
    function getColorGroup(cp: string | undefined): string {
      if (!cp) return '';
      var c = cp.toLowerCase();
      if (
        c.indexOf('blanco') !== -1 ||
        c.indexOf('white') !== -1 ||
        c.indexOf('ivory') !== -1 ||
        c.indexOf('semi white') !== -1
      )
        return 'Blanco';
      if (
        c.indexOf('negro') !== -1 ||
        c.indexOf('antracita') !== -1 ||
        c.indexOf('black') !== -1 ||
        c.indexOf('anthracite') !== -1
      )
        return 'Negro';
      if (
        c.indexOf('gris') !== -1 ||
        c.indexOf('plateado') !== -1 ||
        c.indexOf('grey') !== -1 ||
        c.indexOf('gray') !== -1 ||
        c.indexOf('silver') !== -1
      )
        return 'Gris';
      if (
        c.indexOf('beige') !== -1 ||
        c.indexOf('crema') !== -1 ||
        c.indexOf('arena') !== -1 ||
        c.indexOf('miel') !== -1 ||
        c.indexOf('cream') !== -1 ||
        c.indexOf('buff') !== -1 ||
        c.indexOf('sand') !== -1 ||
        c.indexOf('taupe') !== -1
      )
        return 'Beige';
      if (
        c.indexOf('marrón') !== -1 ||
        c.indexOf('marron') !== -1 ||
        c.indexOf('chocolate') !== -1 ||
        c.indexOf('café') !== -1 ||
        c.indexOf('brown') !== -1 ||
        c.indexOf('coffee') !== -1 ||
        c.indexOf('walnut') !== -1
      )
        return 'Marrón';
      if (
        c.indexOf('verde') !== -1 ||
        c.indexOf('esmeralda') !== -1 ||
        c.indexOf('green') !== -1 ||
        c.indexOf('emerald') !== -1 ||
        c.indexOf('forest') !== -1
      )
        return 'Verde';
      if (
        c.indexOf('azul') !== -1 ||
        c.indexOf('blue') !== -1 ||
        c.indexOf('navy') !== -1 ||
        c.indexOf('cobalt') !== -1
      )
        return 'Azul';
      if (
        c.indexOf('rojo') !== -1 ||
        c.indexOf('rosa') !== -1 ||
        c.indexOf('burdeos') !== -1 ||
        c.indexOf('coral') !== -1 ||
        c.indexOf('red') !== -1 ||
        c.indexOf('pink') !== -1 ||
        c.indexOf('rose') !== -1 ||
        c.indexOf('burgundy') !== -1 ||
        c.indexOf('bordeaux') !== -1 ||
        c.indexOf('lilac') !== -1 ||
        c.indexOf('lila') !== -1 ||
        c.indexOf('purple') !== -1 ||
        c.indexOf('violet') !== -1 ||
        c.indexOf('morado') !== -1
      )
        return 'Rojo';
      if (
        c.indexOf('dorado') !== -1 ||
        c.indexOf('amarillo') !== -1 ||
        c.indexOf('oro') !== -1 ||
        c.indexOf('gold') !== -1 ||
        c.indexOf('yellow') !== -1 ||
        c.indexOf('amber') !== -1 ||
        c.indexOf('ochre') !== -1 ||
        c.indexOf('orange') !== -1 ||
        c.indexOf('naranja') !== -1
      )
        return 'Dorado';
      return '';
    }

    /* ── FLAGS ── */
    function getFlag(p: string | string[] | null | undefined): string {
      return getFlagImg(p);
    }

    /* ── HELPERS ── */
    function esc(s: unknown): string {
      return (s == null ? '' : String(s))
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
    function trunc(s: unknown, n: number): string {
      const str = s == null ? '' : String(s);
      return str.length > n ? str.slice(0, n) + '…' : str;
    }
    function arr(v: unknown): string[] {
      if (!v) return [];
      if (Array.isArray(v)) return v.map(String);
      if (typeof v === 'string') {
        const s = v.trim();
        if (s.charAt(0) === '[') {
          try {
            const p = JSON.parse(s);
            if (Array.isArray(p)) return p.map(String);
          } catch (e) {}
        }
        if (s.charAt(0) === '{' && s.charAt(s.length - 1) === '}') {
          const inner = s.slice(1, -1);
          try {
            const p2 = JSON.parse('[' + inner + ']');
            if (Array.isArray(p2)) return p2.map(String);
          } catch (e) {}
          return [inner];
        }
        return [v];
      }
      return [String(v)];
    }
    function getRegionDisplay(v: unknown): string {
      const items = arr(v);
      if (!items.length) return '';
      const r = items[0].trim();
      const m = r.match(/\(([^)]+)\)/);
      if (m) return m[1].trim();
      return r;
    }

    /* ── BUILD CARD ── */
    function buildCard(m: Material): string {
      const colors = getSwatchGradient(m.color_principal);
      const gradient = 'linear-gradient(135deg,' + colors[0] + ' 0%,' + colors[1] + ' 100%)';
      const paises = arr(m.origen_pais);
      const regionStr = trunc(getRegionDisplay(m.origen_region), 30);
      const flag = getFlag(paises[0]);
      const paisStr = paises.slice(0, 2).join(' · ');
      const acabados = arr(m.acabados_disponibles);
      const MAX_ACAB = 4;
      let acabHtml = '';
      for (let i = 0; i < Math.min(acabados.length, MAX_ACAB); i++) {
        acabHtml += '<span class="acabado-pill">' + esc(tradAcabado(acabados[i])) + '</span>';
      }
      if (acabados.length > MAX_ACAB) {
        acabHtml += '<span class="acabado-more">+' + (acabados.length - MAX_ACAB) + ' más</span>';
      }

      const pt = (m.propiedades_tecnicas || {}) as PropiedadesTecnicas;
      let specsHtml = '';
      if (pt.densidad_kg_m3 || pt.absorcion_agua_pct || pt.resistencia_flexion_mpa) {
        specsHtml = '<div class="card-specs">';
        if (pt.densidad_kg_m3)
          specsHtml +=
            '<span class="spec-item"><span class="spec-k">ρ</span> ' +
            pt.densidad_kg_m3 +
            ' kg/m³</span>';
        if (pt.absorcion_agua_pct)
          specsHtml +=
            '<span class="spec-item"><span class="spec-k">Abs.</span> ' +
            pt.absorcion_agua_pct +
            '%</span>';
        if (pt.resistencia_flexion_mpa)
          specsHtml +=
            '<span class="spec-item"><span class="spec-k">Flex.</span> ' +
            pt.resistencia_flexion_mpa +
            ' MPa</span>';
        specsHtml += '</div>';
      }

      const verBtn = m.slug
        ? '<a class="card-ver-btn" href="material.html?id=' +
          esc(m.slug) +
          '" onclick="event.stopPropagation()">Ver ficha →</a>'
        : '';

      const score = m.content_score || 0;
      let qualityBadge = '';
      if (score >= 80) {
        qualityBadge =
          '<span class="card-quality-badge card-quality-full" title="Ficha completa · ' +
          score +
          '/100">★★★</span>';
      } else if (score >= 50) {
        qualityBadge =
          '<span class="card-quality-badge card-quality-mid" title="Ficha parcial · ' +
          score +
          '/100">★★</span>';
      }

      const accentColors = getSwatchGradient(m.color_acento || m.color_principal);
      const accentStripe =
        '<span class="card-accent-stripe" style="background:linear-gradient(90deg,' +
        accentColors[0] +
        ',' +
        accentColors[1] +
        ');"></span>';

      return (
        '<div class="material-card" onclick="' +
        (m.slug ? "location.href='material.html?id=" + esc(m.slug) + "'" : '') +
        '">' +
        '<div class="card-swatch" style="background:' +
        gradient +
        '">' +
        (m.imagen_url_principal
          ? '<img src="' +
            esc(m.imagen_url_principal) +
            '" alt="' +
            esc(m.nombre_comercial || '') +
            '" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block" loading="lazy" onerror="this.parentElement.style.background=\'#e8e5e0\'">'
          : '') +
        '<span class="card-cat-pill">' +
        esc(m.categoria || '') +
        '</span>' +
        '</div>' +
        accentStripe +
        '<div class="card-body">' +
        '<div class="card-nombre">' +
        esc(m.nombre_comercial || 'Sin nombre') +
        '</div>' +
        (paisStr || regionStr
          ? '<div class="card-origen">' +
            (flag ? '<span class="card-flag">' + flag + '</span>' : '') +
            (paisStr ? '<span>' + esc(paisStr) + '</span>' : '') +
            (regionStr
              ? '<span class="card-origen-sep">·</span><span style="color:var(--ink-4)">' +
                esc(regionStr) +
                '</span>'
              : '') +
            '</div>'
          : '') +
        (acabHtml ? '<div class="card-acabados">' + acabHtml + '</div>' : '') +
        specsHtml +
        '</div>' +
        '<div class="card-footer">' +
        verBtn +
        qualityBadge +
        '</div>' +
        '</div>'
      );
    }

    /* ── GRID RENDER ── */
    function renderGrid(list: Material[] | null, reset: boolean): void {
      const container = document.getElementById('gridContainer') as HTMLElement | null;
      const moreWrap = document.getElementById('loadMoreWrap') as HTMLElement | null;
      const moreInfo = document.getElementById('loadMoreInfo') as HTMLElement | null;
      if (!container || !moreWrap || !moreInfo) return;
      if (reset && list) {
        currentPage = 1;
        filteredList = list;
      }
      if (!filteredList.length) {
        container.innerHTML =
          '<div class="empty-state"><svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><p>Sin resultados</p><small>Prueba con otros filtros o términos</small></div>';
        moreWrap.style.display = 'none';
        return;
      }
      const visible = filteredList.slice(0, currentPage * PAGE_SIZE);
      let html = '<div class="cards-grid">';
      for (let i = 0; i < visible.length; i++) html += buildCard(filteredList[i]);
      html += '</div>';
      container.innerHTML = html;
      const remaining = filteredList.length - visible.length;
      if (remaining > 0) {
        moreWrap.style.display = 'block';
        moreInfo.textContent =
          'Mostrando ' + visible.length + ' de ' + filteredList.length + ' materiales';
      } else moreWrap.style.display = 'none';
    }

    /* ── FILTERS / SEARCH / SORT ── */
    const CAT_NORM: Record<string, string> = {
      bluestone: 'piedra azul',
      'blue stone': 'piedra azul',
      esquisto: 'pizarra',
      phyllite: 'pizarra',
      filita: 'pizarra',
      gneis: 'granito',
      gneiss: 'granito',
      felsite: 'basalto',
      rhyolite: 'basalto',
      soapstone: 'pizarra',
      cantera: 'caliza',
      limestone: 'caliza',
      jade: 'ónix',
      serpentinite: 'ónix',
      mármol: 'mármol',
      marble: 'mármol',
      granite: 'granito',
      sandstone: 'arenisca',
      quartzite: 'cuarcita',
      slate: 'pizarra',
      travertine: 'travertino',
      onyx: 'ónix',
      basalt: 'basalto',
      alabaster: 'alabastro',
      andesite: 'andesita',
      porphyry: 'pórfido',
      tuff: 'toba',
      'toba volcánica': 'toba',
    };

    function applyFilters(): void {
      const q = searchQuery.trim().toLowerCase();
      const fc = activeFilters.cat;
      const fcolor = activeFilters.color;
      const result = DB.filter(function (m: Material) {
        if (fc) {
          const catRaw = (m.categoria || '').toLowerCase();
          const catNorm = CAT_NORM[catRaw] || catRaw;
          if (catNorm !== fc) return false;
        }
        if (fcolor && getColorGroup(m.color_principal) !== fcolor) return false;
        if (q) {
          const names = arr(m.nombres_alternativos).join(' ');
          const usos = arr(m.usos_recomendados).join(' ');
          const acab = arr(m.acabados_disponibles).join(' ');
          const pais = arr(m.origen_pais).join(' ');
          const reg = getRegionDisplay(m.origen_region);
          const tags = arr(m.tags_busqueda).join(' ');
          const hay = [
            m.nombre_comercial,
            names,
            m.categoria,
            m.color_principal,
            m.color_acento,
            pais,
            reg,
            usos,
            acab,
            tags,
          ]
            .join(' ')
            .toLowerCase();
          if (hay.indexOf(q) === -1) return false;
        }
        return true;
      });
      result.sort(function (a: Material, b: Material): number {
        if (activeSort === 'calidad') {
          const sa = a.content_score || 0;
          const sb = b.content_score || 0;
          return (
            sb - sa || (a.nombre_comercial || '').localeCompare(b.nombre_comercial || '', 'es')
          );
        }
        if (activeSort === 'za')
          return (b.nombre_comercial || '').localeCompare(a.nombre_comercial || '', 'es');
        if (activeSort === 'pais') {
          const pa1 = arr(a.origen_pais)[0] || '';
          const pb1 = arr(b.origen_pais)[0] || '';
          return (
            pa1.localeCompare(pb1, 'es') ||
            (a.nombre_comercial || '').localeCompare(b.nombre_comercial || '', 'es')
          );
        }
        if (activeSort === 'cat')
          return (
            (a.categoria || '').localeCompare(b.categoria || '', 'es') ||
            (a.nombre_comercial || '').localeCompare(b.nombre_comercial || '', 'es')
          );
        if (activeSort === 'precio_asc' || activeSort === 'precio_desc') {
          const extractP = (s: string | undefined): number => {
            if (!s) return activeSort === 'precio_asc' ? Infinity : -1;
            const mx = String(s).match(/[\d]+([.,]\d+)?/);
            return mx
              ? parseFloat(mx[0].replace(',', '.'))
              : activeSort === 'precio_asc'
                ? Infinity
                : -1;
          };
          const pa2 = extractP(a.precio_orientativo);
          const pb2 = extractP(b.precio_orientativo);
          return activeSort === 'precio_asc' ? pa2 - pb2 : pb2 - pa2;
        }
        return (a.nombre_comercial || '').localeCompare(b.nombre_comercial || '', 'es');
      });
      renderGrid(result, true);
      const counter = document.getElementById('resultsCount');
      if (counter) {
        counter.textContent =
          result.length === DB.length
            ? DB.length + ' materiales'
            : result.length + ' de ' + DB.length;
      }
      updateActiveBanner();
    }

    function updateActiveBanner(): void {
      const banner = document.getElementById('activeBanner');
      if (!banner) return;
      const tags: string[] = [];
      if (activeFilters.cat)
        tags.push(
          '<span class="active-tag">' +
            esc(activeFilters.cat.charAt(0).toUpperCase() + activeFilters.cat.slice(1)) +
            '<span class="active-tag-x" onclick="clearFilter(\'cat\')">×</span></span>'
        );
      if (activeFilters.color)
        tags.push(
          '<span class="active-tag">' +
            esc(activeFilters.color) +
            '<span class="active-tag-x" onclick="clearFilter(\'color\')">×</span></span>'
        );
      if (searchQuery.trim())
        tags.push(
          '<span class="active-tag">«' +
            esc(trunc(searchQuery.trim(), 24)) +
            '»<span class="active-tag-x" onclick="clearSearch()">×</span></span>'
        );
      if (tags.length) {
        banner.className = 'active-banner visible';
        banner.innerHTML =
          tags.join('') +
          '<button class="active-banner-clear" onclick="clearAllFilters()">Limpiar todo ×</button>';
      } else {
        banner.className = 'active-banner';
        banner.innerHTML = '';
      }
    }

    function clearFilter(group: FilterGroup): void {
      activeFilters[group] = null;
      document.querySelectorAll('[data-group="' + group + '"]').forEach(function (b) {
        b.classList.remove('active');
      });
      applyFilters();
    }
    function clearSearch(): void {
      searchQuery = '';
      const input = document.getElementById('searchInput') as HTMLInputElement | null;
      if (input) input.value = '';
      applyFilters();
    }
    function clearAllFilters(): void {
      activeFilters = { cat: null, color: null };
      searchQuery = '';
      const input = document.getElementById('searchInput') as HTMLInputElement | null;
      if (input) input.value = '';
      document.querySelectorAll('.filter-chip').forEach(function (b) {
        b.classList.remove('active');
      });
      applyFilters();
    }

    // Expose for inline onclick handlers built via innerHTML
    interface MaterialesWindow extends Window {
      clearFilter: (group: FilterGroup) => void;
      clearSearch: () => void;
      clearAllFilters: () => void;
    }
    (window as unknown as MaterialesWindow).clearFilter = clearFilter;
    (window as unknown as MaterialesWindow).clearSearch = clearSearch;
    (window as unknown as MaterialesWindow).clearAllFilters = clearAllFilters;

    /* ── FEATURED STONE ── */
    function showFeaturedStone(): void {
      const loading = document.getElementById('featuredLoading');
      const slot = document.getElementById('featuredSlot');
      if (!slot) return;
      let pool: Material[] = DB.filter(function (m: Material) {
        return !!m.imagen_url_principal && (m.content_score || 0) >= 80;
      });
      if (!pool.length)
        pool = DB.filter(function (m: Material) {
          return !!m.imagen_url_principal && (m.content_score || 0) >= 50;
        });
      if (!pool.length)
        pool = DB.filter(function (m: Material) {
          return !!m.imagen_url_principal;
        }).slice(0, 200);
      if (!pool.length) {
        if (loading) loading.style.display = 'none';
        return;
      }
      const m: Material = pool[Math.floor(Math.random() * pool.length)];
      const flag = getFlag(arr(m.origen_pais)[0]);
      const pais = arr(m.origen_pais)[0] || '';
      if (loading) loading.style.display = 'none';
      slot.innerHTML =
        '<div class="featured-stone"><img src="' +
        esc(m.imagen_url_principal) +
        '" alt="' +
        esc(m.nombre_comercial || '') +
        '" loading="lazy"><div class="featured-stone-overlay"></div><span class="featured-stone-eyebrow">Piedra destacada</span><span class="featured-stone-badge">' +
        esc(m.categoria || '') +
        '</span><div class="featured-stone-body"><div class="featured-stone-name">' +
        esc(m.nombre_comercial || '') +
        '</div>' +
        (pais
          ? '<div class="featured-stone-origin">' +
            (flag || '') +
            '<span>' +
            esc(pais) +
            '</span></div>'
          : '') +
        (m.slug
          ? '<a class="featured-stone-cta" href="material.html?id=' +
            esc(m.slug) +
            '" onclick="event.stopPropagation()">Ver ficha →</a>'
          : '') +
        '</div></div>';
      if (m.slug) {
        const panel = document.getElementById('featuredPanel');
        if (!panel) return;
        panel.style.cursor = 'pointer';
        panel.onclick = function (e: MouseEvent): void {
          const target = e.target as HTMLElement | null;
          if (!target || !target.closest('.featured-stone-cta'))
            location.href = 'material.html?id=' + encodeURIComponent(m.slug);
        };
      }
    }

    /* ── EVENT LISTENERS ── */
    (function (): void {
      const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
      if (searchInput) {
        searchInput.addEventListener('input', function (this: HTMLInputElement) {
          searchQuery = this.value;
          applyFilters();
        });
      }
      document.querySelectorAll<HTMLElement>('.filter-chip').forEach(function (btn) {
        btn.addEventListener('click', function (this: HTMLElement) {
          const group = this.dataset.group as FilterGroup | undefined;
          const val = this.dataset.val;
          if (!group || !val) return;
          if (activeFilters[group] === val) {
            activeFilters[group] = null;
            this.classList.remove('active');
          } else {
            document.querySelectorAll('[data-group="' + group + '"]').forEach(function (b) {
              b.classList.remove('active');
            });
            activeFilters[group] = val;
            this.classList.add('active');
          }
          applyFilters();
        });
      });
      const clearBtn = document.getElementById('clearFilters');
      if (clearBtn) clearBtn.addEventListener('click', clearAllFilters);
      const sortSelect = document.getElementById('sortSelect') as HTMLSelectElement | null;
      if (sortSelect) {
        sortSelect.addEventListener('change', function (this: HTMLSelectElement) {
          activeSort = this.value as SortKey;
          applyFilters();
        });
      }
      const loadMoreBtn = document.getElementById('loadMoreBtn');
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function () {
          currentPage++;
          renderGrid(null, false);
          const grid = document.querySelector('.cards-grid');
          if (grid) {
            const lastCard = grid.children[(currentPage - 1) * PAGE_SIZE];
            if (lastCard) lastCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      }
    })();

    /* ── DATA LOADER ── */
    (function loadMateriales(): void {
      const PAGE = 1000;
      let allData: Material[] = [];
      function loadAll(offset: number): void {
        getMaterialesAll({ offset, limit: PAGE })
          .then(function (data: Material[]) {
            allData = allData.concat(data);
            if (data.length === PAGE) {
              loadAll(offset + PAGE);
            } else {
              DB = allData;
              const paises: Record<string, number> = {};
              const colores: Record<string, number> = {};
              DB.forEach(function (m: Material) {
                arr(m.origen_pais).forEach(function (p: string) {
                  if (p) paises[p] = 1;
                });
                if (m.color_principal) colores[m.color_principal] = 1;
              });
              const elMat = document.getElementById('statMateriales');
              if (elMat) elMat.textContent = String(DB.length);
              const elPais = document.getElementById('statPaises');
              if (elPais) elPais.textContent = String(Object.keys(paises).length);
              const elCol = document.getElementById('statColores');
              if (elCol) elCol.textContent = String(Object.keys(colores).length);
              showFeaturedStone();
              applyFilters();
            }
          })
          .catch(function (err: Error) {
            if (allData.length) {
              DB = allData;
              applyFilters();
            } else {
              const grid = document.getElementById('gridContainer');
              if (grid)
                grid.innerHTML =
                  '<div class="empty-state"><p>No se pudo conectar</p><small>' +
                  err.message +
                  '</small></div>';
            }
          });
      }
      loadAll(0);
    })();
  </script>
</Page>
