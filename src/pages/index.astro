  ></script>
  <script is:inline slot="scripts">
    (function () {
      var svgEl = document.getElementById('mini-map-svg');
      if (!svgEl) return;
      var W = svgEl.parentElement.clientWidth || 600;
      var H = svgEl.parentElement.clientHeight || 420;
      var svg = d3.select('#mini-map-svg').attr('width', W).attr('height', H);
      svg.append('rect').attr('width', W).attr('height', H).attr('fill', '#2a2d35');
      var projection = d3
        .geoNaturalEarth1()
        .scale(W / 3.2)
        .translate([W / 2, H / 2 + 30]);
      var path = d3.geoPath().projection(projection);
      var graticule = d3.geoGraticule().step([30, 30]);
      svg
        .append('path')
        .datum(graticule())
        .attr('d', path)
        .attr('fill', 'none')
        .attr('stroke', 'rgba(255,255,255,0.05)')
        .attr('stroke-width', 0.4);
      var g = svg.append('g');
      var DOTS = [
        { lat: 44.0, lng: 10.1, tier: 1 },
        { lat: 37.6, lng: -3.5, tier: 1 },
        { lat: 39.9, lng: 32.9, tier: 1 },
        { lat: 20.5, lng: 78.9, tier: 1 },
        { lat: -14.2, lng: -51.9, tier: 1 },
        { lat: 35.8, lng: 104.1, tier: 1 },
        { lat: 26.8, lng: 30.8, tier: 2 },
        { lat: 37.1, lng: -119.5, tier: 2 },
        { lat: -25.3, lng: 133.7, tier: 2 },
        { lat: 37.9, lng: 23.7, tier: 2 },
        { lat: 60.4, lng: 8.4, tier: 2 },
        { lat: 39.3, lng: -8.2, tier: 2 },
        { lat: 32.4, lng: 53.6, tier: 2 },
        { lat: -29.0, lng: 26.1, tier: 3 },
        { lat: 31.5, lng: 35.4, tier: 3 },
        { lat: 46.8, lng: 8.2, tier: 3 },
        { lat: -20.0, lng: 30.0, tier: 3 },
        { lat: 4.9, lng: -52.3, tier: 3 },
      ];
      fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')
        .then(function (r) {
          return r.json();
        })
        .then(function (world) {
          var countries = topojson.feature(world, world.objects.countries);
          g.selectAll('.mini-country')
            .data(countries.features)
            .join('path')
            .attr('class', 'mini-country')
            .attr('d', path)
            .attr('fill', '#363c48')
            .attr('stroke', 'rgba(255,255,255,0.10)')
            .attr('stroke-width', 0.4)
            .attr('vector-effect', 'non-scaling-stroke');
          DOTS.forEach(function (d) {
            var coords = projection([d.lng, d.lat]);
            if (!coords) return;
            var r = d.tier === 1 ? 3.5 : d.tier === 2 ? 2.2 : 1.5;
            var col = d.tier === 1 ? '#A67C52' : d.tier === 2 ? '#C4A05A' : '#9a9690';
            var glow = d.tier === 1 ? 'drop-shadow(0 0 3px rgba(160,120,60,0.6))' : 'none';
            g.append('circle')
              .attr('cx', coords[0])
              .attr('cy', coords[1])
              .attr('r', r)
              .attr('fill', col)
              .style('filter', glow);
          });
        })
        .catch(function () {
          g.append('text')
            .attr('x', W / 2)
            .attr('y', H / 2)
            .attr('text-anchor', 'middle')
            .attr('fill', 'rgba(255,255,255,0.15)')
            .attr('font-size', 11)
            .attr('letter-spacing', 4)
            .text('WORLD STONE MAP');
        });
    })();

    /* ── UNIFIED SEARCH ENGINE ── */
    (function () {
      var SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
      var SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
      var INDEX = [];
      var activeType = 'all';
      var currentQuery = '';
      var visibleCount = 12;
      var allResults = [];
      var indexLoaded = false;
      var input = document.getElementById('globalSearch');
      var wrap = document.getElementById('spResultsWrap');
      var emptyEl = document.getElementById('spEmpty');
      var grid = document.getElementById('spResultsGrid');
      var countEl = document.getElementById('spCount');
      var moreWrap = document.getElementById('spMore');
      var moreBtn = document.getElementById('spMoreBtn');
      function arr(v) {
        if (!v) return [];
        if (Array.isArray(v)) return v;
        if (typeof v === 'string')
          return v.split(',').map(function (s) {
            return s.trim();
          });
        return [];
      }
      function esc(s) {
        return String(s || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }
      function hi(s, q) {
        if (!q || !s) return esc(s);
        var re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        return esc(s).replace(
          re,
          '<mark style="background:rgba(166,124,82,0.18);color:inherit">$1</mark>'
        );
      }
      function trunc(s, n) {
        s = String(s || '');
        return s.length > n ? s.slice(0, n) + '…' : s;
      }
      function sbFetch(path) {
        return fetch(SB_URL + path, {
          headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY },
        }).then(function (r) {
          return r.json();
        });
      }
      var FLAG_CODES = {
        España: 'es',
        Italia: 'it',
        Portugal: 'pt',
        Grecia: 'gr',
        Turquía: 'tr',
        Francia: 'fr',
        Alemania: 'de',
        India: 'in',
        China: 'cn',
        Brasil: 'br',
        'Estados Unidos': 'us',
        México: 'mx',
        Canadá: 'ca',
        Argentina: 'ar',
        Chile: 'cl',
        Australia: 'au',
        Sudáfrica: 'za',
        Marruecos: 'ma',
        Egipto: 'eg',
        Irán: 'ir',
        Pakistán: 'pk',
        Vietnam: 'vn',
        Indonesia: 'id',
        Japón: 'jp',
      };
      function getFlag(pais) {
        if (!pais) return '';
        if (Array.isArray(pais)) pais = pais[0] || '';
        pais = String(pais);
        var code = FLAG_CODES[pais];
        if (!code) {
          var pl = pais.toLowerCase();
          for (var k in FLAG_CODES) {
            if (k.toLowerCase() === pl) {
              code = FLAG_CODES[k];
              break;
            }
          }
        }
        if (!code) return '';
        return (
          '<img src="https://flagicons.lipis.dev/flags/1x1/' +
          code +
          '.svg" width="18" height="18" alt="' +
          pais.replace(/"/g, '&quot;') +
          '" style="border-radius:3px;flex-shrink:0;display:inline-block;vertical-align:middle" loading="lazy" onerror="this.style.display=\'none\'">'
        );
      }
      function buildCard(item, q) {
        var thumbHtml = item.img
          ? '<div class="sp-card-thumb"><img src="' +
            esc(item.img) +
            '" alt="" loading="lazy" onerror="this.style.display=\'none\'"></div>'
          : '<div class="sp-card-thumb" style="background:' +
            (item.t === 'cantera' ? '#c4aa86' : item.t === 'proveedor' ? '#8a7a6a' : '#A67C52') +
            ';opacity:0.35"></div>';
        var flag = getFlag(item.pais);
        return (
          '<a class="sp-card" href="' +
          esc(item.link) +
          '">' +
          thumbHtml +
          '<div class="sp-card-body"><div class="sp-card-main"><div class="sp-card-name">' +
          hi(trunc(item.n, 42), q) +
          '</div></div>' +
          (flag || '') +
          '</div></a>'
        );
      }
      function search(q) {
        q = (q || '').trim().toLowerCase();
        if (!q) return [];
        var words = q.split(/\s+/).filter(Boolean);
        var scored = [];
        INDEX.forEach(function (item) {
          if (activeType !== 'all' && item.t !== activeType) return;
          var s = item._search;
          var score = 0;
          var nameL = item.n.toLowerCase();
          if (nameL === q) score = 100;
          else if (nameL.indexOf(q) === 0) score = 80;
          else if (nameL.indexOf(q) > 0) score = 60;
          else {
            var allMatch = words.every(function (w) {
              return s.indexOf(w) >= 0;
            });
            if (!allMatch) return;
            words.forEach(function (w) {
              if (nameL.indexOf(w) >= 0) score += 20;
              else if (s.indexOf(w) >= 0) score += 5;
            });
          }
          if (score > 0) scored.push({ item: item, score: score });
        });
        scored.sort(function (a, b) {
          return b.score - a.score;
        });
        return scored.map(function (x) {
          return x.item;
        });
      }
      function render() {
        var q = currentQuery;
        if (!q) {
          wrap.style.display = 'none';
          emptyEl.style.display = 'none';
          return;
        }
        if (!indexLoaded) {
          wrap.style.display = 'block';
          emptyEl.style.display = 'none';
          grid.innerHTML =
            '<div style="padding:32px;text-align:center;color:#8a8784;font-size:11px;letter-spacing:2px;text-transform:uppercase">Cargando índice…</div>';
          return;
        }
        allResults = search(q);
        if (allResults.length === 0) {
          wrap.style.display = 'none';
          emptyEl.style.display = 'block';
          return;
        }
        emptyEl.style.display = 'none';
        wrap.style.display = 'block';
        var shown = allResults.slice(0, visibleCount);
        countEl.textContent =
          allResults.length + ' resultado' + (allResults.length !== 1 ? 's' : '');
        grid.innerHTML = shown
          .map(function (item) {
            return buildCard(item, q);
          })
          .join('');
        if (allResults.length > visibleCount) {
          moreWrap.style.display = 'block';
          moreBtn.textContent = 'Ver ' + (allResults.length - visibleCount) + ' resultados más';
        } else {
          moreWrap.style.display = 'none';
        }
      }
      Promise.all([
        sbFetch(
          '/rest/v1/materiales?select=nombre_comercial,nombre_cientifico,categoria,subcategoria,color_principal,origen_pais,origen_region,tags_busqueda,nombres_alternativos,usos_recomendados,imagen_url,slug&order=nombre_comercial.asc&limit=500'
        ),
        sbFetch(
          '/rest/v1/canteras?select=nombre,tipo_piedra,pais,localizacion,continente,materiales,color_principal,slug,activo&order=nombre.asc&limit=500'
        ),
        sbFetch(
          '/rest/v1/proveedores?select=nombre_empresa,tipo_empresa,plan,pais,ciudad,descripcion,slug,logo_url,activo,estado&order=nombre_empresa.asc&limit=100'
        ),
      ])
        .then(function (results) {
          var mats = Array.isArray(results[0]) ? results[0] : [];
          var cants = Array.isArray(results[1])
            ? results[1].filter(function (c) {
                return c.nombre;
              })
            : [];
          var provs = Array.isArray(results[2])
            ? results[2].filter(function (p) {
                return p.activo !== false && p.plan && p.plan !== 'free';
              })
            : [];
          mats.forEach(function (m) {
            var obj = {
              t: 'material',
              n: m.nombre_comercial || '',
              sub: m.subcategoria || m.categoria || '',
              pais: arr(m.origen_pais)[0] || '',
              color: m.color_principal || '',
              desc: m.nombre_cientifico || '',
              link: m.slug ? 'material.html?id=' + m.slug : 'materiales.html',
              img: m.imagen_url || '',
            };
            obj._search = [
              obj.n,
              obj.sub,
              obj.pais,
              obj.color,
              obj.desc,
              arr(m.tags_busqueda).join(' '),
              arr(m.nombres_alternativos).join(' '),
            ]
              .join(' ')
              .toLowerCase();
            INDEX.push(obj);
          });
          cants.forEach(function (c) {
            var obj = {
              t: 'cantera',
              n: c.nombre || '',
              sub: c.tipo_piedra || 'Piedra natural',
              pais: c.pais || '',
              desc: c.materiales || '',
              link: c.slug ? 'cantera.html?id=' + c.slug : 'canteras.html',
              img: '',
            };
            obj._search = [
              obj.n,
              obj.sub,
              obj.pais,
              c.localizacion,
              c.materiales,
              c.color_principal,
            ]
              .filter(Boolean)
              .join(' ')
              .toLowerCase();
            INDEX.push(obj);
          });
          provs.forEach(function (p) {
            var obj = {
              t: 'proveedor',
              n: p.nombre_empresa || '',
              sub: p.tipo_empresa || '',
              pais: p.pais || '',
              desc: p.descripcion || '',
              link: p.slug ? 'proveedor.html?id=' + p.slug : 'proveedores.html',
              img: p.logo_url || '',
            };
            obj._search = [obj.n, obj.sub, obj.pais, p.ciudad, p.descripcion]
              .filter(Boolean)
              .join(' ')
              .toLowerCase();
            INDEX.push(obj);
          });
          indexLoaded = true;
          var sub = document.querySelector('.sp-subtitle');
          if (sub)
            sub.textContent =
              mats.length +
              ' materiales · ' +
              cants.length +
              ' canteras · ' +
              provs.length +
              ' empresas · todo en tiempo real';
          if (currentQuery) render();
        })
        .catch(function () {
          indexLoaded = true;
        });
      if (input) {
        input.addEventListener('input', function () {
          currentQuery = this.value.trim();
          visibleCount = 12;
          render();
        });
        input.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            this.value = '';
            currentQuery = '';
            visibleCount = 12;
            if (wrap) wrap.style.display = 'none';
            if (emptyEl) emptyEl.style.display = 'none';
          }
        });
      }
      if (moreBtn) {
        moreBtn.addEventListener('click', function () {
          visibleCount += 12;
          render();
        });
      }
    })();

    /* ── HAMBURGER MENU ── */
    (function () {
      var burger = document.getElementById('navBurger');
      var menu = document.getElementById('mobileMenu');
      if (!burger || !menu) return;
      burger.addEventListener('click', function () {
        var isOpen = menu.classList.toggle('open');
        burger.classList.toggle('open', isOpen);
        burger.setAttribute('aria-expanded', isOpen);
        menu.setAttribute('aria-hidden', !isOpen);
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });
      menu.addEventListener('click', function (e) {
        if (e.target === menu) {
          menu.classList.remove('open');
          burger.classList.remove('open');
          burger.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
      });
    })();

    /* ── TRENDING SEARCHES ── */
    (function () {
      var trending = document.getElementById('spTrending');
      var input = document.getElementById('globalSearch');
      if (!trending || !input) return;
      input.addEventListener('input', function () {
        if (trending) trending.style.display = input.value.trim() ? 'none' : 'block';
      });
      document.querySelectorAll('.sp-trending-tag').forEach(function (btn) {
        btn.addEventListener('click', function () {
          input.value = btn.dataset.q;
          trending.style.display = 'none';
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.focus();
        });
      });
    })();

    /* ── PROVIDERS COUNT ── */
    (function () {
      var SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
      var SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
      fetch(SB_URL + '/rest/v1/proveedores?select=id&activo=eq.true&estado=eq.activo', {
        headers: {
          apikey: SB_KEY,
          Authorization: 'Bearer ' + SB_KEY,
          Prefer: 'count=exact',
          Range: '0-0',
        },
      })
        .then(function (r) {
          var cr = r.headers.get('content-range');
          if (cr) {
            var total = cr.split('/')[1];
            if (total && total !== '*') {
              var proEl = document.getElementById('proCount');
              var heroEl = document.getElementById('heroStatCompanies');
              if (proEl) proEl.textContent = total + ' operadores activos';
              if (heroEl) {
                heroEl.textContent = total;
                heroEl.removeAttribute('style');
              }
            }
          }
        })
        .catch(function () {
          var heroEl = document.getElementById('heroStatCompanies');
          if (heroEl) heroEl.textContent = '—';
        });
    })();

    /* ── FOUNDERS SEATS ── */
    (function () {
      var TOTAL_SEATS = 20;
      var fill = document.getElementById('fcSeatsFill');
      var label = document.getElementById('fcSeatsText');
      if (!fill && !label) return;
      fetch(
        'https://whcptmdapnavcxcszwwk.supabase.co/rest/v1/solicitudes_fundadores?select=id&estado=neq.rechazado',
        {
          headers: {
            apikey: 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO',
            Authorization: 'Bearer sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO',
            Prefer: 'count=exact',
            Range: '0-0',
          },
        }
      )
        .then(function (r) {
          var range = r.headers.get('content-range') || '';
          var match = range.match(/\/(\d+)$/);
          return match ? parseInt(match[1], 10) : null;
        })
        .then(function (count) {
          if (count === null) count = 3;
          var taken = Math.min(count, TOTAL_SEATS);
          var pct = (taken / TOTAL_SEATS) * 100;
          if (fill) fill.style.width = pct.toFixed(0) + '%';
          if (label) {
            var remaining = TOTAL_SEATS - taken;
            label.textContent =
              remaining > 0
                ? remaining +
                  ' plaza' +
                  (remaining === 1 ? '' : 's') +
                  ' disponible' +
                  (remaining === 1 ? '' : 's')
                : 'Plazas agotadas';
            if (remaining <= 5) label.style.color = '#C9A84C';
          }
        })
        .catch(function () {
          if (fill) fill.style.width = '15%';
          if (label) label.textContent = '17 plazas disponibles';
        });
    })();

    /* ── AD SLOT OBSERVER ── */
    (function () {
      var slot = document.getElementById('heroAdSlot');
      var fallback = document.getElementById('heroAdFallback');
      if (!slot) return;
      var observer = new MutationObserver(function () {
        if (slot.querySelector('a.ad-link') && fallback) fallback.style.display = 'none';
      });
      observer.observe(slot, { childList: true });
    })();

    /* ── AD LOADER ── */
    (function loadAd() {
      var SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
      var SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
      var today = new Date().toISOString().slice(0, 10);
      fetch(
        SB_URL +
          '/rest/v1/anuncios?espacio_codigo=eq.HOME-TOP&activo=eq.true&select=imagen_url,url_destino,texto_alt,fecha_inicio,fecha_fin&limit=5',
        {
          headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY },
        }
      )
        .then(function (r) {
          return r.json();
        })
        .then(function (data) {
          if (!Array.isArray(data) || !data.length) return;
          var valid = data.filter(function (a) {
            if (a.fecha_inicio && a.fecha_inicio > today) return false;
            if (a.fecha_fin && a.fecha_fin < today) return false;
            return true;
          });
          if (!valid.length) return;
          var ad = valid[0];
          var slot = document.getElementById('heroAdSlot');
          if (!slot) return;
          var href = ad.url_destino
            ? ad.url_destino.startsWith('http')
              ? ad.url_destino
              : 'https://' + ad.url_destino
            : '#';
          slot.innerHTML =
            '<a class="ad-link" href="' +
            href +
            '" target="_blank" rel="noopener sponsored"><img src="' +
            (ad.imagen_url || '') +
            '" alt="' +
            (ad.texto_alt || 'Publicidad') +
            '" loading="lazy"></a>';
        })
        .catch(function () {});
    })();
  </script>
</Page>
