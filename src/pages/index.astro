---
import Page from '../layouts/Page.astro';
import MobileMenu from '../contexts/home/components/MobileMenu.astro';
import HomeHero from '../contexts/home/components/HomeHero.astro';
import MarqueeSection from '../contexts/home/components/MarqueeSection.astro';
import SearchPreview from '../contexts/home/components/SearchPreview.astro';
import ProfessionalsSection from '../contexts/home/components/ProfessionalsSection.astro';
import QuarriesSection from '../contexts/home/components/QuarriesSection.astro';
import MembershipSection from '../contexts/home/components/MembershipSection.astro';
---

<Page
  title="World Stone Hub — Portal Mundial de la Piedra"
  description="El directorio B2B global para el sector de la piedra natural. Canteras, fabricantes, distribuidores y proveedores de todo el mundo."
  ogTitle="World Stone Hub — Portal Mundial de la Piedra Natural"
  ogDescription="El directorio B2B global para el sector de la piedra natural. Canteras, fabricantes, distribuidores y proveedores de todo el mundo."
  ogUrl="https://worldstonehub.com/"
  activePage="inicio"
>
  <style slot="head" is:global>
    /* ── BODY NOISE ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.4;
    }

    /* ── SHARED SECTION STYLES ── */
    section {
      padding: 96px 60px;
    }
    .section-eyebrow {
      font-family: 'DM Mono', monospace !important;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #a67c52;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-eyebrow::before {
      content: '';
      width: 30px;
      height: 1px;
      background: #a67c52;
      flex-shrink: 0;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 300;
      line-height: 1.1;
      color: #1a1917;
      margin-bottom: 16px;
    }
    .section-title em {
      font-style: italic;
      color: #a67c52;
    }
    .gold-divider {
      width: 40px;
      height: 1px;
      background: #a67c52;
      margin: 24px 0;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      section {
        padding: 80px 30px;
      }
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar {
      width: 5px;
      height: 5px;
    }
    ::-webkit-scrollbar-track {
      background: #f0efed;
    }
    ::-webkit-scrollbar-thumb {
      background: #c8c5bf;
      border-radius: 2px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #a67c52;
    }
  </style>

  <MobileMenu />
  <HomeHero />
  <MarqueeSection />
  <SearchPreview />
  <ProfessionalsSection />
  <QuarriesSection />
  <MembershipSection />

  <script>
    import { getForSearch as getMaterialesForSearch } from '@contexts/materials/services/http/materialsHttp';
    import { getForSearch as getCanterasForSearch } from '@contexts/canteras/services/http/canterasHttp';
    import {
      getActiveCount,
      getForSearch as getProveedoresForSearch,
    } from '@contexts/proveedores/services/http/proveedoresHttp';
    import {
      getAnunciosByEspacio,
      getFundadoresCount,
    } from '@contexts/home/services/http/homeHttp';

    /* ── UNIFIED SEARCH ENGINE ── */
    (function () {
      var INDEX: any[] = [];
      var currentQuery = '';
      var visibleCount = 12;
      var allResults: any[] = [];
      var indexLoaded = false;
      var input = document.getElementById('globalSearch') as HTMLInputElement | null;
      var wrap = document.getElementById('spResultsWrap');
      var emptyEl = document.getElementById('spEmpty');
      var grid = document.getElementById('spResultsGrid');
      var countEl = document.getElementById('spCount');
      var moreWrap = document.getElementById('spMore');
      var moreBtn = document.getElementById('spMoreBtn');

      function arr(v: any): any[] {
        if (!v) return [];
        if (Array.isArray(v)) return v;
        if (typeof v === 'string') return v.split(',').map((s: string) => s.trim());
        return [];
      }
      function esc(s: any): string {
        return String(s || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }
      function hi(s: string, q: string): string {
        if (!q || !s) return esc(s);
        var re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        return esc(s).replace(
          re,
          '<mark style="background:rgba(166,124,82,0.18);color:inherit">$1</mark>'
        );
      }
      function trunc(s: any, n: number): string {
        s = String(s || '');
        return s.length > n ? s.slice(0, n) + '…' : s;
      }
      var FLAG_CODES: Record<string, string> = {
        España: 'es',
        Italia: 'it',
        Portugal: 'pt',
        Grecia: 'gr',
        Turquía: 'tr',
        Francia: 'fr',
        Alemania: 'de',
        India: 'in',
        China: 'cn',
        Brasil: 'br',
        'Estados Unidos': 'us',
        México: 'mx',
        Canadá: 'ca',
        Argentina: 'ar',
        Chile: 'cl',
        Australia: 'au',
        Sudáfrica: 'za',
        Marruecos: 'ma',
        Egipto: 'eg',
        Irán: 'ir',
        Pakistán: 'pk',
        Vietnam: 'vn',
        Indonesia: 'id',
        Japón: 'jp',
      };
      function getFlag(pais: any): string {
        if (!pais) return '';
        if (Array.isArray(pais)) pais = pais[0] || '';
        pais = String(pais);
        var code = FLAG_CODES[pais];
        if (!code) {
          var pl = pais.toLowerCase();
          for (var k in FLAG_CODES) {
            if (k.toLowerCase() === pl) {
              code = FLAG_CODES[k];
              break;
            }
          }
        }
        if (!code) return '';
        return (
          '<img src="https://flagicons.lipis.dev/flags/1x1/' +
          code +
          '.svg" width="18" height="18" alt="' +
          pais.replace(/"/g, '&quot;') +
          '" style="border-radius:3px;flex-shrink:0;display:inline-block;vertical-align:middle" loading="lazy" onerror="this.style.display=\'none\'">'
        );
      }
      function buildCard(item: any, q: string): string {
        var thumbHtml = item.img
          ? '<div class="sp-card-thumb"><img src="' +
            esc(item.img) +
            '" alt="" loading="lazy" onerror="this.style.display=\'none\'"></div>'
          : '<div class="sp-card-thumb" style="background:' +
            (item.t === 'cantera' ? '#c4aa86' : item.t === 'proveedor' ? '#8a7a6a' : '#A67C52') +
            ';opacity:0.35"></div>';
        var flag = getFlag(item.pais);
        return (
          '<a class="sp-card" href="' +
          esc(item.link) +
          '">' +
          thumbHtml +
          '<div class="sp-card-body"><div class="sp-card-main"><div class="sp-card-name">' +
          hi(trunc(item.n, 42), q) +
          '</div></div>' +
          (flag || '') +
          '</div></a>'
        );
      }
      function search(q: string): any[] {
        q = (q || '').trim().toLowerCase();
        if (!q) return [];
        var words = q.split(/\s+/).filter(Boolean);
        var scored: { item: any; score: number }[] = [];
        INDEX.forEach(function (item) {
          var s = item._search;
          var score = 0;
          var nameL = item.n.toLowerCase();
          if (nameL === q) score = 100;
          else if (nameL.indexOf(q) === 0) score = 80;
          else if (nameL.indexOf(q) > 0) score = 60;
          else {
            var allMatch = words.every((w: string) => s.indexOf(w) >= 0);
            if (!allMatch) return;
            words.forEach((w: string) => {
              if (nameL.indexOf(w) >= 0) score += 20;
              else if (s.indexOf(w) >= 0) score += 5;
            });
          }
          if (score > 0) scored.push({ item, score });
        });
        scored.sort((a, b) => b.score - a.score);
        return scored.map((x) => x.item);
      }
      function render(): void {
        var q = currentQuery;
        if (!q) {
          if (wrap) wrap.style.display = 'none';
          if (emptyEl) emptyEl.style.display = 'none';
          return;
        }
        if (!indexLoaded) {
          if (wrap) wrap.style.display = 'block';
          if (emptyEl) emptyEl.style.display = 'none';
          if (grid)
            grid.innerHTML =
              '<div style="padding:32px;text-align:center;color:#8a8784;font-size:11px;letter-spacing:2px;text-transform:uppercase">Cargando índice…</div>';
          return;
        }
        allResults = search(q);
        if (allResults.length === 0) {
          if (wrap) wrap.style.display = 'none';
          if (emptyEl) emptyEl.style.display = 'block';
          return;
        }
        if (emptyEl) emptyEl.style.display = 'none';
        if (wrap) wrap.style.display = 'block';
        var shown = allResults.slice(0, visibleCount);
        if (countEl)
          countEl.textContent =
            allResults.length + ' resultado' + (allResults.length !== 1 ? 's' : '');
        if (grid) grid.innerHTML = shown.map((item) => buildCard(item, q)).join('');
        if (moreWrap && moreBtn) {
          if (allResults.length > visibleCount) {
            moreWrap.style.display = 'block';
            moreBtn.textContent = 'Ver ' + (allResults.length - visibleCount) + ' resultados más';
          } else {
            moreWrap.style.display = 'none';
          }
        }
      }

      Promise.all([getMaterialesForSearch(), getCanterasForSearch(), getProveedoresForSearch()])
        .then(function (results) {
          var mats = Array.isArray(results[0]) ? results[0] : [];
          var cants = Array.isArray(results[1])
            ? (results[1] as any[]).filter((c) => c.nombre)
            : [];
          var provs = Array.isArray(results[2])
            ? (results[2] as any[]).filter((p) => p.activo !== false && p.plan && p.plan !== 'free')
            : [];
          mats.forEach(function (m: any) {
            var obj: any = {
              t: 'material',
              n: m.nombre_comercial || '',
              sub: m.subcategoria || m.categoria || '',
              pais: arr(m.origen_pais)[0] || '',
              color: m.color_principal || '',
              desc: m.nombre_cientifico || '',
              link: m.slug ? 'material.html?id=' + m.slug : 'materiales.html',
              img: m.imagen_url || '',
            };
            obj._search = [
              obj.n,
              obj.sub,
              obj.pais,
              obj.color,
              obj.desc,
              arr(m.tags_busqueda).join(' '),
              arr(m.nombres_alternativos).join(' '),
            ]
              .join(' ')
              .toLowerCase();
            INDEX.push(obj);
          });
          cants.forEach(function (c: any) {
            var obj: any = {
              t: 'cantera',
              n: c.nombre || '',
              sub: c.tipo_piedra || 'Piedra natural',
              pais: c.pais || '',
              desc: c.materiales || '',
              link: c.slug ? 'cantera.html?id=' + c.slug : 'canteras.html',
              img: '',
            };
            obj._search = [
              obj.n,
              obj.sub,
              obj.pais,
              c.localizacion,
              c.materiales,
              c.color_principal,
            ]
              .filter(Boolean)
              .join(' ')
              .toLowerCase();
            INDEX.push(obj);
          });
          provs.forEach(function (p: any) {
            var obj: any = {
              t: 'proveedor',
              n: p.nombre_empresa || '',
              sub: p.tipo_empresa || '',
              pais: p.pais || '',
              desc: p.descripcion || '',
              link: p.slug ? 'proveedor.html?id=' + p.slug : 'proveedores.html',
              img: p.logo_url || '',
            };
            obj._search = [obj.n, obj.sub, obj.pais, p.ciudad, p.descripcion]
              .filter(Boolean)
              .join(' ')
              .toLowerCase();
            INDEX.push(obj);
          });
          indexLoaded = true;
          var sub = document.querySelector('.sp-subtitle');
          if (sub)
            sub.textContent =
              mats.length +
              ' materiales · ' +
              cants.length +
              ' canteras · ' +
              provs.length +
              ' empresas · todo en tiempo real';
          if (currentQuery) render();
        })
        .catch(() => {
          indexLoaded = true;
        });

      if (input) {
        input.addEventListener('input', function (this: HTMLInputElement) {
          currentQuery = this.value.trim();
          visibleCount = 12;
          render();
          var trending = document.getElementById('spTrending');
          if (trending) trending.style.display = this.value.trim() ? 'none' : 'block';
        });
        input.addEventListener('keydown', function (this: HTMLInputElement, e: Event) {
          if ((e as KeyboardEvent).key === 'Escape') {
            this.value = '';
            currentQuery = '';
            visibleCount = 12;
            if (wrap) wrap.style.display = 'none';
            if (emptyEl) emptyEl.style.display = 'none';
          }
        });
      }
      if (moreBtn) {
        moreBtn.addEventListener('click', function () {
          visibleCount += 12;
          render();
        });
      }
      document.querySelectorAll<HTMLButtonElement>('.sp-trending-tag').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var q = btn.dataset.q || '';
          if (input) {
            input.value = q;
            var trending = document.getElementById('spTrending');
            if (trending) trending.style.display = 'none';
            input.dispatchEvent(new Event('input', { bubbles: true }));
            input.focus();
          }
        });
      });
    })();

    /* ── PROVIDERS COUNT ── */
    (function () {
      getActiveCount()
        .then(function (total: number | null) {
          if (total !== null) {
            var proEl = document.getElementById('proCount');
            var heroEl = document.getElementById('heroStatCompanies');
            if (proEl) proEl.textContent = String(total) + ' operadores activos';
            if (heroEl) {
              heroEl.textContent = String(total);
              heroEl.removeAttribute('style');
            }
          }
        })
        .catch(function () {
          var heroEl = document.getElementById('heroStatCompanies');
          if (heroEl) heroEl.textContent = '—';
        });
    })();

    /* ── FOUNDERS SEATS ── */
    (function () {
      var TOTAL_SEATS = 20;
      var fill = document.getElementById('fcSeatsFill');
      var label = document.getElementById('fcSeatsText');
      if (!fill && !label) return;
      getFundadoresCount()
        .then(function (count: number | null) {
          if (count === null) count = 3;
          var taken = Math.min(count, TOTAL_SEATS);
          var pct = (taken / TOTAL_SEATS) * 100;
          if (fill) fill.style.width = pct.toFixed(0) + '%';
          if (label) {
            var remaining = TOTAL_SEATS - taken;
            label.textContent =
              remaining > 0
                ? remaining +
                  ' plaza' +
                  (remaining === 1 ? '' : 's') +
                  ' disponible' +
                  (remaining === 1 ? '' : 's')
                : 'Plazas agotadas';
            if (remaining <= 5) label.style.color = '#C9A84C';
          }
        })
        .catch(function () {
          if (fill) fill.style.width = '15%';
          if (label) label.textContent = '17 plazas disponibles';
        });
    })();

    /* ── AD SLOT OBSERVER ── */
    (function () {
      var slot = document.getElementById('heroAdSlot');
      var fallback = document.getElementById('heroAdFallback');
      if (!slot) return;
      var slotEl = slot;
      var observer = new MutationObserver(function () {
        if (slotEl.querySelector('a.ad-link') && fallback)
          (fallback as HTMLElement).style.display = 'none';
      });
      observer.observe(slotEl, { childList: true });
    })();

    /* ── AD LOADER ── */
    (function loadAd() {
      var today = new Date().toISOString().slice(0, 10);
      getAnunciosByEspacio('HOME-TOP')
        .then(function (data: any[]) {
          if (!data.length) return;
          var valid = data.filter(function (a: any) {
            if (a.fecha_inicio && a.fecha_inicio > today) return false;
            if (a.fecha_fin && a.fecha_fin < today) return false;
            return true;
          });
          if (!valid.length) return;
          var ad = valid[0];
          var slot = document.getElementById('heroAdSlot');
          if (!slot) return;
          var href = ad.url_destino
            ? ad.url_destino.startsWith('http')
              ? ad.url_destino
              : 'https://' + ad.url_destino
            : '#';
          slot.innerHTML =
            '<a class="ad-link" href="' +
            href +
            '" target="_blank" rel="noopener sponsored"><img src="' +
            (ad.imagen_url || '') +
            '" alt="' +
            (ad.texto_alt || 'Publicidad') +
            '" loading="lazy"></a>';
        })
        .catch(function () {});
    })();
  </script>
</Page>
