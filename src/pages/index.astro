---
import Page from '../layouts/Page.astro';
import MobileMenu from '../contexts/home/components/MobileMenu.astro';
import HomeHero from '../contexts/home/components/HomeHero.astro';
import MarqueeSection from '../contexts/home/components/MarqueeSection.astro';
import SearchPreview from '../contexts/home/components/SearchPreview.astro';
import ProfessionalsSection from '../contexts/home/components/ProfessionalsSection.astro';
import QuarriesSection from '../contexts/home/components/QuarriesSection.astro';
import MembershipSection from '../contexts/home/components/MembershipSection.astro';
---

<Page
  title="World Stone Hub — Portal Mundial de la Piedra"
  description="El directorio B2B global para el sector de la piedra natural. Canteras, fabricantes, distribuidores y proveedores de todo el mundo."
  ogTitle="World Stone Hub — Portal Mundial de la Piedra Natural"
  ogDescription="El directorio B2B global para el sector de la piedra natural. Canteras, fabricantes, distribuidores y proveedores de todo el mundo."
  ogUrl="https://worldstonehub.com/"
  activePage="inicio"
>
  <style slot="head" is:global>
    /* ── BODY NOISE ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.4;
    }

    /* ── SHARED SECTION STYLES ── */
    section {
      padding: 96px 60px;
    }
    .section-eyebrow {
      font-family: 'DM Mono', monospace !important;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #a67c52;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-eyebrow::before {
      content: '';
      width: 30px;
      height: 1px;
      background: #a67c52;
      flex-shrink: 0;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 300;
      line-height: 1.1;
      color: #1a1917;
      margin-bottom: 16px;
    }
    .section-title em {
      font-style: italic;
      color: #a67c52;
    }
    .gold-divider {
      width: 40px;
      height: 1px;
      background: #a67c52;
      margin: 24px 0;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      section {
        padding: 80px 30px;
      }
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar {
      width: 5px;
      height: 5px;
    }
    ::-webkit-scrollbar-track {
      background: #f0efed;
    }
    ::-webkit-scrollbar-thumb {
      background: #c8c5bf;
      border-radius: 2px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #a67c52;
    }
  </style>

  <MobileMenu />
  <HomeHero />
  <MarqueeSection />
  <SearchPreview />
  <ProfessionalsSection />
  <QuarriesSection />
  <MembershipSection />

  <script>
    import { getActiveCount } from '@contexts/proveedores/services/http/proveedoresHttp';
    import { getAdByCode, getFundadoresCount } from '@contexts/home/services/http/homeHttp';

    /* ── PROVIDERS COUNT ── */
    (function () {
      getActiveCount()
        .then(function (total: number | null) {
          if (total !== null) {
            var proEl = document.getElementById('proCount');
            var heroEl = document.getElementById('heroStatCompanies');
            if (proEl) proEl.textContent = String(total) + ' operadores activos';
            if (heroEl) {
              heroEl.textContent = String(total);
              heroEl.removeAttribute('style');
            }
          }
        })
        .catch(function () {
          var heroEl = document.getElementById('heroStatCompanies');
          if (heroEl) heroEl.textContent = '—';
        });
    })();

    /* ── FOUNDERS SEATS ── */
    (function () {
      var TOTAL_SEATS = 20;
      var fill = document.getElementById('fcSeatsFill');
      var label = document.getElementById('fcSeatsText');
      if (!fill && !label) return;
      getFundadoresCount()
        .then(function (count: number | null) {
          if (count === null) count = 3;
          var taken = Math.min(count, TOTAL_SEATS);
          var pct = (taken / TOTAL_SEATS) * 100;
          if (fill) fill.style.width = pct.toFixed(0) + '%';
          if (label) {
            var remaining = TOTAL_SEATS - taken;
            label.textContent =
              remaining > 0
                ? remaining +
                  ' plaza' +
                  (remaining === 1 ? '' : 's') +
                  ' disponible' +
                  (remaining === 1 ? '' : 's')
                : 'Plazas agotadas';
            if (remaining <= 5) label.style.color = '#C9A84C';
          }
        })
        .catch(function () {
          if (fill) fill.style.width = '15%';
          if (label) label.textContent = '17 plazas disponibles';
        });
    })();

    /* ── AD SLOT OBSERVER ── */
    (function () {
      var slot = document.getElementById('heroAdSlot');
      var fallback = document.getElementById('heroAdFallback');
      if (!slot) return;
      var slotEl = slot;
      var observer = new MutationObserver(function () {
        if (slotEl.querySelector('a.ad-link') && fallback)
          (fallback as HTMLElement).style.display = 'none';
      });
      observer.observe(slotEl, { childList: true });
    })();

    /* ── AD LOADER ── */
    (function loadAd() {
      var today = new Date().toISOString().slice(0, 10);
      getAdByCode('HOME-TOP')
        .then(function (data: any[]) {
          if (!data.length) return;
          var valid = data.filter(function (a: any) {
            if (a.fecha_inicio && a.fecha_inicio > today) return false;
            if (a.fecha_fin && a.fecha_fin < today) return false;
            return true;
          });
          if (!valid.length) return;
          var ad = valid[0];
          var slot = document.getElementById('heroAdSlot');
          if (!slot) return;
          var href = ad.url_destino
            ? ad.url_destino.startsWith('http')
              ? ad.url_destino
              : 'https://' + ad.url_destino
            : '#';
          slot.innerHTML =
            '<a class="ad-link" href="' +
            href +
            '" target="_blank" rel="noopener sponsored"><img src="' +
            (ad.imagen_url || '') +
            '" alt="' +
            (ad.texto_alt || 'Publicidad') +
            '" loading="lazy"></a>';
        })
        .catch(function () {});
    })();
  </script>
</Page>
