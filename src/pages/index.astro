---
import Page from '../layouts/Page.astro';
---

<Page
  title="World Stone Hub — Portal Mundial de la Piedra"
  description="El directorio B2B global para el sector de la piedra natural. Canteras, fabricantes, distribuidores y proveedores de todo el mundo."
  ogTitle="World Stone Hub — Portal Mundial de la Piedra Natural"
  ogDescription="El directorio B2B global para el sector de la piedra natural. Canteras, fabricantes, distribuidores y proveedores de todo el mundo."
  ogUrl="https://worldstonehub.com/"
  activePage="inicio"
>
  <style slot="head" is:global>
    /* ── BODY NOISE ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.4;
    }

    /* ── HERO ── */
    .hero {
      height: auto !important;
      min-height: 0 !important;
      position: static !important;
      display: block !important;
      overflow: visible !important;
      padding: 0 !important;
      background: none !important;
    }
    .hero-bg,
    .hero-stone-pattern {
      display: none !important;
    }
    .hero-scroll {
      display: none !important;
    }
    .hero-content {
      position: static !important;
      padding: 0 !important;
      max-width: none !important;
      animation: none !important;
    }

    /* ── PAGE HEADER 50/50 ── */
    .page-hdr {
      display: flex;
      align-items: stretch;
      min-height: 380px;
      margin-top: 64px;
      overflow: hidden;
    }
    .page-hdr-left {
      flex: 0 0 50%;
      max-width: 50%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 44px 60px 40px;
      box-sizing: border-box;
      background: #f8f7f5;
    }
    .page-hdr-right {
      flex: 1;
      position: relative;
      overflow: hidden;
      min-height: 380px;
      background: #f0efed;
      border-left: 1px solid #e2e0dc;
    }
    .ad-container {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .ad-link {
      display: block;
      width: 100%;
      height: 100%;
    }
    .ad-link img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    @media (max-width: 900px) {
      .page-hdr {
        flex-direction: column;
        margin-top: 56px;
        min-height: auto;
      }
      .page-hdr-left {
        flex: none;
        max-width: 100%;
        padding: 36px 24px 28px;
      }
      .page-hdr-right {
        flex: none;
        width: 100%;
        min-height: 220px;
      }
    }

    /* ── HERO EYEBROW / TITLE / STATS ── */
    .hero-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: #a67c52;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .hero-eyebrow::before {
      content: '';
      width: 40px;
      height: 1px;
      background: #a67c52;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 4.5vw, 66px);
      font-weight: 300;
      line-height: 0.9 !important;
      letter-spacing: -2px;
      margin-bottom: 6px;
      color: #1a1917;
    }
    .hero-title em {
      font-style: italic;
      color: #a67c52;
    }

    .hero-title-accent {
      font-family: 'Cormorant Garamond', serif !important;
      font-size: clamp(36px, 4.5vw, 66px);
      font-style: italic;
      letter-spacing: -1px;
      color: #a67c52;
      line-height: 1;
      display: block;
      margin-bottom: 20px;
    }

    .hero-sub {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.65;
      color: #4a4845;
      max-width: 480px;
      margin-bottom: 20px;
    }

    .hero-actions {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      padding: 14px 32px;
      background: #a67c52;
      color: #ffffff;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      text-decoration: none;
      border: none;
      transition:
        background 0.25s,
        transform 0.2s;
      position: relative;
      overflow: hidden;
    }
    .btn-primary::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255, 255, 255, 0.1);
      transform: translateX(-100%);
      transition: transform 0.3s;
    }
    .btn-primary:hover {
      background: #8f6a40;
    }
    .btn-primary:hover::after {
      transform: translateX(0);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      padding: 14px 32px;
      background: transparent;
      color: #1a1917;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid #c8c5bf;
      transition:
        border-color 0.25s,
        color 0.25s;
    }
    .btn-secondary:hover {
      border-color: #a67c52;
      color: #a67c52;
    }
    .btn-secondary::after {
      content: '→';
      margin-left: 8px;
      transition: transform 0.3s;
    }
    .btn-secondary:hover::after {
      transform: translateX(6px);
    }

    .hero-stats {
      display: flex;
      gap: 32px;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid rgba(30, 25, 20, 0.09);
      flex-wrap: wrap;
      align-items: flex-end;
    }
    .stat {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .stat-num {
      font-family: 'DM Mono', monospace !important;
      font-size: 28px;
      letter-spacing: 1px;
      color: #1a1917;
      line-height: 1;
      font-weight: 300;
    }
    .stat-num span {
      color: #a67c52;
      font-size: 17px;
      vertical-align: super;
    }
    .stat-label {
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #8a8784;
      line-height: 1.3;
    }

    /* ── FOUNDERS CARD ── */
    .founders-card {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 14px;
      padding: 36px 40px 28px;
      background: #1a1917;
      overflow: hidden;
    }
    .founders-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 80% 10%, rgba(166, 124, 82, 0.08) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }
    .founders-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(166, 124, 82, 0.3), transparent);
      pointer-events: none;
      z-index: 0;
    }
    .founders-card > * {
      position: relative;
      z-index: 1;
    }
    .fc-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(166, 124, 82, 0.1);
      border: 1px solid rgba(166, 124, 82, 0.3);
      padding: 5px 12px;
      width: fit-content;
      font-family: 'DM Mono', monospace;
      font-size: 8px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #a67c52;
    }
    .fc-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #a67c52;
      flex-shrink: 0;
      animation: fcPulse 2.5s ease-in-out infinite;
    }
    @keyframes fcPulse {
      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }
      50% {
        opacity: 0.3;
        transform: scale(0.6);
      }
    }
    .fc-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(24px, 2.6vw, 34px);
      font-weight: 300;
      line-height: 1.05;
      color: #f0ede8;
    }
    .fc-title em {
      font-style: italic;
      color: #c9a84c;
    }
    .fc-sub {
      font-size: 11.5px;
      font-weight: 300;
      line-height: 1.6;
      color: rgba(240, 237, 232, 0.6);
      margin: 0;
    }
    .fc-features {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
      border-top: 1px solid rgba(166, 124, 82, 0.15);
      padding-top: 14px;
    }
    .fc-features li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 11px;
      font-weight: 300;
      color: rgba(240, 237, 232, 0.75);
      line-height: 1.45;
    }
    .fc-check {
      color: #c9a84c;
      font-size: 10px;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .fc-seats {
      margin-top: 2px;
    }
    .fc-seats-bar {
      height: 2px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 1px;
      overflow: hidden;
    }
    .fc-seats-fill {
      height: 100%;
      background: linear-gradient(90deg, #a67c52, #c9a84c);
      transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
      width: 0%;
    }
    .fc-seats-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 6px;
    }
    .fc-seats-labels span {
      font-family: 'DM Mono', monospace;
      font-size: 7.5px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: rgba(240, 237, 232, 0.45);
    }
    .fc-seats-limit {
      color: rgba(240, 237, 232, 0.3);
    }
    .fc-cta {
      display: block;
      text-align: center;
      background: #a67c52;
      color: #f8f7f5;
      padding: 14px 24px;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-decoration: none;
      transition:
        background 0.25s,
        transform 0.2s;
      position: relative;
      overflow: hidden;
      margin-top: 4px;
    }
    .fc-cta::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.1) 50%,
        transparent 100%
      );
      transform: translateX(-100%);
      transition: transform 0.45s ease;
    }
    .fc-cta:hover {
      background: #8f6a40;
      transform: translateY(-1px);
    }
    .fc-cta:hover::after {
      transform: translateX(100%);
    }
    .fc-note {
      text-align: center;
      font-size: 9.5px;
      color: rgba(240, 237, 232, 0.38);
      font-weight: 300;
      margin: 0;
      letter-spacing: 0.2px;
    }
    @media (max-width: 768px) {
      .founders-card {
        padding: 24px 20px;
        gap: 10px;
      }
      .fc-title {
        font-size: 22px;
      }
      .fc-features {
        gap: 6px;
      }
    }

    /* ── MARQUEE ── */
    .marquee-section {
      background: #a67c52;
      padding: 0;
      overflow: hidden;
      height: 36px;
      display: flex;
      align-items: center;
    }
    .marquee-track {
      display: flex;
      align-items: center;
      gap: 0;
      animation: marquee 30s linear infinite;
      white-space: nowrap;
      height: 36px;
    }
    .marquee-item {
      color: rgba(255, 255, 255, 0.9);
      font-family: 'Instrument Sans', sans-serif;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      padding: 0 32px;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      height: 36px;
      line-height: 1;
    }
    .marquee-item::after {
      content: '·';
      margin-left: 32px;
      opacity: 0.45;
    }
    @keyframes marquee {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }

    /* ── SECTION SHARED ── */
    section {
      padding: 96px 60px;
    }
    .section-eyebrow {
      font-family: 'DM Mono', monospace !important;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #a67c52;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-eyebrow::before {
      content: '';
      width: 30px;
      height: 1px;
      background: #a67c52;
      flex-shrink: 0;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 300;
      line-height: 1.1;
      color: #1a1917;
      margin-bottom: 16px;
    }
    .section-title em {
      font-style: italic;
      color: #a67c52;
    }
    .gold-divider {
      width: 40px;
      height: 1px;
      background: #a67c52;
      margin: 24px 0;
    }

    /* ── SEARCH PREVIEW ── */
    .search-preview {
      background: #f8f7f5;
      border-top: 1px solid #e8e6e2;
      padding: 64px 60px 44px;
      position: relative;
      overflow: hidden;
    }
    .search-preview::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(
        ellipse 80% 60% at 50% 30%,
        rgba(160, 120, 60, 0.05) 0%,
        transparent 70%
      );
      pointer-events: none;
    }
    .sp-inner {
      max-width: 740px;
      margin: 0 auto;
      position: relative;
    }
    .sp-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .sp-subtitle {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #8a8784;
      margin-top: 12px;
    }
    .sp-bar-wrap {
      position: relative;
      margin-bottom: 16px;
    }
    .sp-icon {
      position: absolute;
      left: 18px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 20px;
      color: #a67c52;
      pointer-events: none;
      z-index: 2;
    }
    .sp-input {
      width: 100%;
      background: #ffffff;
      border: 1px solid #e2e0dc;
      border-radius: 0;
      color: #1a1917;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 16px;
      padding: 18px 120px 18px 52px;
      outline: none;
      transition:
        border-color 0.3s,
        box-shadow 0.3s;
      letter-spacing: 0.3px;
    }
    .sp-input:focus {
      border-color: #a67c52;
      box-shadow: 0 0 0 3px rgba(166, 124, 82, 0.1);
    }
    .sp-input::placeholder {
      color: #8a8784;
      font-size: 14px;
    }
    .sp-kbd {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #8a8784;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .sp-input:focus ~ .sp-kbd {
      opacity: 1;
    }
    .sp-trending {
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid rgba(30, 25, 20, 0.07);
    }
    .sp-trending-label {
      font-size: 9px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #8a8784;
      margin-bottom: 10px;
    }
    .sp-trending-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .sp-trending-tag {
      font-size: 11px;
      letter-spacing: 1px;
      padding: 6px 14px;
      border: 1px solid rgba(30, 25, 20, 0.1);
      color: #a67c52;
      cursor: pointer;
      transition: all 0.2s;
      background: transparent;
      font-family: 'Instrument Sans', sans-serif;
    }
    .sp-trending-tag:hover {
      border-color: #a67c52;
      background: rgba(160, 120, 60, 0.04);
    }
    .sp-results-wrap {
      margin-top: 4px;
    }
    .sp-results-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(30, 25, 20, 0.07);
    }
    .sp-results-count {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #a67c52;
    }
    .sp-results-hint {
      font-size: 10px;
      color: #8a8784;
      letter-spacing: 1px;
    }
    .sp-results-grid {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .sp-card {
      display: flex;
      align-items: stretch;
      background: #ffffff;
      border: 1px solid #e2e0dc;
      cursor: pointer;
      transition:
        background 0.2s,
        border-color 0.2s,
        transform 0.15s;
      text-decoration: none;
      color: inherit;
      animation: spFadeIn 0.2s ease both;
    }
    .sp-card:hover {
      background: #f8f7f5;
      border-color: rgba(166, 124, 82, 0.35);
      transform: translateX(4px);
    }
    @keyframes spFadeIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .sp-card-thumb {
      width: 64px;
      height: 64px;
      flex-shrink: 0;
      overflow: hidden;
      background: rgba(0, 0, 0, 0.3);
      align-self: stretch;
      display: flex;
      align-items: center;
    }
    .sp-card-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: brightness(0.9);
      transition: filter 0.2s;
    }
    .sp-card:hover .sp-card-thumb img {
      filter: brightness(1);
    }
    .sp-card-body {
      padding: 14px 16px;
      flex: 1;
      min-width: 0;
      display: flex;
      gap: 16px;
      align-items: center;
    }
    .sp-card-main {
      flex: 1;
      min-width: 0;
    }
    .sp-card-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      color: #1a1917;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sp-more-btn {
      background: transparent;
      border: 1px solid rgba(196, 168, 130, 0.2);
      color: #a67c52;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 10px 28px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .sp-more-btn:hover {
      border-color: #a67c52;
    }
    .sp-results-more {
      text-align: center;
      margin-top: 12px;
    }
    .sp-empty {
      text-align: center;
      padding: 32px 0;
    }
    .sp-empty-icon {
      font-size: 24px;
      color: #8a8784;
      margin-bottom: 8px;
      opacity: 0.4;
    }
    .sp-empty-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      color: #a67c52;
      margin-bottom: 6px;
    }
    .sp-empty-sub {
      font-size: 12px;
      color: #8a8784;
    }

    /* ── PROFESSIONALS ── */
    .professionals {
      padding: 72px 60px;
      background: #f8f7f5;
    }
    .pro-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(30, 25, 20, 0.06);
      margin-top: 48px;
    }
    @media (max-width: 900px) {
      .pro-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 500px) {
      .pro-grid {
        grid-template-columns: 1fr;
      }
    }
    .pro-card {
      background: #ffffff;
      border: 1px solid #e2e0dc;
      padding: 32px 24px 28px;
      text-align: center;
      transition: background 0.3s;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
    }
    .pro-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: #a67c52;
      transform: scaleX(0);
      transition: transform 0.3s;
    }
    .pro-card:hover {
      background: #f2ede8;
      border-top: 2px solid #a67c52 !important;
    }
    .pro-card:hover::after {
      transform: scaleX(1);
    }
    .pro-icon {
      font-size: 36px;
      margin-bottom: 12px;
      display: block;
    }
    .pro-icon svg {
      width: 36px;
      height: 36px;
      display: block;
      margin: 0 auto;
    }
    .pro-num {
      font-family: 'DM Mono', monospace !important;
      font-size: 11px;
      letter-spacing: 4px;
      color: #bab8b5;
      margin-bottom: 8px;
    }
    .pro-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
