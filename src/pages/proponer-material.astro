---
import Page from "../layouts/Page.astro";
---

<Page
  title="Proponer Material — World Stone Hub"
  description="Añade un material al catálogo de World Stone Hub. Tu propuesta será revisada y publicada en un plazo de 24-48h."
  noIndex={true}
>
  <style slot="head">
    main {
      background: var(--bg-soft);
    }
    .page {
      margin-top: 70px;
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
      padding: 48px 24px 80px;
    }
    .page-header {
      margin-bottom: 40px;
    }
    .page-eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }
    .page-title {
      font-family: "Cormorant Garamond", serif;
      font-size: 2.4rem;
      font-weight: 300;
      line-height: 1.1;
      margin-bottom: 12px;
    }
    .page-desc {
      font-size: 0.85rem;
      color: var(--ink-2);
      line-height: 1.7;
    }
    .notice {
      background: var(--bg-soft);
      border: 1px solid var(--border2);
      border-left: 3px solid var(--gold);
      padding: 14px 18px;
      font-size: 0.8rem;
      color: var(--ink-2);
      margin-bottom: 32px;
      border-radius: 2px;
    }
    /* Auth gate */
    .auth-gate {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 48px;
      text-align: center;
      border-radius: 2px;
    }
    .auth-gate-icon {
      font-size: 2rem;
      margin-bottom: 16px;
      opacity: 0.3;
    }
    .auth-gate-title {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.4rem;
      margin-bottom: 8px;
    }
    .auth-gate-desc {
      font-size: 0.82rem;
      color: var(--ink-2);
      margin-bottom: 24px;
    }
    .btn {
      display: inline-block;
      padding: 12px 28px;
      background: var(--ink);
      color: white;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 2px;
      cursor: pointer;
      border: none;
      font-family: "Instrument Sans", sans-serif;
      transition: background 0.2s;
      text-decoration: none;
    }
    .btn:hover {
      background: var(--gold);
    }
    .btn.outline {
      background: transparent;
      color: var(--ink);
      border: 1px solid var(--border2);
    }
    .btn.outline:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .btn.gold {
      background: var(--gold);
    }
    .btn.gold:hover {
      background: #8a6340;
    }
    /* Form */
    .form-card {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 40px;
      border-radius: 2px;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }
    .form-section {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .form-section-title {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-4);
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-group.full {
      grid-column: 1 / -1;
    }
    label {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-2);
    }
    input,
    select,
    textarea {
      padding: 10px 14px;
      border: 1px solid var(--border);
      background: var(--bg-soft);
      font-family: "Instrument Sans", sans-serif;
      font-size: 0.82rem;
      color: var(--ink);
      border-radius: 2px;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--gold);
      background: var(--bg);
    }
    textarea {
      resize: vertical;
      min-height: 80px;
    }
    /* Autocomplete canteras */
    .autocomplete-wrap {
      position: relative;
    }
    .autocomplete-input-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 8px 12px;
      border: 1px solid var(--border);
      background: var(--bg-soft);
      border-radius: 2px;
      min-height: 44px;
      cursor: text;
      transition: border-color 0.2s;
    }
    .autocomplete-input-wrap:focus-within {
      border-color: var(--gold);
      background: var(--bg);
    }
    .autocomplete-input-wrap input {
      border: none;
      background: transparent;
      padding: 2px 4px;
      flex: 1;
      min-width: 140px;
      font-size: 0.82rem;
    }
    .autocomplete-input-wrap input:focus {
      outline: none;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 10px;
      background: var(--ink);
      color: white;
      font-size: 0.68rem;
      border-radius: 2px;
    }
    .chip-remove {
      cursor: pointer;
      opacity: 0.6;
      font-size: 0.8rem;
      line-height: 1;
    }
    .chip-remove:hover {
      opacity: 1;
    }
    .autocomplete-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border: 1px solid var(--border);
      max-height: 220px;
      overflow-y: auto;
      z-index: 50;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }
    .autocomplete-dropdown.open {
      display: block;
    }
    .autocomplete-item {
      padding: 10px 16px;
      cursor: pointer;
      font-size: 0.8rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border);
    }
    .autocomplete-item:last-child {
      border-bottom: none;
    }
    .autocomplete-item:hover,
    .autocomplete-item.active {
      background: var(--bg-soft);
    }
    .autocomplete-item-sub {
      font-size: 0.7rem;
      color: var(--ink-2);
    }
    /* Submit */
    .form-actions {
      display: flex;
      gap: 12px;
      align-items: center;
      padding-top: 8px;
      border-top: 1px solid var(--border);
    }
    .form-status {
      font-size: 0.78rem;
      padding: 12px 16px;
      border-radius: 2px;
      display: none;
    }
    .form-status.success {
      background: var(--bg-soft);
      color: var(--gold);
      border: 1px solid rgba(166, 124, 82, 0.25);
      display: block;
    }
    .form-status.error {
      background: #fce4e4;
      color: #c62828;
      border: 1px solid #ffcdd2;
      display: block;
    }
    .spinner {
      width: 20px;
      height: 20px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: inline-block;
    }
    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
  </style>

  <div class="page">
    <div class="page-header">
      <div class="page-eyebrow">Directorio · Contribuir</div>
      <h1 class="page-title">Proponer un material</h1>
      <p class="page-desc">Añade un material al catálogo de World Stone Hub. Tu propuesta será revisada y publicada en un plazo de 24-48h.</p>
    </div>

    <!-- Auth gate -->
    <div id="authGate" style="display:none">
      <div class="auth-gate">
        <div class="auth-gate-icon">◇</div>
        <div class="auth-gate-title">Acceso requerido</div>
        <div class="auth-gate-desc">Debes tener una cuenta activa en World Stone Hub para proponer materiales.</div>
        <a href="/panel.html" class="btn">Acceder a mi panel</a>
      </div>
    </div>

    <!-- Formulario -->
    <div id="formWrap" style="display:none">
      <div class="notice">
        ⏱ Tu propuesta quedará en estado <strong>pendiente</strong> hasta que sea revisada y aprobada manualmente. Recibirás confirmación en tu email.
      </div>

      <div class="form-card">
        <div class="form-section">
          <div class="form-section-title">Identificación del material</div>
          <div class="form-row">
            <div class="form-group full">
              <label>Nombre comercial *</label>
              <input id="f-nombre" type="text" placeholder="Ej: Bianco Carrara C" required />
            </div>
            <div class="form-group">
              <label>Categoría *</label>
              <select id="f-categoria">
                <option value="">— Selecciona —</option>
                <option>Mármol</option><option>Granito</option><option>Cuarcita</option>
                <option>Travertino</option><option>Caliza</option><option>Pizarra</option>
                <option>Ónix</option><option>Arenisca</option><option>Basalto</option>
                <option>Cuarzo engineered</option><option>Piedra sinterizada</option>
                <option>Porcelánico</option><option>Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label>País de origen</label>
              <input id="f-pais" type="text" placeholder="Ej: Italia" />
            </div>
            <div class="form-group">
              <label>Color principal</label>
              <input id="f-color" type="text" placeholder="Ej: Blanco con venas grises" />
            </div>
            <div class="form-group">
              <label>Rango de precio</label>
              <select id="f-precio">
                <option value="">— Selecciona —</option>
                <option value="económico">Económico</option>
                <option value="medio">Medio</option>
                <option value="alto">Alto</option>
                <option value="premium">Premium</option>
                <option value="ultra-premium">Ultra Premium</option>
              </select>
            </div>
            <div class="form-group">
              <label>Acabados disponibles</label>
              <input id="f-acabados" type="text" placeholder="Ej: Pulido, apomazado, cepillado" />
            </div>
            <div class="form-group full">
              <label>Usos recomendados</label>
              <input id="f-usos" type="text" placeholder="Ej: Encimeras, revestimiento, suelos exteriores" />
            </div>
            <div class="form-group full">
              <label>Descripción libre</label>
              <textarea id="f-desc" placeholder="Cualquier información adicional relevante sobre este material…"></textarea>
            </div>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-title">Canteras de origen (opcional)</div>
          <p style="font-size:.78rem;color:var(--ink-2);margin-bottom:4px">Vincula este material con las canteras de las que se extrae.</p>
          <div class="form-group">
            <label>Buscar y añadir canteras</label>
            <div class="autocomplete-wrap" id="canterasWrap">
              <div class="autocomplete-input-wrap" id="canterasChips" onclick="document.getElementById('canterasInput').focus()">
                <input id="canterasInput" type="text" placeholder="Escribe para buscar canteras…" autocomplete="off" />
              </div>
              <div class="autocomplete-dropdown" id="canterasDropdown"></div>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button class="btn gold" id="submitBtn" onclick="submitForm()">Enviar propuesta</button>
          <a href="/materiales.html" class="btn outline">Cancelar</a>
          <div class="spinner" id="spinner" style="display:none"></div>
        </div>
        <div class="form-status" id="formStatus"></div>
      </div>
    </div>
  </div>

  <script is:inline slot="scripts">
  (function(){
  var SB_URL='https://whcptmdapnavcxcszwwk.supabase.co';
  var SB_KEY='sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
  var db=supabase.createClient(SB_URL,SB_KEY);
  var session=null;
  var canterasSeleccionadas=[];
  var todasCanteras=[];

  db.auth.getSession().then(function(r){
    session=r.data&&r.data.session;
    if(session){
      document.getElementById('formWrap').style.display='block';
      cargarCanteras();
    } else {
      document.getElementById('authGate').style.display='block';
    }
  });

  function cargarCanteras(){
    db.from('canteras').select('id,slug,nombre,pais,tipo_piedra').order('nombre')
      .then(function(r){ todasCanteras=r.data||[]; });
  }

  var inp=document.getElementById('canterasInput');
  var dd=document.getElementById('canterasDropdown');

  inp.addEventListener('input',function(){
    var q=inp.value.toLowerCase().trim();
    if(!q){dd.classList.remove('open');return;}
    var matches=todasCanteras.filter(function(c){
      return c.nombre.toLowerCase().includes(q)||
             (c.pais||'').toLowerCase().includes(q)||
             (c.tipo_piedra||'').toLowerCase().includes(q);
    }).slice(0,8);
    if(!matches.length){dd.classList.remove('open');return;}
    dd.innerHTML=matches.map(function(c){
      var sel=canterasSeleccionadas.some(function(s){return s.id===c.id;});
      return '<div class="autocomplete-item'+(sel?' active':'')+'" data-id="'+c.id+'" data-slug="'+c.slug+'" data-nombre="'+c.nombre.replace(/"/g,'&quot;')+'">'
        +'<span>'+c.nombre+'</span>'
        +'<span class="autocomplete-item-sub">'+c.pais+' · '+c.tipo_piedra+'</span>'
        +'</div>';
    }).join('');
    dd.classList.add('open');
    dd.querySelectorAll('.autocomplete-item').forEach(function(el){
      el.addEventListener('click',function(){
        var id=el.getAttribute('data-id');
        var slug=el.getAttribute('data-slug');
        var nombre=el.getAttribute('data-nombre');
        if(!canterasSeleccionadas.some(function(s){return s.id===id;})){
          canterasSeleccionadas.push({id:id,slug:slug,nombre:nombre});
          renderChips();
        }
        inp.value='';
        dd.classList.remove('open');
      });
    });
  });

  document.addEventListener('click',function(e){
    if(!document.getElementById('canterasWrap').contains(e.target)) dd.classList.remove('open');
  });

  function renderChips(){
    var chips=document.getElementById('canterasChips');
    chips.querySelectorAll('.chip').forEach(function(c){c.remove();});
    canterasSeleccionadas.forEach(function(c){
      var chip=document.createElement('span');
      chip.className='chip';
      chip.innerHTML=c.nombre+'<span class="chip-remove" data-id="'+c.id+'">×</span>';
      chip.querySelector('.chip-remove').addEventListener('click',function(e){
        e.stopPropagation();
        canterasSeleccionadas=canterasSeleccionadas.filter(function(s){return s.id!==c.id;});
        renderChips();
      });
      chips.insertBefore(chip,inp);
    });
  }

  window.submitForm=function(){
    var nombre=document.getElementById('f-nombre').value.trim();
    var categoria=document.getElementById('f-categoria').value;
    if(!nombre||!categoria){showStatus('Por favor completa nombre y categoría.','error');return;}
    if(!session){showStatus('Sesión caducada. Por favor recarga la página.','error');return;}
    document.getElementById('submitBtn').disabled=true;
    document.getElementById('spinner').style.display='inline-block';
    var payload={
      user_id:session.user.id,
      nombre_comercial:nombre,
      categoria:categoria,
      origen_pais:document.getElementById('f-pais').value.trim()||null,
      color_principal:document.getElementById('f-color').value.trim()||null,
      acabados:document.getElementById('f-acabados').value.trim()||null,
      usos:document.getElementById('f-usos').value.trim()||null,
      precio_rango:document.getElementById('f-precio').value||null,
      descripcion_libre:document.getElementById('f-desc').value.trim()||null,
      canteras_vinculadas:canterasSeleccionadas.map(function(c){return c.slug;}),
      estado:'pendiente'
    };
    db.from('propuestas_materiales').insert(payload).then(function(r){
      document.getElementById('spinner').style.display='none';
      document.getElementById('submitBtn').disabled=false;
      if(r.error){showStatus('Error: '+r.error.message,'error');return;}
      showStatus('✓ Propuesta enviada correctamente. La revisaremos en 24-48h.','success');
      document.querySelector('.form-card').style.opacity='.5';
      document.querySelector('.form-card').style.pointerEvents='none';
    });
  };

  function showStatus(msg,type){
    var el=document.getElementById('formStatus');
    el.textContent=msg;el.className='form-status '+type;
  }
  }());
  </script>
</Page>
