---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
---

<Base
  title="Alta Profesional · World Stone Hub"
  description="Registra tu empresa en el directorio global de piedra natural. Planes desde gratuito hasta Élite."
  ogTitle="Alta Profesional — World Stone Hub"
  ogDescription="Registra tu empresa en el directorio global de piedra natural. Planes desde gratuito hasta Élite."
  ogUrl="https://worldstonehub.com/registro.html"
  canonicalUrl="https://worldstonehub.com/registro.html"
  bodyClass="registro-body"
>

<style slot="head">
/* ═══════════════════════════════════════════════
   WORLD STONE HUB — REGISTRO PROFESIONAL
═══════════════════════════════════════════════ */
body.registro-body {
  background:#f8f7f5;
  color:#1a1917;
  font-family: 'Instrument Sans', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── OUTER SHELL ── */
.shell {
  display:grid;
  grid-template-columns:280px 1fr;
  min-height:100vh;
  padding-top:64px;
  width:100%;
}

/* ── LEFT SIDEBAR ── */
.sidebar {
  background: #f0efed;
  border-right:1px solid var(--border);
  padding:48px 28px;
  position:sticky; top:64px; height:calc(100vh - 64px);
  display:flex; flex-direction:column;
  overflow:hidden;
}
.sidebar-stone-bg {
  position:absolute; inset:0; pointer-events:none;
  background: radial-gradient(ellipse 120% 60% at 80% 110%, rgba(201,168,76,0.04) 0%, transparent 60%);
}
.sidebar-eyebrow {
  font-size:8px; letter-spacing:5px; text-transform:uppercase; color:#A67C52; margin-bottom:20px;
}
.sidebar-title {
  font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:300; color:#1a1917; line-height:1.1; margin-bottom:8px;
}
.sidebar-title em { color:#A67C52; font-style:italic; display:block; }
.sidebar-sub { font-size:12px; color:#8a8784; line-height:1.7; margin-bottom:48px; }

/* Step list in sidebar */
.step-list { display:flex; flex-direction:column; gap:0; position:relative; }
.step-list::before {
  content:''; position:absolute; left:15px; top:20px; bottom:20px; width:1px;
  background: linear-gradient(to bottom, #A67C52, transparent);
  opacity:0.2;
}
.step-row {
  display:flex; align-items:flex-start; gap:16px; padding:14px 0;
  transition:all 0.3s; cursor:default;
}
.step-dot {
  width:30px; height:30px; border-radius:50%; flex-shrink:0;
  border:1px solid var(--border2); background:#f0efed;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; color:#8a8784; transition:all 0.4s; z-index:1;
  font-family:'Instrument Sans',sans-serif; font-weight:500;
}
.step-row.active .step-dot {
  border-color:#A67C52; background:rgba(160,120,60,0.08); color:#A67C52;
  box-shadow:0 0 16px rgba(201,168,76,0.15);
}
.step-row.done .step-dot {
  border-color:var(--green); background:var(--green); color:#f8f7f5;
  font-size:13px;
}
.step-row.done .step-dot::after { content:'✓'; }
.step-row.done .step-num { display:none; }
.step-info { padding-top:4px; }
.step-name {
  font-size:12px; font-weight:500; letter-spacing:1px; color:#8a8784; transition:color 0.3s;
}
.step-row.active .step-name { color:#1a1917; }
.step-row.done .step-name  { color:#8a8784; }
.step-desc { font-size:10px; color:#8a8784; margin-top:3px; opacity:0; transition:opacity 0.3s; letter-spacing:0.3px; }
.step-row.active .step-desc { opacity:1; color:#4a4845; }

/* Sidebar plan badge (shows after step 1) */
.sidebar-plan-badge {
  margin-top:auto; padding:20px; background:#f0efed;
  border:1px solid var(--border2); display:none;
}
.sidebar-plan-badge.show { display:block; }
.spb-label { font-size:8px; letter-spacing:4px; text-transform:uppercase; color:#8a8784; margin-bottom:8px; }
.spb-name { font-family:'Cormorant Garamond',serif; font-size:26px; color:#A67C52; line-height:1; }
.spb-price { font-size:11px; color:#4a4845; margin-top:4px; letter-spacing:1px; }
.spb-actors { font-size:10px; color:#8a8784; margin-top:8px; padding-top:8px; border-top:1px solid var(--border); line-height:1.6; }

/* ── MAIN CONTENT ── */
.main {
  padding:48px 56px 80px;
  width:100%;
  box-sizing:border-box;
  min-width:0;
}

/* ── SCREENS ── */
.screen { display:none; }
.screen.active {
  display:block;
  animation: screenIn 0.5s cubic-bezier(0.22,1,0.36,1) both;
}
@keyframes screenIn {
  from { opacity:0; transform:translateY(24px); }
  to   { opacity:1; transform:translateY(0); }
}

.screen-eyebrow { font-size:9px; letter-spacing:5px; text-transform:uppercase; color:#A67C52; margin-bottom:16px; }
.screen-title { font-family:'Cormorant Garamond',serif; font-size:clamp(36px,4vw,58px); font-weight:300; color:#1a1917; line-height:1.1; margin-bottom:12px; }
.screen-title em { color:#A67C52; font-style:italic; }
.screen-desc { font-size:13px; color:#8a8784; line-height:1.8; max-width:520px; margin-bottom:52px; }
.screen-desc a { color:#A67C52; text-decoration:none; }

/* ════════════════════════
   STEP 1 — ACTOR TYPE
════════════════════════ */
.plans-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:3px; margin-top:36px; margin-bottom:44px;
}
@media(max-width:800px){ .plans-grid { grid-template-columns:repeat(2,1fr); } .shell { grid-template-columns:1fr; } .sidebar { display:none; } }

.plan-card-wrap {
  display:flex; flex-direction:column;
  padding-top:30px;
}
.plan-card {
  background:#f0efed;
  border:1px solid #e2e0dc;
  padding:26px 22px 22px;
  cursor:pointer;
  transition:background .25s, border-color .25s, box-shadow .3s, transform .2s;
  position:relative;
  display:flex; flex-direction:column; gap:0;
  user-select:none;
  flex:1;
}
.plan-card:hover {
  background:rgba(50,42,32,.95);
  border-color:rgba(201,168,76,.38);
  transform:translateY(-4px);
  box-shadow:
    0 0 0 1px rgba(160,120,60,0.10),
    0 20px 52px -10px rgba(0,0,0,.6),
    0 4px 18px rgba(160,120,60,0.06);
}
.plan-card.selected {
  border-color:#A67C52;
  background:rgba(201,168,76,.06);
  transform:translateY(-4px);
  box-shadow:
    0 0 0 1px rgba(160,120,60,0.28),
    0 20px 52px -10px rgba(0,0,0,.5),
    0 4px 20px rgba(160,120,60,0.08);
}
.plan-card.featured {
  border-color:rgba(201,168,76,.2);
  border-top:2px solid #A67C52;
}
.plan-card.featured:hover {
  border-color:rgba(160,120,60,0.4);
  border-top-color:#A67C52;
}
.plan-card.selected .plan-check { opacity:1; transform:scale(1); }
.plan-check {
  position:absolute; top:14px; right:14px;
  width:20px; height:20px; background:#A67C52; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:10px; color:#f8f7f5; font-weight:700;
  opacity:0; transform:scale(0.5); transition:all 0.25s;
}
.plan-popular {
  position:absolute;
  top:-30px; left:-1px; right:-1px;
  height:28px;
  display:flex; align-items:center; justify-content:center;
  background:#A67C52; color:#f8f7f5;
  font-size:8px; letter-spacing:4px; text-transform:uppercase;
  font-family:'Instrument Sans',sans-serif; font-weight:700;
}
.plan-tag {
  font-size:8px; letter-spacing:4px; text-transform:uppercase;
  margin-bottom:14px; margin-top:0;
  min-height:16px;
}
.t-free { color:#4a8a5a; } .t-base { color:#4a4845; } .t-pro { color:#A67C52; } .t-elite { color:#C9A84C; }
.plan-name { font-family:'Cormorant Garamond',serif; font-size:28px; color:#1a1917; margin-bottom:4px; }
.plan-price-line { display:flex; align-items:baseline; gap:3px; margin-bottom:2px; }
.plan-price { font-family:'Cormorant Garamond',serif; font-size:42px; line-height:1; color:#A67C52; }
.plan-price sup { font-size:18px; vertical-align:super; }
.plan-pm { font-size:11px; color:#8a8784; }
.plan-billing { font-size:9px; color:#8a8784; letter-spacing:1px; margin-bottom:6px; }
.plan-saving  { font-size:9px; color:#A67C52; letter-spacing:0.5px; margin-bottom:14px; font-weight:600; }

/* ── Billing toggle ── */
.bill-toggle-wrap {
  display: flex; align-items: center; gap: 4px;
  margin-bottom: 4px;
}
.bill-btn {
  padding: 7px 20px;
  font-family: 'Instrument Sans', sans-serif;
  font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
  border: 1px solid var(--border2);
  background: var(--bg-mid);
  color: var(--ink-4);
  cursor: pointer;
  transition: all 0.18s;
  border-radius: 4px;
}
.bill-btn:first-child { border-radius: 4px 0 0 4px; }
.bill-btn:nth-child(2) { border-radius: 0 4px 4px 0; border-left: none; }
.bill-btn.active {
  background: var(--ink);
  border-color: var(--ink);
  color: #fff;
}
.bill-save-badge {
  display: inline-flex; align-items: center;
  background: #F5EFEA;
  color: #A67C52;
  font-size: 10px; font-weight: 600;
  padding: 4px 10px; border-radius: 20px;
  letter-spacing: 0.3px; margin-left: 8px;
  border: 1px solid rgba(166,124,82,0.25);
}
.plan-divider { height:1px; background:var(--border); margin:0 0 18px; }
.plan-feats { list-style:none; display:flex; flex-direction:column; gap:9px; flex:1; }
.plan-feats li {
  font-size:11.5px; color:#4a4845; display:flex; align-items:flex-start; gap:7px; line-height:1.4;
}
.plan-feats li .fi { color:#A67C52; flex-shrink:0; font-size:9px; margin-top:2px; }
.plan-feats li.off { color:#8a8784; }
.plan-feats li.off .fi { color:#8a8784; }

/* Comparison table */
.compare-wrap {
  background:#f0efed; border:1px solid #e2e0dc;
  padding:24px 28px; margin-top:2px;
}
.compare-hd { font-size:9px; letter-spacing:4px; text-transform:uppercase; color:#8a8784; margin-bottom:16px; }
.compare-row {
  display:grid; grid-template-columns:2fr 1fr 1fr 1fr 1fr;
  gap:4px; padding:8px 0; border-bottom:1px solid rgba(185,152,112,0.05);
  font-size:11px; align-items:center;
}
.compare-row:last-child { border:none; }
.compare-row.hd { font-size:9px; letter-spacing:2px; text-transform:uppercase; color:#8a8784; }
.cf { color:#4a4845; }
.cv { text-align:center; color:#8a8784; font-size:11px; }
.cv.y { color:#6aaa7a; } .cv.n { color:rgba(122,106,86,0.3); } .cv.g { color:#A67C52; font-weight:500; }

/* ════════════════════════
   STEP 1 — ACTOR CARDS
════════════════════════ */
.actors-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:2px; margin-bottom:12px;
}
@media(max-width:900px){ .actors-grid{ grid-template-columns:repeat(2,1fr); } }
@media(max-width:720px){ .actors-grid{ grid-template-columns:repeat(2,1fr); } }
@media(max-width:500px){ .actors-grid{ grid-template-columns:1fr; } }

.actor-card {
  background:#f0efed; border:2px solid transparent;
  padding:28px 24px; cursor:pointer;
  transition:all 0.22s; user-select:none; position:relative;
  min-height:140px; display:flex; flex-direction:column;
}
.actor-card:hover { background:#f0efed; border-color:rgba(185,152,112,0.2); }
.actor-card.selected { border-color:#A67C52; background:rgba(201,168,76,0.04); }
.actor-card.selected .ac-check { opacity:1; }
.ac-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; }
.ac-icon { font-size:20px; line-height:1; }
.ac-check {
  width:18px; height:18px; background:#A67C52; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:9px; color:#f8f7f5; font-weight:700; opacity:0;
  transition:opacity 0.2s; flex-shrink:0;
}
.ac-name { font-family:'Cormorant Garamond',serif; font-size:20px; color:#1a1917; margin-bottom:5px; }
.ac-desc { font-size:11px; color:#8a8784; line-height:1.6; }

.actors-section-hd{grid-column:1/-1;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:#8a8784;padding:10px 0 6px;border-bottom:1px solid var(--border);margin-bottom:6px;display:flex;align-items:center;gap:12px;}
.actors-section-hd .demand-badge{font-size:8px;letter-spacing:2px;background:#F5EFEA;color:#A67C52;padding:2px 8px;border:1px solid rgba(166,124,82,0.25);text-transform:uppercase;font-family:'Instrument Sans',sans-serif;}

/* ════════════════════════
   STEP 2 — FORM
════════════════════════ */
.fsections { display:flex; flex-direction:column; gap:40px; }
.fsec { margin-bottom:2px; }
.fsec-hd {
  font-size:9px; letter-spacing:5px; text-transform:uppercase; color:#A67C52;
  padding-bottom:14px; margin-bottom:20px; border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:10px;
}
.fsec-hd::before { content:'◆'; font-size:7px; }

.fgrid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:2px; }
.fgrid.g2 { grid-template-columns:1fr 1fr; }
.fgrid.g1 { grid-template-columns:1fr; }
.fgrid.g3 { grid-template-columns:1fr 1fr 1fr; }
@media(max-width:960px){ .fgrid { grid-template-columns:1fr 1fr; } }
@media(max-width:620px){ .fgrid, .fgrid.g2, .fgrid.g3 { grid-template-columns:1fr; } }

.field {
  background:#ffffff; padding:18px 20px;
  border:1px solid #e8e6e2; transition:border-color 0.2s;
  display:flex; flex-direction:column; gap:7px; position:relative;
}
.field:focus-within { border-color:rgba(201,168,76,0.3); }
.field.err { border-color:rgba(160,70,70,0.5); }
.field.locked { opacity:0.38; pointer-events:none; }

.flabel {
  font-size:9px; letter-spacing:3px; text-transform:uppercase; color:#8a8784;
  display:flex; align-items:center; gap:4px;
}
.flabel .req { color:#A67C52; }

.field input, .field select, .field textarea {
  background:#ffffff; border:none; outline:none;
  color:#1A1410; font-family:'Instrument Sans',sans-serif; font-size:15px;
  width:100%; padding:0; resize:vertical;
}
.field select option { background:#ffffff; color:#1A1410; }
.field textarea { resize:vertical; min-height:88px; line-height:1.65; }
.field input::placeholder, .field textarea::placeholder { color:rgba(122,106,86,0.5); }
.field-hint { font-size:9px; color:#8a8784; letter-spacing:0.5px; }
.field-err-msg { font-size:9px; color:#c07070; letter-spacing:0.5px; display:none; }
.field.err .field-err-msg { display:block; }

/* Upload zones */
.uzone {
  border:1px dashed rgba(185,152,112,0.2); padding:28px 20px; text-align:center;
  cursor:pointer; transition:border-color 0.2s; background:rgba(0,0,0,0.12);
  display:flex; flex-direction:column; align-items:center; gap:8px;
}
.uzone:hover { border-color:#A67C52; }
.uzone-icon { font-size:22px; color:#8a8784; }
.uzone-text { font-size:12px; color:#8a8784; }
.uzone-text span { color:#4a4845; }
.uzone-limit { font-size:9px; color:#8a8784; letter-spacing:1px; }

/* Tier upgrade notice */
.tier-notice {
  background:rgba(201,168,76,0.04); border-left:2px solid #A67C52;
  padding:12px 16px; margin-bottom:2px;
  font-size:11px; color:#4a4845; line-height:1.7;
  display:flex; align-items:flex-start; gap:10px;
}
.tier-notice::before { content:'↑'; color:#A67C52; font-size:13px; flex-shrink:0; }

/* ════════════════════════
   STEP 4 — REVIEW
════════════════════════ */
.review-plan {
  background:#f0efed; border:1px solid var(--border2);
  padding:28px; margin-bottom:2px;
  display:flex; justify-content:space-between; align-items:center;
}
.rp-tag { font-size:9px; letter-spacing:4px; text-transform:uppercase; color:#8a8784; margin-bottom:8px; }
.rp-name { font-family:'Cormorant Garamond',serif; font-size:36px; color:#A67C52; line-height:1; }
.rp-actors { font-size:11px; color:#8a8784; margin-top:6px; }
.rp-right { text-align:right; }
.rp-price { font-family:'Cormorant Garamond',serif; font-size:44px; color:#1a1917; line-height:1; }
.rp-price sup { font-size:20px; }
.rp-period { font-size:10px; color:#8a8784; margin-top:4px; letter-spacing:1px; }

.review-grid { display:grid; grid-template-columns:1fr 1fr; gap:2px; margin-bottom:24px; }
.rv-block { background:#f0efed; padding:24px 22px; }
.rv-title { font-size:9px; letter-spacing:4px; text-transform:uppercase; color:#A67C52; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid var(--border); }
.rv-row { display:flex; justify-content:space-between; gap:12px; padding:7px 0; font-size:12px; border-bottom:1px solid rgba(185,152,112,0.04); }
.rv-row:last-child { border:none; }
.rv-k { color:#8a8784; flex-shrink:0; }
.rv-v { color:#1a1917; text-align:right; max-width:220px; word-break:break-all; }

/* Terms */
.terms-label {
  display:flex; align-items:flex-start; gap:14px; cursor:pointer;
  padding:20px; background:#f0efed; border:1px solid #e2e0dc;
  font-size:12px; color:#8a8784; line-height:1.7; margin-bottom:2px;
}
.terms-label input { width:16px; height:16px; flex-shrink:0; margin-top:2px; accent-color:#A67C52; cursor:pointer; }
.terms-label a { color:#A67C52; text-decoration:none; }

.btn-submit {
  width:100%; padding:18px; background:#A67C52; border:none;
  color:#f8f7f5; font-family:'Instrument Sans',sans-serif; font-size:11px;
  letter-spacing:4px; text-transform:uppercase; font-weight:500;
  cursor:pointer; transition:opacity 0.2s, transform 0.2s;
}
.btn-submit:hover { opacity:0.87; transform:translateY(-1px); }
.btn-submit:active { transform:translateY(0); }

/* ════════════════════════
   STEP 5 — SUCCESS
════════════════════════ */
.success-screen { padding:60px 0; text-align:center; }
.success-ring {
  width:88px; height:88px; border-radius:50%;
  border:1px solid rgba(74,122,90,0.4); background:rgba(74,122,90,0.06);
  display:flex; align-items:center; justify-content:center;
  font-size:34px; margin:0 auto 36px;
  animation: ringPop 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes ringPop { from{transform:scale(0);opacity:0;} to{transform:scale(1);opacity:1;} }
.success-title { font-family:'Cormorant Garamond',serif; font-size:clamp(36px,4vw,56px); color:#1a1917; margin-bottom:12px; }
.success-title em { color:#A67C52; }
.success-text { font-size:14px; color:#8a8784; max-width:460px; margin:0 auto 44px; line-height:1.85; }
.success-text strong { color:#4a4845; }
.success-links { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }
.sl { padding:12px 28px; font-size:10px; letter-spacing:3px; text-transform:uppercase; text-decoration:none; font-family:'Instrument Sans',sans-serif; transition:all 0.2s; }
.sl.gold { background:#A67C52; color:#f8f7f5; }
.sl.out  { border:1px solid var(--border2); color:#4a4845; }
.sl:hover { opacity:0.8; }

/* ── NAVIGATION BUTTONS ── */
.btn-row {
  display:flex; justify-content:space-between; align-items:center;
  margin-top:52px; padding-top:28px; border-top:1px solid var(--border);
}
.btn-back {
  background:transparent; border:1px solid #e2e0dc; color:#8a8784;
  font-family:'Instrument Sans',sans-serif; font-size:10px; letter-spacing:3px;
  text-transform:uppercase; padding:13px 24px; cursor:pointer; transition:all 0.2s;
}
.btn-back:hover { border-color:#4a4845; color:#1a1917; }
.btn-next {
  background:#A67C52; border:none; color:#f8f7f5;
  font-family:'Instrument Sans',sans-serif; font-size:10px; letter-spacing:3px;
  text-transform:uppercase; padding:13px 32px; cursor:pointer;
  transition:opacity 0.2s, transform 0.2s; font-weight:500;
}
.btn-next:hover:not(:disabled) { opacity:0.87; transform:translateY(-1px); }
.btn-next:disabled { opacity:0.3; cursor:not-allowed; }
.btn-row-info { font-size:10px; letter-spacing:2px; color:#8a8784; text-transform:uppercase; }

/* ── Smart Search Especialización ── */
.esp-search-wrap{position:relative;}
.esp-search-wrap input{width:100%;box-sizing:border-box;}
.esp-dropdown{position:absolute;top:calc(100% + 4px);left:0;right:0;background:#fff;border:1px solid #c8c5bf;border-top:2px solid #A67C52;z-index:200;max-height:280px;overflow-y:auto;box-shadow:0 8px 24px rgba(26,25,23,.1);}
.esp-opt{display:flex;align-items:center;gap:10px;padding:10px 14px;cursor:pointer;transition:background .15s;}
.esp-opt:hover{background:#f8f7f5;}
.esp-opt-badge{font-family:'DM Mono',monospace;font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;padding:2px 6px;border-radius:2px;flex-shrink:0;}
.esp-opt-badge-material{background:#A67C52;color:#fff;}
