  var WSH_SUPABASE_URL  = 'https://whcptmdapnavcxcszwwk.supabase.co';
  var WSH_SUPABASE_ANON = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
  var wshDB = window.supabase.createClient(WSH_SUPABASE_URL, WSH_SUPABASE_ANON);
