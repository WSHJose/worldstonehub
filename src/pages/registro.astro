<script is:inline slot="head">
// ── Smart Search: Especialización (materiales y canteras) ──────────────────
var _espData     = null;
var _espSelected = [];

function _espEsc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function loadEspData() {
  if (_espData) return Promise.resolve(_espData);
  return Promise.all([
    wshDB.from('materiales').select('slug,nombre_comercial,categoria').eq('activo',true).order('nombre_comercial').limit(500),
    wshDB.from('canteras').select('slug,nombre,tipo_piedra').eq('activo',true).order('nombre').limit(500)
  ]).then(function(res) {
    var mats  = (res[0].data||[]).map(function(m){
      return { type:'material', id:m.slug, label:m.nombre_comercial, sub:m.categoria };
    });
    var cants = (res[1].data||[]).map(function(c){
      return { type:'cantera', id:c.slug, label:c.nombre, sub:c.tipo_piedra };
    });
    _espData = mats.concat(cants);
    return _espData;
  });
}

function espSearch(q) {
  q = q.toLowerCase();
  return (_espData||[]).filter(function(item){
    return item.label.toLowerCase().includes(q) || (item.sub||'').toLowerCase().includes(q);
  }).slice(0,8);
}

function renderEspTags() {
  var container = document.getElementById('esp_tags');
  if (!container) return;
  container.innerHTML = _espSelected.map(function(item){
    var typeLbl = item.type === 'material' ? 'Material' : 'Cantera';
    return '<span class="esp-tag esp-tag-'+item.type+'" data-id="'+item.id+'">' +
      '<span class="esp-tag-type">'+typeLbl+'</span>' +
      _espEsc(item.label) +
      '<button class="esp-tag-rm" type="button" onclick="espRemove(\''+item.id+'\')">×</button>' +
    '</span>';
  }).join('');
}

function espRemove(id) {
  _espSelected = _espSelected.filter(function(i){ return i.id !== id; });
  renderEspTags();
}

function espAdd(item) {
  if (_espSelected.find(function(i){ return i.id === item.id; })) return;
  _espSelected.push(item);
  renderEspTags();
  var inp = document.getElementById('f_esp_input');
  if (inp) inp.value = '';
  var dd = document.getElementById('esp_dropdown');
  if (dd) dd.style.display = 'none';
}

document.addEventListener('DOMContentLoaded', function() {
  var input    = document.getElementById('f_esp_input');
  var dropdown = document.getElementById('esp_dropdown');
  if (!input || !dropdown) return;

  input.addEventListener('focus', function() { loadEspData(); });

  input.addEventListener('input', function() {
    var q = input.value.trim();
    if (!q) { dropdown.style.display = 'none'; return; }
    if (!_espData) { loadEspData().then(function(){ showEspResults(q); }); return; }
    showEspResults(q);
  });

  function showEspResults(q) {
    var results = espSearch(q);
    if (!results.length) { dropdown.style.display = 'none'; return; }
    dropdown.innerHTML = results.map(function(item){
      var badge = item.type === 'material'
        ? '<span class="esp-opt-badge esp-opt-badge-material">Material</span>'
        : '<span class="esp-opt-badge esp-opt-badge-cantera">Cantera</span>';
      return '<div class="esp-opt" data-id="'+item.id+'">' +
        badge +
        '<span class="esp-opt-label">'+_espEsc(item.label)+'</span>' +
        (item.sub ? '<span class="esp-opt-sub">'+_espEsc(item.sub)+'</span>' : '') +
      '</div>';
    }).join('');
    dropdown.style.display = 'block';
    dropdown.querySelectorAll('.esp-opt').forEach(function(opt){
      opt.addEventListener('mousedown', function(e){
        e.preventDefault();
        var found = (_espData||[]).find(function(i){ return i.id === opt.dataset.id; });
        if (found) espAdd(found);
      });
    });
  }

  input.addEventListener('blur', function(){
    setTimeout(function(){ dropdown.style.display = 'none'; }, 180);
  });
});
</script>

