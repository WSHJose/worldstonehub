  document.getElementById('s2-actor-name').textContent = actor.nombre;

  var roiEl = document.getElementById('s2-roi');
  if (actor.roi) { roiEl.textContent = '💡 ' + actor.roi; roiEl.style.display = 'block'; }
  else { roiEl.style.display = 'none'; }

  document.getElementById('compare-supply').style.display = isSupply ? 'block' : 'none';
  document.getElementById('compare-demand').style.display = isSupply ? 'none' : 'block';

  var plans = [];
  if (isSupply) {
    plans = [
      { key:'free',        tag:'Gratuito',    tagCls:'t-free', name:'Directorio',  price:0,            feats:FEATS.supply.free,        featured:false, popular:false },
      { key:'presencia',   tag:'Entrada',     tagCls:'t-base', name:'Presencia',   price:p.presencia,  feats:FEATS.supply.presencia,   featured:false, popular:false },
      { key:'profesional', tag:'Recomendado', tagCls:'t-pro',  name:'Profesional', price:p.profesional,feats:FEATS.supply.profesional, featured:true,  popular:true  },
      { key:'elite',       tag:'Premium',     tagCls:'t-elite',name:'Élite',       price:p.elite,      feats:FEATS.supply.elite,       featured:false, popular:false }
    ];
  } else {
    plans = [
      { key:'free',        tag:'Especificador',tagCls:'t-free', name:'Directorio',  price:0,            feats:FEATS.demand.free,        featured:false, popular:false },
      { key:'profesional', tag:'Recomendado',  tagCls:'t-pro',  name:'Profesional', price:p.profesional,feats:FEATS.demand.profesional, featured:true,  popular:true  }
    ];
    if (p.elite !== null) {
      plans.push({ key:'elite', tag:'Premium', tagCls:'t-elite', name:'Élite', price:p.elite, feats:FEATS.demand.elite, featured:false, popular:false });
    }
  }

  var saveBadge = document.getElementById('bill-save-badge');
  if (saveBadge) saveBadge.style.display = ST.billing === 'annual' ? 'inline-flex' : 'none';

  var isMonthly = ST.billing === 'monthly';

  var html = '';
  plans.forEach(function(plan) {
    var annualPrice   = plan.price;
    var monthlyPrice  = annualPrice > 0 ? Math.round(annualPrice / 10) : 0;
    var displayPrice  = isMonthly ? monthlyPrice : annualPrice;
    var dataPrice     = isMonthly ? monthlyPrice : annualPrice;

    var priceStr = displayPrice === 0
      ? '0<sup>€</sup>'
      : '<sup>€</sup>' + displayPrice.toLocaleString('es-ES');

    var billingStr;
    if (displayPrice === 0) {
      billingStr = isSupply ? 'Sin tarjeta · Sin compromiso' : 'Siempre gratuito para compradores';
    } else if (isMonthly) {
      billingStr = '€' + monthlyPrice + '/mes · facturación mensual';
    } else {
      var monthlyEquiv = monthlyPrice;
      billingStr = '€' + annualPrice.toLocaleString('es-ES') + '/año · equivale a €' + monthlyEquiv + '/mes';
    }

    var savingHtml = '';
    if (annualPrice > 0 && !isMonthly) {
      var saving = (monthlyPrice * 12) - annualPrice;
      if (saving > 0) savingHtml = '<div class="plan-saving">Ahorras €' + saving + ' vs mensual</div>';
    }

    var featsHtml = plan.feats.map(function(f){
      var off = f.charAt(0) === '—';
      var txt = off ? f.slice(1).trim() : f;
      return '<li' + (off ? ' class="off"' : '') + '><span class="fi">' + (off ? '·' : '›') + '</span>' + txt + '</li>';
    }).join('');

    html += '<div class="plan-card-wrap">' +
      '<label class="plan-card' + (plan.featured ? ' featured' : '') + '" data-plan="' + plan.key + '" data-price="' + dataPrice + '" data-annual="' + annualPrice + '">' +
      (plan.popular ? '<div class="plan-popular">Más popular</div>' : '') +
      '<div class="plan-check">✓</div>' +
      '<div class="plan-tag ' + plan.tagCls + '">' + plan.tag + '</div>' +
      '<div class="plan-name">' + plan.name + '</div>' +
      '<div class="plan-price-line"><div class="plan-price">' + priceStr + '</div>' + (displayPrice > 0 ? '<span class="plan-pm">' + (isMonthly ? '/mes' : '/año') + '</span>' : '') + '</div>' +
      '<div class="plan-billing">' + billingStr + '</div>' +
      savingHtml +
      '<div class="plan-divider"></div>' +
      '<ul class="plan-feats">' + featsHtml + '</ul>' +
      '</label></div>';
  });

  var container = document.getElementById('plans-dynamic');
  container.innerHTML = html;
  container.style.gridTemplateColumns = 'repeat(' + plans.length + ',1fr)';

  container.querySelectorAll('.plan-card').forEach(function(card) {
    card.addEventListener('click', function(e){ e.stopPropagation(); e.preventDefault(); selectPlan(card); });
  });

  ST.plan = null; ST.price = 0;
  document.getElementById('btn3').disabled = true;
  updateSidebarBadge();
}

// == 3. Selección de plan ==
function selectPlan(card) {
  document.querySelectorAll('#plans-dynamic .plan-card').forEach(function(c){ c.classList.remove('selected'); });
  card.classList.add('selected');
  ST.plan  = card.dataset.plan;
  ST.price = parseInt(card.dataset.price) || 0;
  document.getElementById('btn3').disabled = false;
  updateSidebarBadge();
  updateTierUI();
}

// == Sidebar badge ==
function updateSidebarBadge() {
  var b = document.getElementById('planBadge');
  if (!ST.actorKey) { b.classList.remove('show'); return; }
  b.classList.add('show');
  document.getElementById('spbName').textContent  = PLAN_NAMES[ST.plan] || '—';
  document.getElementById('spbPrice').textContent = ST.price > 0 ? '€' + ST.price.toLocaleString('es-ES') + '/año' : (ST.plan ? 'Gratuito' : '—');
  var actEl = document.getElementById('spbActors');
  actEl.style.display = 'block';
  actEl.textContent = ACTOR_NAMES[ST.actorKey] || ST.actorKey;
}

// == Tier-based UI ==
function updateTierUI() {
  var p = ST.plan;
  var isFree = p === 'free';
  var isPro  = p === 'profesional' || p === 'elite';

  var fn = document.getElementById('img_notice_free');
  var ff = document.getElementById('img_fields');
  if (fn) fn.style.display = isFree ? 'block' : 'none';
  if (ff) { ff.style.opacity = isFree ? '0.28' : '1'; ff.style.pointerEvents = isFree ? 'none' : 'auto'; }

  var uzp = document.getElementById('uz_projects');
  var uzpt = document.getElementById('uz_proj_text');
  var uzpl = document.getElementById('uz_proj_limit');
  if (uzp) {
    if (!isPro) {
      uzp.style.opacity = '0.4'; uzp.style.pointerEvents = 'none';
      if (uzpt) uzpt.innerHTML = '<span style="color:#8a8784">Galería de proyectos</span>';
      if (uzpl) uzpl.textContent = 'Disponible en plan Profesional o superior';
    } else {
      uzp.style.opacity = '1'; uzp.style.pointerEvents = 'auto';
      if (uzpt) uzpt.innerHTML = '<span>Galería de proyectos</span>';
      if (uzpl) uzpl.textContent = 'Ilimitado · JPG / PNG · 5 MB c/u';
    }
  }

  var uc = document.getElementById('uz_cat_limit');
  if (uc) uc.textContent = isPro ? 'Ilimitado · JPG / PNG · 5 MB c/u' : 'Hasta 10 imágenes · JPG / PNG · 5 MB c/u';
}

// == Navigate ==
function goTo(n) {
  document.querySelectorAll('.screen').forEach(function(s){ s.classList.remove('active'); });
  document.getElementById('s' + n).classList.add('active');
  ST.step = n;
  updateSteps(n);
  window.scrollTo({ top:0, behavior:'smooth' });
  if (n === 3) renderPlanCards();
  if (n === 4) fillReview();
}

function updateSteps(cur) {
  for (var i = 1; i <= 4; i++) {
    var r = document.getElementById('si' + i);
    if (!r) continue;
    r.classList.remove('active','done');
    if (i < cur)      r.classList.add('done');
    else if (i === cur) r.classList.add('active');
  }
}

// == Validate step 2 (form) ==
function validateS3() {
  var checks = [
    { id:'f_nombre', fn:function(v){ return v.trim().length > 0; } },
    { id:'f_nif',    fn:function(v){ return v.trim().length > 0; } },
    { id:'f_pais',   fn:function(v){ return v.trim().length > 0; } },
    { id:'f_ciudad', fn:function(v){ return v.trim().length > 0; } },
    { id:'f_email',  fn:function(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); } },
    { id:'f_tel',    fn:function(v){ return v.trim().length > 0; } },
    { id:'f_resp_nombre', fn:function(v){ return v.trim().length > 0; } },
    { id:'f_resp_cargo',  fn:function(v){ return v.trim().length > 0; } },
    { id:'f_resp_email',  fn:function(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); } },
    { id:'f_pass1',  fn:function(v){ return v.length >= 8; } },
    { id:'f_pass2',  fn:function(v){ return v === document.getElementById('f_pass1').value && v.length >= 8; } },
  ];

  var ok = true;
  var firstErr = null;
  checks.forEach(function(c) {
    var el = document.getElementById(c.id);
    if (!el) return;
    var field = el.closest('.field');
    var valid = c.fn(el.value);
    if (!valid) {
      ok = false; field.classList.add('err');
      if (!firstErr) firstErr = field;
    } else { field.classList.remove('err'); }
  });

  if (!ok && firstErr) {
    var top = firstErr.getBoundingClientRect().top + window.scrollY - 120;
    window.scrollTo({ top:top, behavior:'smooth' });
    return;
  }
  goTo(3);
}

// == Fill review ==
function fillReview() {
  function v(id) { var e=document.getElementById(id); return e ? (e.value.trim()||'—') : '—'; }

  document.getElementById('rv_plan').textContent   = PLAN_NAMES[ST.plan] || '-';
  document.getElementById('rv_actors').textContent = ST.actorKey ? (ACTORS_DATA[ST.actorKey] ? ACTORS_DATA[ST.actorKey].nombre : ST.actorKey) : '-';

  var priceEl = document.getElementById('rv_price');
  if (ST.price === 0) { priceEl.innerHTML = '<span style="font-size:28px;font-family:Cormorant Garamond,serif;color:#A67C52">Gratuito</span>'; }
  else { priceEl.innerHTML = '<sup>€</sup>' + ST.price.toLocaleString('es-ES'); }

  var periodoTxt = ST.price > 0
    ? (ST.billing === 'monthly'
        ? '€' + ST.price.toLocaleString('es-ES') + '/mes · facturación mensual'
        : '€' + ST.price.toLocaleString('es-ES') + '/año · facturación anual')
    : 'Sin coste';
  document.getElementById('rv_period').textContent = periodoTxt;
  document.getElementById('rv_nombre').textContent  = v('f_nombre');
  var paisSel = document.getElementById('f_pais');
  document.getElementById('rv_pais').textContent = paisSel && paisSel.selectedIndex > 0 ? paisSel.options[paisSel.selectedIndex].text : '—';
  document.getElementById('rv_ciudad').textContent  = v('f_ciudad');
  document.getElementById('rv_fundacion').textContent = v('f_fundacion') !== '—' ? v('f_fundacion') : 'No indicado';
  document.getElementById('rv_empleados').textContent = v('f_empleados') !== '—' ? v('f_empleados') : 'No indicado';
  document.getElementById('rv_email').textContent   = v('f_email');
  document.getElementById('rv_tel').textContent     = v('f_tel');
  document.getElementById('rv_resp').textContent    = v('f_resp_nombre');
  document.getElementById('rv_cargo').textContent   = v('f_resp_cargo');
  document.getElementById('rv_login').textContent   = v('f_resp_email');
}

// == Submit ==
function submitForm() {
  if (!document.getElementById('chk_terms').checked) {
    alert('Acepta los términos y condiciones para continuar.');
    return;
  }

  function v(id) { var e = document.getElementById(id); return e ? (e.value.trim() || '') : ''; }
  function paisNombre() {
    var sel = document.getElementById('f_pais');
    return (sel && sel.selectedIndex > 0) ? sel.options[sel.selectedIndex].text : '';
  }
  function makeSlug(str) {
    return str.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  var btn = document.querySelector('.btn-submit');
  btn.textContent = 'Registrando...';
  btn.disabled = true;

  var emailLogin    = v('f_resp_email');
  var password      = v('f_pass1');
  var nombreEmpresa = v('f_nombre');

  // 1) Crear usuario en Supabase Auth
  wshDB.auth.signUp({
    email: emailLogin,
    password: password,
    options: { data: { nombre: nombreEmpresa, nombre_empresa: nombreEmpresa, tier: ST.plan || 'free' } }
  })
  .then(function(authResult) {
    if (authResult.error) throw authResult.error;
    var userId = authResult.data.user ? authResult.data.user.id : null;

    var identities = (authResult.data.user && authResult.data.user.identities) ? authResult.data.user.identities : [];
    if (identities.length === 0) {
      throw new Error('User already registered');
    }

    // 2) Insertar proveedor
    var rawCerts = v('f_certs');
    var certsArr = rawCerts ? rawCerts.split(',').map(function(s){ return s.trim(); }).filter(Boolean) : null;
    var fullPayload = {
      user_id:            userId,
      nombre_empresa:     nombreEmpresa,
      nombre:             nombreEmpresa,
      nombre_comercial:   v('f_marca')      || null,
      nif:                v('f_nif'),
      slug:               makeSlug(nombreEmpresa) + '-' + Date.now().toString(36),
      descripcion:        v('f_desc')       || null,
      pais:               paisNombre(),
      ciudad:             v('f_ciudad'),
      ano_fundacion:      v('f_fundacion')  ? parseInt(v('f_fundacion')) : null,
      num_empleados:      v('f_empleados')  || null,
      mercados:           v('f_mercados')   || null,
      certificaciones:    certsArr,
      email:              v('f_email'),
      email_contacto:     v('f_email')      || null,
      telefono:           v('f_tel'),
      website:            v('f_web')        || null,
      linkedin:           v('f_linkedin')   || null,
      responsable_nombre: v('f_resp_nombre'),
      responsable_cargo:  v('f_resp_cargo'),
      tipo_empresa:       ST.actorKey ? (ACTOR_NAMES[ST.actorKey] || ST.actorKey) : null,
      tier:               ST.plan || 'free',
      activo:             ST.plan === 'free',
      plan_activo:        ST.plan === 'free',
      plan:               ST.plan || 'free',
      estado:             ST.plan === 'free' ? 'activo' : 'pendiente'
    };

    if (_espSelected && _espSelected.length) {
      var selMats  = _espSelected.filter(function(i){ return i.type === 'material'; });
      var selCants = _espSelected.filter(function(i){ return i.type === 'cantera'; });
      if (selMats.length)  fullPayload.materiales = selMats.map(function(i){ return i.id; });
      if (selCants.length) fullPayload.canteras   = selCants.map(function(i){ return i.id; });
    }

    if (ST.actorKey) fullPayload.sector = [ST.actorKey];

    var safePayload = {
      user_id:        userId,
      nombre_empresa: nombreEmpresa,
      nombre:         nombreEmpresa,
      slug:           fullPayload.slug,
      descripcion:    fullPayload.descripcion,
      pais:           fullPayload.pais,
      ciudad:         fullPayload.ciudad,
      email:          fullPayload.email,
      telefono:       fullPayload.telefono,
      website:        fullPayload.website,
      linkedin:       fullPayload.linkedin,
      plan:           fullPayload.plan,
      estado:         'pendiente'
    };

    return wshDB.from('proveedores').insert(fullPayload)
      .then(function(r) {
        if (r.error) {
          var msg = r.error.message || '';
          var isSchemaError = msg.includes('column') || msg.includes('schema') ||
                              msg.includes('violates') || msg.includes('does not exist');
          if (isSchemaError) {
            console.warn('WSH: fallo con payload completo, reintentando con payload mínimo.', msg);
            return wshDB.from('proveedores').insert(safePayload);
          }
          console.error('WSH insert error (fullPayload):', r.error);
        }
        return r;
      });
  })
  .then(function(insertResult) {
    if (insertResult.error) throw insertResult.error;

    // 3) Email de bienvenida (fire-and-forget)
    try {
      wshDB.functions.invoke('send-welcome', {
        body: {
          email:          v('f_email') || v('f_resp_email'),
          nombre_empresa: nombreEmpresa,
          plan:           ST.plan || 'free'
        }
      });
    } catch(e) { console.warn('WSH send-welcome omitido:', e); }

    // 4) Redirigir a Stripe Checkout o gracias.html
    if (ST.plan === 'free') {
      window.location.href = '/gracias.html';
    } else {
      var emailVal = document.getElementById('f_email');
      var emailStr = (emailVal && emailVal.value.trim()) ? emailVal.value.trim() : v('f_resp_email');
      btn.textContent = 'Redirigiendo a Stripe…';
      fetch(CHECKOUT_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          actor:          ST.actorKey,
          plan:           ST.plan,
          billing:        ST.billing || 'annual',
          email:          emailStr,
          nombre_empresa: nombreEmpresa
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          console.error('Checkout error:', data);
          alert('Error al iniciar el pago. Por favor escríbenos a hello@worldstonehub.com\n\n' + (data.error || ''));
          btn.textContent = 'Enviar solicitud de alta →';
          btn.disabled = false;
        }
      })
      .catch(function(err) {
        console.error('Checkout fetch error:', err);
        alert('Error de conexión al iniciar el pago. Inténtalo de nuevo.');
        btn.textContent = 'Enviar solicitud de alta →';
        btn.disabled = false;
      });
    }
  })
  .catch(function(err) {
    btn.textContent = 'Enviar solicitud de alta →';
    btn.disabled = false;
    var msg = err.message || 'Error desconocido';
    console.error('WSH submit error completo:', JSON.stringify(err), err);
    if (msg.includes('already registered') || msg.includes('User already registered')) {
      alert('Este email ya está registrado.\nSi ya tienes cuenta, accede desde "Iniciar sesión".\nSi crees que es un error, escríbenos a hello@worldstonehub.com');
    } else {
      alert('Error al registrar.\n\nDetalle técnico: ' + msg + '\n\nCopia este mensaje y escríbenos a hello@worldstonehub.com para que lo resolvamos.');
    }
  });
}

// == Live validation ==
document.querySelectorAll('.field input, .field select, .field textarea').forEach(function(el) {
  el.addEventListener('input', function() {
    var f = this.closest('.field');
    if (f && f.classList.contains('err')) f.classList.remove('err');
  });
});

// == Init ==
updateTierUI();
</script>

