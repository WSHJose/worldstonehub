---
import Page from '../layouts/Page.astro';
---

<Page title="Panel de Proveedor — World Stone Hub" noIndex={true}>
  <style slot="head">
    .panel-layout {
      margin-top: 64px;
      display: grid;
      grid-template-columns: 250px 1fr;
      min-height: calc(100vh - 64px);
    }

    .sidebar {
      background: var(--ink);
      color: #fff;
      padding: 30px 20px;
      position: sticky;
      top: 64px;
      height: calc(100vh - 64px);
      overflow-y: auto;
    }
    .sidebar-title {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 20px;
    }
    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .sidebar-nav a {
      padding: 12px 16px;
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      border-radius: 4px;
      transition: all 0.2s;
    }
    .sidebar-nav a:hover,
    .sidebar-nav a.active {
      background: rgba(166, 124, 82, 0.2);
      color: var(--gold);
    }

    .main {
      padding: 40px;
      background: var(--bg);
    }
    .main-header {
      margin-bottom: 40px;
    }
    .main-title {
      font-family: var(--font-disp);
      font-size: 2rem;
      font-weight: 400;
      margin-bottom: 8px;
    }
    .main-subtitle {
      color: var(--ink-muted);
    }

    .section {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 32px;
      border-radius: 8px;
      margin-bottom: 24px;
    }
    .section-title {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .form-group {
      margin-bottom: 16px;
    }
    .form-group label {
      display: block;
      font-weight: 500;
      margin-bottom: 6px;
      font-size: 0.9rem;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 10px;
      border: 1px solid var(--border);
      border-radius: 4px;
      font-family: inherit;
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--gold);
      outline: none;
    }

    .btn {
      display: inline-block;
      padding: 12px 28px;
      background: var(--gold);
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 600;
    }
    .btn:hover {
      opacity: 0.9;
    }

    @media (max-width: 900px) {
      .panel-layout {
        grid-template-columns: 1fr;
      }
      .sidebar {
        height: auto;
        position: static;
      }
    }
  </style>

  <div class="panel-layout">
    <div class="sidebar">
      <div class="sidebar-title">Panel</div>
      <nav class="sidebar-nav">
        <a href="#" class="active">Mi perfil</a>
        <a href="#materiales">Mis materiales</a>
        <a href="#facturacion">Facturación</a>
        <a href="#contacto">Contacto</a>
        <a href="#" onclick="handleLogout();return false">Salir</a>
      </nav>
    </div>

    <div class="main">
      <div class="main-header">
        <h1 class="main-title">Panel de Proveedor</h1>
        <p class="main-subtitle" id="userEmail">Cargando...</p>
      </div>

      <div class="section">
        <h2 class="section-title">Información de empresa</h2>
        <div class="form-group">
          <label>Nombre de empresa</label>
          <input type="text" placeholder="Ej: Tu Empresa S.L." id="empresa" />
        </div>
        <div class="form-group">
          <label>Descripción</label>
          <textarea placeholder="Describe tu empresa..."></textarea>
        </div>
        <button class="btn">Guardar cambios</button>
      </div>

      <div class="section">
        <h2 class="section-title">Plan actual</h2>
        <p id="planInfo">Elite Fundador - 890 €/año (Precio bloqueado)</p>
      </div>
    </div>
  </div>

  <script slot="scripts" is:inline>
    const SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
    const SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
    const db = supabase.createClient(SB_URL, SB_KEY);

    db.auth.getSession().then((r) => {
      const session = r.data?.session;
      if (!session) {
        window.location.href = '/login';
        return;
      }
      document.getElementById('userEmail').textContent = session.user.email;
    });

    window.handleLogout = function () {
      db.auth.signOut().then(() => {
        window.location.href = '/';
      });
    };
  </script>
</Page>
