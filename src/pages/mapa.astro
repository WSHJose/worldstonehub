---
import Page from '../layouts/Page.astro';
---

<Page title="Mapa Interactivo — World Stone Hub">
  <style slot="head">
    .map-container {
      margin-top: 64px;
      height: calc(100vh - 64px);
      display: flex;
      position: relative;
    }

    #sidebar {
      width: 280px;
      background: rgba(14, 11, 8, 0.97);
      border-right: 1px solid rgba(201, 168, 76, 0.1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      z-index: 800;
      color: #d4cfc8;
    }
    .sb-header {
      padding: 18px 20px 14px;
      border-bottom: 1px solid rgba(201, 168, 76, 0.1);
      flex-shrink: 0;
    }
    .sb-title {
      font-family: var(--font-disp);
      font-size: 22px;
      font-weight: 300;
      color: #e8e3dc;
      line-height: 1.1;
    }
    .sb-title em {
      color: #c9a84c;
      font-style: italic;
    }
    .sb-search {
      padding: 10px 16px 8px;
      border-bottom: 1px solid rgba(201, 168, 76, 0.1);
      flex-shrink: 0;
    }
    #searchInput {
      width: 100%;
      padding: 7px 12px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(201, 168, 76, 0.15);
      color: #d4cfc8;
      border-radius: 2px;
      font-size: 12px;
    }
    #searchInput:focus {
      border-color: rgba(201, 168, 76, 0.4);
      outline: none;
    }
    .sb-body {
      flex: 1;
      overflow-y: auto;
    }
    .sb-footer {
      padding: 12px 16px;
      border-top: 1px solid rgba(201, 168, 76, 0.1);
      flex-shrink: 0;
      font-size: 12px;
    }

    #map-wrap {
      flex: 1;
      position: relative;
    }
    #map {
      position: absolute;
      inset: 0;
    }

    @media (max-width: 960px) {
      #sidebar {
        display: none;
      }
    }
  </style>

  <div class="map-container">
    <div id="sidebar">
      <div class="sb-header">
        <div
          style="font-size:7px;letter-spacing:2px;text-transform:uppercase;color:var(--dm-gold);margin-bottom:8px"
        >
          Explorar
        </div>
        <h1 class="sb-title">Piedras del <em>Mundo</em></h1>
      </div>

      <div class="sb-search">
        <input type="text" id="searchInput" placeholder="Buscar material..." />
      </div>

      <div class="sb-body">
        <div style="padding:20px;color:rgba(212,207,200,0.5);font-size:13px">
          Selecciona un filtro o busca un material
        </div>
      </div>

      <div class="sb-footer">22.000+ materiales · 138 países</div>
    </div>

    <div id="map-wrap">
      <div
        id="map"
        style="background:linear-gradient(135deg,#1a1917 0%,#2a2622 100%);display:flex;align-items:center;justify-content:center"
      >
        <div style="text-align:center;color:#fff">
          <p style="font-size:18px;margin-bottom:12px">🗺️</p>
          <p>Mapa interactivo de piedra natural</p>
          <p style="font-size:12px;color:rgba(255,255,255,0.5);margin-top:8px">
            Cargando MapBox...
          </p>
        </div>
      </div>
    </div>
  </div>

  <script src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet" />

  <script slot="scripts" is:inline>
    const SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
    const SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
    const db = supabase.createClient(SB_URL, SB_KEY);

    // MapBox initialization placeholder
    // Nota: Requiere API key de MapBox para funcionar completamente
    document.getElementById('searchInput').addEventListener('input', function (e) {
      console.log('Search:', e.target.value);
    });
  </script>
</Page>
