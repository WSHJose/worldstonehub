  <script slot="scripts" is:inline>
    const SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
    const SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
    const db = supabase.createClient(SB_URL, SB_KEY);

    let _contribEstado = 'pendiente';

    // Auth check
    document.addEventListener('DOMContentLoaded', async () => {
      const {
        data: { session },
      } = await db.auth.getSession();
      if (!session) {
        document.getElementById('panel').classList.add('hidden');
      } else {
        document.getElementById('login-overlay').classList.add('hidden');
        document.getElementById('panel').classList.remove('hidden');
        document.getElementById('sidebar-email').textContent = session.user.email;
        cargarDashboard();
      }
    });

    function handleLogin() {
      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-pass').value;
      const errorEl = document.getElementById('login-error');

      if (!email || !password) {
        errorEl.textContent = 'Por favor completa todos los campos';
        return;
      }

      db.auth.signInWithPassword({ email, password }).then((r) => {
        if (r.error) {
          errorEl.textContent = r.error.message;
        } else {
          window.location.reload();
        }
      });
    }

    function handleLogout() {
      db.auth.signOut().then(() => {
        window.location.href = '/';
      });
    }

    function navTo(section) {
      document.querySelectorAll('.section').forEach((s) => s.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach((n) => n.classList.remove('active'));

      document.getElementById('section-' + section).classList.add('active');
      document.querySelector(`[data-section="${section}"]`).classList.add('active');

      if (section === 'dashboard') cargarDashboard();
      if (section === 'solicitudes') cargarSolicitudes();
      if (section === 'fundadores') cargarFundadores();
      if (section === 'proveedores') cargarProveedores();
      if (section === 'materiales') cargarMateriales();
      if (section === 'contribuciones') cargarContribuciones('pendiente');
      if (section === 'anuncios') cargarAnuncios();
      if (section === 'analiticas') cargarAnaliticas();
    }

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('hidden');
    }

    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('open');
      document.getElementById('sidebar-overlay').classList.add('hidden');
    }

    // Placeholder functions
    async function cargarDashboard() {
      console.log('Dashboard');
    }
