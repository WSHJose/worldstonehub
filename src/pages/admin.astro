    async function selectAdTab(tab) {
      document.querySelectorAll('.ad-tab').forEach((t) => t.classList.remove('active'));
      document.querySelectorAll('.ad-pane').forEach((p) => p.classList.remove('active'));
      document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
      document.getElementById('ad-pane-' + tab).classList.add('active');
