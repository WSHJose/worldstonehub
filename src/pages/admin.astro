      console.log('Filtros proveedores');
    }
    async function cargarMateriales() {
      console.log('Materiales');
    }
    async function toggleMatVista(view) {
      document.getElementById('mat-btn-lista').classList.toggle('active', view === 'lista');
      document.getElementById('mat-btn-imagenes').classList.toggle('active', view === 'imagenes');
      document.getElementById('mat-table-wrap').style.display = view === 'lista' ? 'block' : 'none';
      document.getElementById('mat-grid-wrap').style.display =
        view === 'imagenes' ? 'block' : 'none';
    }
    async function abrirModalMaterial(id) {
      console.log('Modal material', id);
    }
    async function cargarContribuciones(estado) {
      _contribEstado = estado;
      console.log('Contribuciones', estado);
    }
    async function contribFiltro(estado) {
      document.querySelectorAll('.contrib-tab').forEach((t) => t.classList.remove('active'));
      document.querySelector(`[data-estado="${estado}"]`).classList.add('active');
      cargarContribuciones(estado);
    }
    async function cerrarContribDetail() {
      document.getElementById('contrib-detail-panel').style.display = 'none';
    }
    async function aceptarContrib() {
