---
import Page from '../layouts/Page.astro';
---

<Page title="Admin — World Stone Hub" noIndex={true}>
  <style slot="head">
    :root {
      --bg: #f8f7f5;
      --bg-soft: #f0efed;
      --bg-white: #ffffff;
      --border: #e2e0dc;
      --border-mid: #c8c5bf;
      --ink: #1a1917;
      --ink-mid: #4a4845;
      --ink-muted: #8a8784;
      --gold: #a67c52;
      --gold-lt: #f5efea;
      --sand: #c9b99a;
      --sand-lt: rgba(201, 185, 154, 0.15);
      --muted: #6b5b4e;
      --muted-lt: #f0efed;
      --sidebar-w: 240px;
      --font-disp: 'Cormorant Garamond', serif;
      --font-body: 'Instrument Sans', sans-serif;
    }
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html,
    body {
      height: 100%;
      font-family: var(--font-body);
      color: var(--ink);
      background: var(--bg);
    }
    a {
      color: inherit;
      text-decoration: none;
    }
    button {
      cursor: pointer;
      font-family: var(--font-body);
    }
    input,
    select,
    textarea {
      font-family: var(--font-body);
    }

    /* ── LOGIN OVERLAY ── */
    #login-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #login-overlay.hidden {
      display: none;
    }
    .login-box {
      width: 400px;
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 48px 44px;
    }
    .login-logo {
      font-family: var(--font-body);
      font-size: 18px;
      letter-spacing: 6px;
      text-transform: uppercase;
      color: var(--ink);
      margin-bottom: 4px;
    }
    .login-logo-hub {
      color: var(--gold);
      font-style: italic;
    }
    .login-sub {
      font-size: 9px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 36px;
    }
    .login-title {
      font-family: var(--font-disp);
      font-size: 28px;
      font-weight: 300;
      margin-bottom: 28px;
      color: var(--ink);
    }
    .login-label {
      display: block;
      font-size: 10px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 6px;
    }
    .login-input {
      width: 100%;
      padding: 11px 14px;
      font-size: 14px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink);
      outline: none;
      margin-bottom: 18px;
      transition: border-color 0.2s;
    }
    .login-input:focus {
      border-color: var(--gold);
    }
    .login-btn {
      width: 100%;
      padding: 13px;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      font-weight: 600;
      background: var(--gold);
      color: #fff;
      border: none;
      transition: background 0.2s;
      margin-top: 4px;
    }
    .login-btn:hover {
      background: #8a6030;
    }
    .login-error {
      font-size: 12px;
      color: var(--muted);
      margin-top: 14px;
      min-height: 18px;
      letter-spacing: 0.3px;
    }

    /* ── LAYOUT ── */
    #panel {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }
    #panel.hidden {
      display: none;
    }

    /* ── SIDEBAR ── */
    #sidebar {
      width: var(--sidebar-w);
      min-width: var(--sidebar-w);
      background: var(--ink);
      display: flex;
      flex-direction: column;
      height: 100vh;
      position: fixed;
      left: 0;
      top: 0;
      z-index: 100;
      transition: transform 0.3s;
    }
    .sidebar-logo {
      padding: 28px 24px 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .sidebar-logo-text {
      font-family: var(--font-body);
      font-size: 16px;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: #fff;
    }
    .sidebar-logo-hub {
      color: var(--gold);
      font-style: italic;
    }
    .sidebar-logo-sub {
      font-size: 8px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.35);
      margin-top: 3px;
      display: block;
    }
    .sidebar-nav {
      flex: 1;
      padding: 16px 0;
      overflow-y: auto;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 11px 24px;
      font-size: 11px;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.55);
      cursor: pointer;
      border-left: 2px solid transparent;
      transition: all 0.2s;
      position: relative;
    }
    .nav-item:hover {
      color: rgba(255, 255, 255, 0.85);
      background: rgba(255, 255, 255, 0.04);
    }
    .nav-item.active {
      color: #fff;
      background: rgba(166, 124, 82, 0.12);
      border-left-color: var(--gold);
    }
    .nav-item svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      opacity: 0.8;
    }
    .nav-item.active svg {
      opacity: 1;
    }
    .nav-badge {
      margin-left: auto;
      background: var(--gold);
      color: #fff;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0;
      padding: 2px 6px;
      border-radius: 2px;
      min-width: 18px;
      text-align: center;
    }
    .sidebar-bottom {
      padding: 16px 24px 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }
    .sidebar-user-email {
      font-size: 10px;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 0.5px;
      margin-bottom: 10px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .sidebar-logout {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.4);
      background: none;
      border: none;
      padding: 0;
      transition: color 0.2s;
      display: block;
    }
    .sidebar-logout:hover {
      color: rgba(255, 255, 255, 0.8);
    }

    /* ── MAIN ── */
    #main {
      margin-left: var(--sidebar-w);
      flex: 1;
      overflow-y: auto;
      height: 100vh;
      background: var(--bg);
    }
    .main-header {
      padding: 28px 40px 20px;
      border-bottom: 1px solid var(--border);
      background: var(--bg-white);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .main-title {
      font-family: var(--font-disp);
      font-size: 26px;
      font-weight: 300;
      letter-spacing: 1px;
    }
    .main-content {
      padding: 32px 40px;
    }

    /* ── SECTIONS ── */
    .section {
      display: none;
    }
    .section.active {
      display: block;
    }

    /* ── KPI CARDS ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 32px;
    }
    .kpi-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 24px;
    }
    .kpi-label {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 10px;
    }
    .kpi-value {
      font-family: var(--font-disp);
      font-size: 42px;
      font-weight: 300;
      line-height: 1;
      color: var(--ink);
    }
    .kpi-sub {
      font-size: 11px;
      color: var(--ink-muted);
      margin-top: 6px;
    }

    /* ── TIER PILLS ROW ── */
    .tier-row {
      display: flex;
      gap: 12px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }
    .tier-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      font-size: 11px;
      letter-spacing: 1px;
    }
    .tier-pill-count {
      font-family: var(--font-disp);
      font-size: 22px;
      font-weight: 300;
      line-height: 1;
    }

    /* ── CHART SECTION ── */
    .chart-box {
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 24px;
      margin-bottom: 32px;
    }
    .chart-title {
      font-size: 10px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 20px;
    }
    .chart-box svg {
      width: 100%;
      display: block;
    }

    /* ── TABLE ── */
    .table-box {
      background: var(--bg-white);
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .table-toolbar {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }
    .toolbar-search {
      flex: 1;
      min-width: 180px;
      padding: 9px 13px;
      font-size: 13px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
    }
    .toolbar-search:focus {
      border-color: var(--gold);
    }
    .toolbar-select {
      padding: 9px 13px;
      font-size: 12px;
      letter-spacing: 0.5px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink);
      outline: none;
      cursor: pointer;
      min-width: 120px;
    }
    .toolbar-btn {
      padding: 9px 18px;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 600;
      background: var(--ink);
      color: #fff;
      border: none;
      transition: background 0.2s;
    }
    .toolbar-btn:hover {
      background: var(--gold);
    }
    .toolbar-btn.gold {
      background: var(--gold);
    }
    .toolbar-btn.gold:hover {
      background: #8a6030;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }
    thead tr {
      background: var(--bg-soft);
    }
    thead th {
      padding: 10px 16px;
      text-align: left;
      font-size: 8px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-muted);
      font-weight: 600;
      white-space: nowrap;
      border-bottom: 1px solid var(--border);
    }
    tbody td {
      padding: 12px 16px;
      font-size: 13px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    tbody tr:hover {
      background: var(--bg-soft);
    }
    tbody tr:last-child td {
      border-bottom: none;
    }

    /* ── BADGES ── */
    .badge {
      display: inline-block;
      padding: 3px 10px;
      font-size: 9px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      font-weight: 600;
      border-radius: 2px;
    }
    .badge-activo {
      background: var(--gold-lt);
      color: var(--gold);
    }
    .badge-pendiente {
      background: var(--sand-lt);
      color: #9c8571;
      border: 1px solid rgba(201, 185, 154, 0.35);
    }
    .badge-rechazado {
      background: var(--muted-lt);
      color: var(--muted);
    }
    .badge-free {
      background: #f0efed;
      color: var(--ink-muted);
    }
    .badge-presencia {
      background: var(--gold-lt);
      color: var(--gold);
    }
    .badge-profesional {
      background: var(--gold-lt);
      color: var(--gold);
      border: 1px solid rgba(166, 124, 82, 0.3);
    }
    .badge-elite {
      background: var(--ink);
      color: #fff;
    }

    /* ── TOGGLE ── */
    .toggle-btn {
      width: 44px;
      height: 22px;
      border-radius: 2px;
      position: relative;
      border: none;
      transition: background 0.2s;
      outline: none;
    }
    .toggle-btn.on {
      background: var(--gold);
    }
    .toggle-btn.off {
      background: #c8c5bf;
    }
    .toggle-dot {
      position: absolute;
      top: 3px;
      width: 16px;
      height: 16px;
      background: #fff;
      transition: left 0.2s;
      border-radius: 1px;
    }
    .toggle-btn.on .toggle-dot {
      left: 25px;
    }
    .toggle-btn.off .toggle-dot {
      left: 3px;
    }

    /* ── PAGINATION ── */
    .pagination {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 16px 20px;
      border-top: 1px solid var(--border);
      justify-content: flex-end;
    }
    .page-btn {
      padding: 6px 11px;
      font-size: 11px;
      letter-spacing: 0.5px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink);
      transition: all 0.2s;
      min-width: 32px;
      text-align: center;
    }
    .page-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .page-btn.active {
      background: var(--ink);
      color: #fff;
      border-color: var(--ink);
    }
    .page-btn:disabled {
      opacity: 0.4;
      cursor: default;
    }

    /* ── CARDS (solicitudes) ── */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }
    .sol-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 24px;
    }
    .sol-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 14px;
    }
    .sol-name {
      font-family: var(--font-disp);
      font-size: 20px;
      font-weight: 400;
    }
    .sol-meta {
      font-size: 12px;
      color: var(--ink-muted);
      margin-bottom: 4px;
    }
    .sol-actions {
      display: flex;
      gap: 8px;
      margin-top: 16px;
      flex-wrap: wrap;
    }
    .sol-btn {
      padding: 8px 14px;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 600;
      border: none;
      transition: background 0.2s;
    }
    .sol-btn-aprobar {
      background: var(--gold-lt);
      color: var(--gold);
      border: 1px solid rgba(166, 124, 82, 0.25);
    }
    .sol-btn-aprobar:hover {
      background: var(--gold);
      color: #fff;
    }
    .sol-btn-rechazar {
      background: var(--muted-lt);
      color: var(--muted);
      border: 1px solid rgba(107, 91, 78, 0.2);
    }
    .sol-btn-rechazar:hover {
      background: var(--muted);
      color: #fff;
    }
    .sol-btn-detalle {
      background: var(--bg-soft);
      color: var(--ink);
    }
    .sol-btn-detalle:hover {
      background: var(--border);
    }

    /* ── MODAL ── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(26, 25, 23, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-overlay.hidden {
      display: none;
    }
    .modal-box {
      background: var(--bg-white);
      border: 1px solid var(--border);
      width: 100%;
      max-width: 640px;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .modal-box.wide {
      max-width: 760px;
    }
    .modal-head {
      padding: 22px 28px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .modal-title {
      font-family: var(--font-disp);
      font-size: 22px;
      font-weight: 300;
    }
    .modal-close {
      background: none;
      border: none;
      font-size: 20px;
      color: var(--ink-muted);
      line-height: 1;
      padding: 4px;
      transition: color 0.2s;
    }
    .modal-close:hover {
      color: var(--ink);
    }
    .modal-body {
      padding: 28px;
      overflow-y: auto;
      flex: 1;
    }

    /* ── DETAIL GRID ── */
    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px 24px;
    }
    .detail-field label {
      display: block;
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 4px;
    }
    .detail-field span {
      font-size: 13px;
      color: var(--ink);
      word-break: break-word;
    }
    .detail-field.full {
      grid-column: 1/-1;
    }

    /* ── FORM ── */
    .form-group {
      margin-bottom: 18px;
    }
    .form-label {
      display: block;
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 6px;
    }
    .form-input,
    .form-select,
    .form-textarea {
      width: 100%;
      padding: 10px 13px;
      font-size: 13px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
    }
    .form-input:focus,
    .form-select:focus,
    .form-textarea:focus {
      border-color: var(--gold);
    }
    .form-textarea {
      resize: vertical;
      min-height: 80px;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    /* ── ANUNCIOS ── */
    .ad-tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
    }
    .ad-tab {
      padding: 10px 20px;
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--ink-muted);
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: -1px;
    }
    .ad-tab:hover {
      color: var(--ink);
    }
    .ad-tab.active {
      color: var(--gold);
      border-bottom-color: var(--gold);
    }
    .ad-pane {
      display: none;
    }
    .ad-pane.active {
      display: block;
    }
    .ad-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
    .ad-stat {
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 20px 22px;
    }
    .ad-stat.gold {
      border-color: rgba(166, 124, 82, 0.3);
      background: var(--gold-lt);
    }
    .ad-stat-val {
      font-family: var(--font-disp);
      font-size: 36px;
      font-weight: 300;
      line-height: 1;
      color: var(--ink);
    }
    .ad-stat.gold .ad-stat-val {
      color: var(--gold);
    }
    .ad-stat-lbl {
      font-size: 8px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-top: 6px;
    }
    .ad-espacios-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }
    .ad-espacio-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 18px 20px;
      position: relative;
    }
    .ad-espacio-card.ocupado {
      border-color: rgba(166, 124, 82, 0.3);
    }
    .ad-espacio-card.libre {
      border-style: dashed;
    }
    .ad-espacio-codigo {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
    }
    .ad-espacio-pagina {
      font-size: 11px;
      color: var(--ink-muted);
      margin-bottom: 4px;
    }
    .ad-espacio-pos {
      font-size: 12px;
      color: var(--ink-mid);
      margin-bottom: 10px;
    }
    .ad-espacio-precio {
      font-family: var(--font-disp);
      font-size: 20px;
      color: var(--ink);
    }
    .ad-espacio-anunciante {
      font-size: 10px;
      font-weight: 600;
      color: var(--gold);
      margin-bottom: 4px;
    }
    .ad-espacio-actions {
      display: flex;
      gap: 6px;
      margin-top: 12px;
    }
    .ad-espacio-dot {
      position: absolute;
      top: 14px;
      right: 16px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }
    .ad-espacio-dot.ocupado {
      background: var(--gold);
    }
    .ad-espacio-dot.libre {
      background: var(--border-mid);
    }
    .ad-form-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 28px;
      align-items: start;
    }
    .ad-form-side {
    }
    .ad-preview-box {
      border: 1px solid var(--border);
      background: var(--bg-soft);
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .btn-danger {
      padding: 10px 20px;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: var(--muted-lt);
      color: var(--muted);
      border: 1px solid rgba(107, 91, 78, 0.2);
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-danger:hover {
      background: var(--muted);
      color: #fff;
    }

    /* ── UPLOAD IMAGEN ── */
    .img-upload-area {
      border: 1px dashed var(--border-mid);
      padding: 16px;
      background: var(--bg-soft);
      display: flex;
      align-items: center;
      gap: 16px;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .img-upload-area:hover {
      border-color: var(--gold);
    }
    .img-preview {
      width: 80px;
      height: 56px;
      object-fit: cover;
      display: block;
      border: 1px solid var(--border);
      flex-shrink: 0;
      background: var(--bg);
    }
    .img-preview-placeholder {
      width: 80px;
      height: 56px;
      flex-shrink: 0;
      background: var(--bg);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink-muted);
      font-size: 20px;
    }
    .img-upload-info {
      flex: 1;
      min-width: 0;
    }
    .img-upload-name {
      font-size: 11px;
      color: var(--ink-mid);
      margin-bottom: 4px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .img-upload-hint {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-muted);
    }
    .img-upload-btn {
      padding: 7px 14px;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: var(--bg-white);
      border: 1px solid var(--border);
      color: var(--ink-mid);
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .img-upload-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .img-upload-progress {
      font-size: 10px;
      color: var(--gold);
      margin-top: 6px;
      display: none;
    }
    .img-url-current {
      font-size: 9px;
      color: var(--ink-muted);
      margin-top: 6px;
      word-break: break-all;
    }
    .modal-footer {
      padding: 18px 28px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      flex-shrink: 0;
    }
    .btn-cancel {
      padding: 10px 20px;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 600;
      background: var(--bg-soft);
      color: var(--ink-mid);
      border: none;
      transition: background 0.2s;
    }
    .btn-cancel:hover {
      background: var(--border);
    }
    .btn-save {
      padding: 10px 22px;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 600;
      background: var(--gold);
      color: #fff;
      border: none;
      transition: background 0.2s;
    }
    .btn-save:hover {
      background: #8a6030;
    }

    /* ── ANALYTICS ── */
    .analytics-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 24px;
    }
    .top-list-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      font-size: 12px;
    }
    .top-list-item:last-child {
      border-bottom: none;
    }
    .top-bar-bg {
      flex: 1;
      height: 6px;
      background: var(--bg-soft);
    }
    .top-bar-fill {
      height: 6px;
      background: var(--gold);
      transition: width 0.4s;
    }
    .top-bar-val {
      font-size: 11px;
      color: var(--ink-muted);
      min-width: 30px;
      text-align: right;
    }

    /* ── SETTINGS ── */
    .settings-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      padding: 28px;
      max-width: 480px;
    }
    .settings-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .settings-row:last-child {
      border-bottom: none;
    }
    .settings-key {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-muted);
    }
    .settings-val {
      color: var(--ink);
      font-size: 12px;
    }

    /* ── TOASTS ── */
    #toast-container {
      position: fixed;
      top: 24px;
      right: 24px;
      z-index: 9000;
      display: flex;
      flex-direction: column;
      gap: 8px;
      pointer-events: none;
    }
    .toast {
      padding: 13px 18px;
      font-size: 12px;
      letter-spacing: 0.3px;
      max-width: 320px;
      pointer-events: auto;
      transform: translateX(120%);
      transition: transform 0.3s;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .toast.show {
      transform: translateX(0);
    }
    .toast-success {
      background: #1a3a2a;
      color: #a8e6c0;
    }
    .toast-error {
      background: #3a1a1a;
      color: #f5b8b8;
    }
    .toast-info {
      background: var(--ink);
      color: rgba(255, 255, 255, 0.85);
    }

    /* ── SKELETON ── */
    .skeleton {
      background: linear-gradient(90deg, var(--bg-soft) 25%, var(--border) 50%, var(--bg-soft) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 1px;
    }
    @keyframes shimmer {
      0% {
        background-position: 200% 0;
      }
      100% {
        background-position: -200% 0;
      }
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 64px 32px;
      color: var(--ink-muted);
    }
    .empty-state-icon {
      font-size: 36px;
      margin-bottom: 14px;
      opacity: 0.4;
    }
    .empty-state-title {
      font-family: var(--font-disp);
      font-size: 22px;
      font-weight: 300;
      margin-bottom: 8px;
      color: var(--ink);
    }
    .empty-state-sub {
      font-size: 13px;
      color: var(--ink-muted);
    }

    /* ── MATERIALES IMAGE GRID ── */
    .mat-view-toggle {
      display: flex;
      gap: 6px;
      margin-left: auto;
    }
    .mat-view-btn {
      padding: 6px 14px;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 600;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink-muted);
      cursor: pointer;
      transition: all 0.15s;
    }
    .mat-view-btn.active {
      background: var(--gold);
      border-color: var(--gold);
      color: #fff;
    }
    .mat-img-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 16px;
      padding: 24px 0;
    }
    .mat-img-card {
      position: relative;
      border: 1px solid var(--border);
      background: var(--bg-white);
      overflow: hidden;
      cursor: pointer;
      transition:
        box-shadow 0.2s,
        border-color 0.2s;
    }
    .mat-img-card:hover {
      border-color: var(--gold);
      box-shadow: 0 4px 16px rgba(166, 124, 82, 0.15);
    }
    .mat-img-card input[type='file'] {
      display: none;
    }
    .mat-img-thumb {
      width: 100%;
      height: 120px;
      object-fit: cover;
      display: block;
      background: var(--bg-soft);
    }
    .mat-img-empty {
      width: 100%;
      height: 120px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      background: var(--bg-soft);
    }
    .mat-img-empty svg {
      opacity: 0.25;
    }
    .mat-img-empty span {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-muted);
    }
    .mat-img-info {
      padding: 10px 12px;
      border-top: 1px solid var(--border);
    }
    .mat-img-name {
      font-size: 12px;
      font-weight: 500;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .mat-img-cat {
      font-size: 10px;
      color: var(--ink-muted);
      letter-spacing: 0.5px;
      margin-top: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .mat-img-overlay {
      position: absolute;
      inset: 0;
      background: rgba(26, 25, 23, 0.55);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .mat-img-card:hover .mat-img-overlay {
      opacity: 1;
    }
    .mat-img-overlay-lbl {
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #fff;
      font-weight: 600;
    }
    .mat-img-uploading {
      position: absolute;
      inset: 0;
      background: rgba(26, 25, 23, 0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 8px;
    }
    .mat-img-uploading-txt {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #fff;
    }
    .mat-img-spin {
      width: 22px;
      height: 22px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    .mat-img-ok {
      position: absolute;
      top: 6px;
      right: 6px;
      background: var(--gold);
      color: #fff;
      font-size: 9px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 3px 7px;
      opacity: 0;
      transition: opacity 0.4s;
    }
    .mat-img-ok.show {
      opacity: 1;
    }

    /* ── INLINE TIER SELECT ── */
    .tier-select {
      padding: 5px 8px;
      font-size: 11px;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink);
      outline: none;
      cursor: pointer;
    }

    /* ── ROW ACTION BTNS ── */
    .act-btn {
      padding: 5px 10px;
      font-size: 9px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      font-weight: 600;
      border: 1px solid var(--border);
      background: var(--bg-white);
      color: var(--ink-mid);
      transition: all 0.15s;
      margin-right: 4px;
    }
    .act-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .act-btn.danger:hover {
      border-color: var(--red);
      color: var(--red);
    }

    /* ── HAMBURGER ── */
    #hamburger {
      display: none;
      position: fixed;
      top: 14px;
      left: 14px;
      z-index: 200;
      background: var(--ink);
      border: none;
      color: #fff;
      padding: 8px 10px;
      font-size: 16px;
      line-height: 1;
    }
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 99;
      background: rgba(0, 0, 0, 0.5);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      #sidebar {
        transform: translateX(-100%);
      }
      #sidebar.open {
        transform: translateX(0);
      }
      #main {
        margin-left: 0;
      }
      #hamburger {
        display: block;
      }
      .sidebar-overlay {
        display: block;
      }
      .sidebar-overlay.hidden {
        display: none;
      }
      .kpi-grid {
        grid-template-columns: 1fr 1fr;
      }
      .analytics-row {
        grid-template-columns: 1fr;
      }
      .detail-grid {
        grid-template-columns: 1fr;
      }
      .form-row {
        grid-template-columns: 1fr;
      }
      .main-content {
        padding: 20px 16px;
      }
      .main-header {
        padding: 16px 20px;
      }
      .cards-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 480px) {
      .kpi-grid {
        grid-template-columns: 1fr;
      }
      .login-box {
        padding: 32px 24px;
      }
    }

    /* ── CONTRIBUCIONES ── */
    .contrib-tab {
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      color: var(--ink-secondary);
      transition: all 0.15s;
    }
    .contrib-tab.active,
    .contrib-tab:hover {
      background: var(--gold);
      color: #fff;
      border-color: var(--gold);
    }
    .contrib-tipo-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .cb-foto {
      background: #e0f0ff;
      color: #0369a1;
    }
    .cb-datos {
      background: #fef9c3;
      color: #854d0e;
    }
    .cb-precio {
      background: #dcfce7;
      color: #166534;
    }
    .cb-formato {
      background: #ede9fe;
      color: #5b21b6;
    }
    .cb-correccion {
      background: #fee2e2;
      color: #991b1b;
    }
    .cb-otro {
      background: var(--surface-alt);
      color: var(--ink-muted);
    }
    .contrib-estado-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .ce-pendiente {
      background: #fef3c7;
      color: #92400e;
    }
    .ce-aprobado {
      background: #dcfce7;
      color: #166534;
    }
    .ce-rechazado {
      background: #fee2e2;
      color: #991b1b;
    }
    /* detail panel */
    .contrib-detail-panel {
      position: fixed;
      right: 0;
      top: 0;
      width: 360px;
      height: 100vh;
      background: var(--surface);
      border-left: 1px solid var(--border);
      z-index: 200;
      display: flex;
      flex-direction: column;
      box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
      overflow: hidden;
    }
    .cdp-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }
    .cdp-title {
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
    }
    .cdp-close {
      background: none;
      border: none;
      font-size: 18px;
      cursor: pointer;
      color: var(--ink-muted);
    }
    .cdp-body {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
    }
    .cdp-row {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
      align-items: flex-start;
    }
    .cdp-lbl {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--ink-muted);
      min-width: 110px;
      padding-top: 2px;
    }
    /* table row hover */
    .contrib-row {
      cursor: pointer;
      transition: background 0.1s;
    }
    .contrib-row:hover td {
      background: var(--surface-alt) !important;
    }
    .contrib-row.selected td {
      background: #fef9ee !important;
    }
  </style>

