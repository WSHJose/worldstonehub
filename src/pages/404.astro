---
import Base from "../layouts/Base.astro";

const LOGO_SVG = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 310 48" style="height:38px;width:auto;display:block;" aria-label="World Stone Hub">
  <text x="0" y="30" font-family="'Cormorant Garamond','Cormorant',Georgia,'Times New Roman',serif" font-weight="300" font-size="18" letter-spacing="6" fill="#1A1410">WORLD STONE</text>
  <line x1="208" y1="7" x2="208" y2="41" stroke="#A67C52" stroke-width="0.75" opacity="0.65"/>
  <text x="220" y="34" font-family="'Cormorant Garamond','Cormorant',Georgia,'Times New Roman',serif" font-weight="300" font-style="italic" font-size="30" letter-spacing="0.5" fill="#A67C52">Hub</text>
</svg>`;
---

<Base
  title="Página no encontrada — World Stone Hub"
  noIndex={true}
  bodyClass="body-404"
>
  <style slot="head">
    .body-404 {
      background: #f5f2ed;
      color: #1a1410;
      font-family: "Instrument Sans", sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }
    .container {
      text-align: center;
      max-width: 560px;
    }
    .number {
      font-family: "Cormorant Garamond", serif;
      font-size: 160px;
      font-weight: 300;
      line-height: 1;
      color: #e0dcd6;
      margin-bottom: -20px;
      letter-spacing: -8px;
    }
    .title {
      font-family: "Cormorant Garamond", serif;
      font-size: 36px;
      font-weight: 400;
      margin-bottom: 16px;
      color: #1a1410;
    }
    .title em {
      color: #a67c52;
      font-style: italic;
    }
    .desc {
      font-size: 14px;
      color: #8a8784;
      line-height: 1.7;
      margin-bottom: 40px;
    }
    .links {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 48px;
    }
    .link-primary {
      background: #1a1410;
      color: #f5f2ed;
      padding: 12px 28px;
      text-decoration: none;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      transition: background 0.25s;
    }
    .link-primary:hover {
      background: #a67c52;
    }
    .link-secondary {
      border: 1px solid #c9b99a;
      color: #4a4540;
      padding: 12px 28px;
      text-decoration: none;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: all 0.25s;
    }
    .link-secondary:hover {
      border-color: #1a1410;
      color: #1a1410;
    }
  </style>

  <div class="container">
    <div class="number">404</div>
    <h1 class="title">Página <em>no encontrada</em></h1>
    <p class="desc">
      Esta página no existe o ha sido movida.<br />Pero el sector de la piedra
      natural sigue aquí.
    </p>
    <div class="links">
      <a href="/index" class="link-primary">Ir al inicio</a>
      <a href="/proveedores" class="link-secondary">Ver directorio</a>
      <a href="/registro" class="link-secondary">Publicar empresa</a>
    </div>
    <div set:html={LOGO_SVG} />
  </div>
</Base>
