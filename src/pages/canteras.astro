---
import Page from "../layouts/Page.astro";
---

<Page
  title="Canteras del Mundo — Directorio Global de Piedra Natural · World Stone Hub"
  description="Directorio global de canteras de piedra natural. Explora más de 200 yacimientos activos en Europa, Asia, América y África. Fichas técnicas completas con producción, materiales y localización."
  ogTitle="Canteras del Mundo — World Stone Hub"
  ogDescription="Directorio global de canteras de piedra natural con fichas técnicas completas."
  ogUrl="https://worldstonehub.com/canteras.html"
  activePage="canteras"
>
  <style slot="head">
    /* ── PAGE HEADER ── */
    .page-header {
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 280px;
      margin-top: 70px;
    }
    .ph-left {
      padding: 52px 56px 44px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-right: 1px solid var(--border);
    }
    .ph-eyebrow {
      font-size: 9px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
      font-family: "DM Mono", monospace;
    }
    .ph-left h1 {
      font-family: "Cormorant Garamond", serif;
      font-size: 48px;
      font-weight: 300;
      line-height: 1;
      letter-spacing: -1px;
      color: var(--ink);
    }
    .ph-left h1 em {
      font-style: italic;
      color: var(--gold);
    }
    .ph-left p {
      margin-top: 12px;
      font-size: 13px;
      color: var(--ink-2);
      max-width: 420px;
      line-height: 1.75;
      padding-top: 12px;
    }
    .ph-stats {
      display: flex;
      gap: 0;
      margin-top: 32px;
      border-top: 1px solid var(--border);
    }
    .stat-block {
      flex: 1;
      padding: 16px 20px 0;
      border-right: 1px solid var(--border);
    }
    .stat-block:last-child {
      border-right: none;
    }
    .stat-n {
      font-family: "DM Mono", monospace;
      font-size: 24px;
      font-weight: 400;
      color: var(--ink);
      display: block;
      line-height: 1;
    }
    .stat-l {
      font-size: 8px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
      display: block;
      margin-top: 5px;
    }
    /* AD SLOT */
    .ph-right {
      position: relative;
      overflow: hidden;
      background: var(--bg-soft);
    }
    .ad-container {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .ad-link {
      display: block;
      width: 100%;
      height: 100%;
    }
    .ad-link img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .ad-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: var(--bg-soft);
      padding: 24px;
    }
    .ad-placeholder svg {
      opacity: 0.2;
    }
    .ad-placeholder-text {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
      text-align: center;
    }
    .ad-placeholder-sub {
      font-size: 11px;
      color: var(--ink-4);
      text-align: center;
    }
    .ad-label {
      position: absolute;
      bottom: 8px;
      right: 12px;
      font-size: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-4);
      z-index: 2;
    }

    /* ── TOOLBAR ── */
    .toolbar {
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 20px 48px;
      position: sticky;
      top: 70px;
      z-index: 90;
    }
    .toolbar-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .search-row {
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .search-wrap {
      flex: 1;
      position: relative;
      max-width: 460px;
    }
    .search-wrap svg {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      opacity: 0.4;
      pointer-events: none;
    }
    #searchInput {
      width: 100%;
      height: 40px;
      padding: 0 14px 0 40px;
      border: 1px solid var(--border2);
      border-radius: 4px;
      font-size: 13px;
      font-family: inherit;
      background: var(--bg-soft);
      color: var(--ink);
      outline: none;
      transition: border 0.2s, box-shadow 0.2s;
    }
    #searchInput:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(166, 124, 82, 0.12);
      background: #fff;
    }
    #searchInput::placeholder {
      color: var(--ink-4);
    }
    .results-count {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-4);
      white-space: nowrap;
    }
    .filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .filter-label {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
      margin-right: 4px;
      white-space: nowrap;
    }
    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      height: 30px;
      padding: 0 14px;
      border: 1px solid var(--border2);
      border-radius: 30px;
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--ink-2);
      background: transparent;
      cursor: pointer;
      transition: all 0.2s;
      font-family: "Instrument Sans", sans-serif;
      font-weight: 500;
      white-space: nowrap;
    }
    .filter-chip:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .filter-chip.active {
      background: var(--gold);
      border-color: var(--gold);
      color: #fff;
    }
    .filter-sep {
      width: 1px;
      height: 18px;
      background: var(--border);
      margin: 0 4px;
    }
    .clear-btn {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-4);
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px 8px;
      font-family: inherit;
      transition: color 0.2s;
    }
    .clear-btn:hover {
      color: var(--gold);
    }

    /* ── GRID ── */
    .grid-section {
      padding: 40px 48px 80px;
    }
    .grid-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    /* ── CARD ── */
    .cantera-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      transition: box-shadow 0.25s, transform 0.2s;
      display: flex;
      flex-direction: column;
    }
    .cantera-card:hover {
      box-shadow: 0 6px 28px rgba(0, 0, 0, 0.1);
      transform: translateY(-2px);
    }
    .card-stripe {
      height: 6px;
    }
    .card-body {
      padding: 24px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 8px;
    }
    .card-tipo {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
      font-family: "DM Mono", monospace;
    }
    .status-badge {
      font-size: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 30px;
      white-space: nowrap;
      font-weight: 500;
    }
    .status-activa {
      background: #f5efea;
      color: #a67c52;
      border: 1px solid rgba(166, 124, 82, 0.25);
    }
    .status-selectiva {
      background: rgba(201, 185, 154, 0.15);
      color: #9c8571;
      border: 1px solid rgba(201, 185, 154, 0.35);
    }
    .status-historica {
      background: #f0efed;
      color: #8a8784;
      border: 1px solid #e2e0dc;
    }
    .status-inactiva {
      background: #f0efed;
      color: #b8b5b0;
      border: 1px solid #e2e0dc;
    }
    .card-nombre {
      font-family: "Cormorant Garamond", serif;
      font-size: 22px;
      font-weight: 400;
      line-height: 1.15;
      color: var(--ink);
    }
    .card-loc {
      font-size: 12px;
      color: var(--ink-4);
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .card-loc svg {
      flex-shrink: 0;
      opacity: 0.5;
    }
    .card-materiales {
      font-size: 12px;
      color: var(--ink-2);
      font-style: italic;
      line-height: 1.5;
    }
    .card-props {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 4px;
    }
    .card-prop {
      background: var(--bg-soft);
      padding: 10px 12px;
      border-radius: 4px;
    }
    .cp-label {
      font-size: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-4);
      display: block;
      margin-bottom: 3px;
    }
    .cp-value {
      font-family: "DM Mono", monospace;
      font-size: 12px;
      color: var(--ink-2);
    }
    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 24px;
      border-top: 1px solid var(--border);
      background: var(--bg-soft);
    }
    .card-pais {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 11px;
      color: var(--ink-2);
    }
    .card-flag {
      font-size: 18px;
      line-height: 1;
    }
    .card-ver-btn {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold);
      padding: 7px 14px;
      border: 1px solid rgba(166, 124, 82, 0.35);
      border-radius: 4px;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      font-family: "Instrument Sans", sans-serif;
      font-weight: 500;
      white-space: nowrap;
    }
    .card-ver-btn:hover {
      background: var(--gold);
      color: #fff;
    }

    /* ── EMPTY / LOADING ── */
    .empty-state {
      padding: 80px 0;
      text-align: center;
    }
    .empty-state svg {
      opacity: 0.2;
      margin-bottom: 20px;
    }
    .empty-state p {
      font-size: 16px;
      color: var(--ink-4);
      font-family: "Cormorant Garamond", serif;
      font-style: italic;
    }
    .empty-state small {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-4);
      display: block;
      margin-top: 8px;
    }
    .loading-state {
      padding: 80px 0;
      text-align: center;
    }
    .spinner {
      width: 32px;
      height: 32px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 20px;
    }
    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
    .loading-state p {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
    }

    @media (max-width: 900px) {
      .page-header {
        grid-template-columns: 1fr;
      }
      .ph-left {
        border-right: none;
      }
      .ph-right {
        min-height: 200px;
        border-top: 1px solid var(--border);
      }
      .page-header,
      .toolbar,
      .grid-section {
        padding-left: 20px;
        padding-right: 20px;
      }
    }
    @media (max-width: 640px) {
      .ph-left h1 {
        font-size: 36px;
      }
      .cards-grid {
        grid-template-columns: 1fr;
      }
      .ph-stats {
        flex-wrap: wrap;
      }
      .stat-block {
        flex: 0 0 50%;
      }
    }
  </style>

  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="ph-left">
      <div>
        <p class="ph-eyebrow" data-i18n="hero.canteras.eyebrow">Lapidis · Directorio global</p>
        <h1>
          <span data-i18n="hero.canteras.title">Canteras</span><br />
          <em data-i18n="hero.canteras.titleItalic">del Mundo</em>
        </h1>
        <p data-i18n="hero.canteras.desc">Directorio global de canteras de piedra natural. Explora producción, materiales, localización y ficha técnica completa de cada yacimiento.</p>
      </div>
      <div class="ph-stats">
        <div class="stat-block">
          <span class="stat-n" id="statCanteras">—</span>
          <span class="stat-l" data-i18n="stats.canteras">Canteras</span>
        </div>
        <div class="stat-block">
          <span class="stat-n" id="statPaises">—</span>
          <span class="stat-l" data-i18n="stats.paises">Países</span>
        </div>
        <div class="stat-block">
          <span class="stat-n">6</span>
          <span class="stat-l" data-i18n="canteras.stats.continentes">Continentes</span>
        </div>
        <div class="stat-block">
          <span class="stat-n">31</span>
          <span class="stat-l" data-i18n="canteras.stats.tipos">Tipos</span>
        </div>
      </div>
    </div>
    <div class="ph-right">
      <div class="ad-container" id="heroAdSlot">
        <div class="ad-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 21V9"></path>
          </svg>
          <span class="ad-placeholder-text" data-i18n="ad.placeholder">Espacio publicitario</span>
          <span class="ad-placeholder-sub">CANTERAS-TOP</span>
        </div>
      </div>
      <div class="ad-label" data-i18n="ad.label">Publicidad</div>
    </div>
  </header>

  <!-- TOOLBAR -->
  <div class="toolbar">
    <div class="toolbar-inner">
      <div class="search-row">
        <div class="search-wrap">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
          <input type="text" id="searchInput" placeholder="Buscar cantera, país, material…" data-i18n-attr="placeholder:search.placeholderCanteras" />
        </div>
        <span class="results-count" id="resultsCount"></span>
      </div>
      <div class="filter-row">
        <span class="filter-label" data-i18n="canteras.filter.continente">Continente</span>
        <button class="filter-chip" data-group="continente" data-val="Europa" data-i18n="canteras.continentes.europa">Europa</button>
        <button class="filter-chip" data-group="continente" data-val="Asia" data-i18n="canteras.continentes.asia">Asia</button>
        <button class="filter-chip" data-group="continente" data-val="América" data-i18n="canteras.continentes.america">América</button>
        <button class="filter-chip" data-group="continente" data-val="África" data-i18n="canteras.continentes.africa">África</button>
        <button class="filter-chip" data-group="continente" data-val="Oceanía" data-i18n="canteras.continentes.oceania">Oceanía</button>
        <div class="filter-sep"></div>
        <span class="filter-label" data-i18n="canteras.filter.tipo">Tipo</span>
        <button class="filter-chip" data-group="tipo" data-val="Mármol" data-i18n="canteras.tipos.marmol">Mármol</button>
        <button class="filter-chip" data-group="tipo" data-val="Granito" data-i18n="canteras.tipos.granito">Granito</button>
        <button class="filter-chip" data-group="tipo" data-val="Cuarcita" data-i18n="canteras.tipos.cuarcita">Cuarcita</button>
        <button class="filter-chip" data-group="tipo" data-val="Travertino" data-i18n="canteras.tipos.travertino">Travertino</button>
        <button class="filter-chip" data-group="tipo" data-val="Caliza" data-i18n="canteras.tipos.caliza">Caliza</button>
        <button class="filter-chip" data-group="tipo" data-val="Pizarra" data-i18n="canteras.tipos.pizarra">Pizarra</button>
        <button class="filter-chip" data-group="tipo" data-val="Ónix" data-i18n="canteras.tipos.onix">Ónix</button>
        <div class="filter-sep"></div>
        <span class="filter-label" data-i18n="canteras.filter.estado">Estado</span>
        <button class="filter-chip" data-group="estado" data-val="Activa" data-i18n="canteras.estados.activa">Activa</button>
        <button class="filter-chip" data-group="estado" data-val="Selectiva" data-i18n="canteras.estados.selectiva">Selectiva</button>
        <button class="filter-chip" data-group="estado" data-val="Histórica" data-i18n="canteras.estados.historica">Histórica</button>
        <div class="filter-sep"></div>
        <button class="clear-btn" id="clearFilters" data-i18n="filter.limpiar">Limpiar filtros</button>
      </div>
    </div>
  </div>

  <!-- GRID -->
  <section class="grid-section">
    <div class="grid-inner">
      <div id="gridContainer">
        <div class="loading-state">
          <div class="spinner"></div>
          <p data-i18n="canteras.loading">Cargando canteras</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline slot="scripts">
  var SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
  var SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';

  var DB = [];
  var activeFilters = { continente: null, tipo: null, estado: null };
  var searchQuery = '';

  var TIPO_COLORS = {
    'Mármol':     'linear-gradient(90deg,#b0bec5,#90a4ae)',
    'Granito':    'linear-gradient(90deg,#8d6e63,#6d4c41)',
