    /* SUPABASE LOAD */
    (function loadCanteras() {
      getCanterasAll()
        .then(function (data) {
          DB = data.filter(function (c) {
            return c.nombre;
          });
          if (DB.length === 0) {
            renderPlaceholders();
            return;
          }
          (document.getElementById('statCanteras') as HTMLElement).textContent = String(DB.length);
          var paises: Record<string, number> = {};
          DB.forEach(function (c) {
            if (c.pais) paises[c.pais] = 1;
          });
          (document.getElementById('statPaises') as HTMLElement).textContent = String(
            Object.keys(paises).length
          );
          applyFilters();
        })
        .catch(function (err: Error) {
          (document.getElementById('gridContainer') as HTMLElement).innerHTML =
            '<div class="empty-state"><p>No se pudo conectar a la base de datos</p><small>' +
            err.message +
            '</small></div>';
        });
    })();

    /* Anuncio CANTERAS-TOP */
    (function loadAd() {
      var today = new Date().toISOString().slice(0, 10);
      getAdByCode('CANTERAS-TOP')
        .then(function (data) {
          if (!data.length) return;
          var valid = data.filter(function (a) {
            if (a.fecha_inicio && a.fecha_inicio > today) return false;
            if (a.fecha_fin && a.fecha_fin < today) return false;
            return true;
          });
          if (!valid.length) return;
          var ad = valid[0];
          var slot = document.getElementById('heroAdSlot');
          if (!slot) return;
          var href = ad.url_destino
            ? ad.url_destino.startsWith('http')
              ? ad.url_destino
              : 'https://' + ad.url_destino
            : '#';
          slot.innerHTML =
            '<a class="ad-link" href="' +
            href +
            '" target="_blank" rel="noopener">' +
            '<img src="' +
            (ad.imagen_url || '') +
            '" alt="' +
            (ad.texto_alt || 'Publicidad') +
            '" loading="lazy">' +
            '</a>';
        })
        .catch(function () {});
    })();
  </script>
</Page>
