  };
  var DEFAULT_COLOR = 'linear-gradient(90deg,#bdbdbd,#9e9e9e)';

  var FLAG_CODES = {
    'España':'es','Italia':'it','Portugal':'pt','Grecia':'gr','Turquía':'tr',
