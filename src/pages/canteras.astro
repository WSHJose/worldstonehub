    'Perú':'pe','Colombia':'co','Australia':'au','Sudáfrica':'za','Marruecos':'ma',
    'Egipto':'eg','Irán':'ir','Pakistán':'pk','Vietnam':'vn','Indonesia':'id',
    'Tailandia':'th','Japón':'jp','Corea del Sur':'kr','Israel':'il','Arabia Saudita':'sa',
    'Etiopía':'et','Tanzania':'tz','Zimbabwe':'zw','Madagascar':'mg','Bolivia':'bo',
    'Ecuador':'ec','Venezuela':'ve','Uruguay':'uy','Paraguay':'py','Honduras':'hn',
    'Guatemala':'gt','Cuba':'cu','Nigeria':'ng','Ghana':'gh','Angola':'ao',
    'Mozambique':'mz','Namibia':'na','Kenia':'ke','Uganda':'ug','Túnez':'tn',
    'Argelia':'dz','Azerbaiyán':'az','Georgia':'ge','Armenia':'am','Hungría':'hu',
    'Eslovaquia':'sk','Letonia':'lv','Lituania':'lt','Estonia':'ee','Suiza':'ch',
    'Reino Unido':'gb','Irlanda':'ie','Nueva Zelanda':'nz','Filipinas':'ph',
    'Malasia':'my','Camboya':'kh','Myanmar':'mm','Laos':'la','Sri Lanka':'lk',
    'Nepal':'np','Afganistán':'af','Libia':'ly','Sudán':'sd','Moldavia':'md',
    'Bielorrusia':'by','Kosovo':'xk','Montenegro':'me','Albania':'al','Macedonia':'mk'
  };

  function getFlag(pais) {
    if (!pais) return '';
    var code = FLAG_CODES[pais];
    if (!code) {
      var pl = pais.toLowerCase();
      for (var k in FLAG_CODES) {
        if (k.toLowerCase() === pl) { code = FLAG_CODES[k]; break; }
      }
    }
    if (!code) return '';
    return '<img src="https://flagicons.lipis.dev/flags/1x1/' + code + '.svg" ' +
      'width="18" height="18" alt="' + pais.replace(/"/g,'&quot;') + '" ' +
      'style="border-radius:3px;flex-shrink:0;display:inline-block;vertical-align:middle" ' +
      'loading="lazy" onerror="this.style.display=\'none\'">';
  }

  function getStripe(tipo) {
    for (var k in TIPO_COLORS) {
      if (tipo && tipo.indexOf(k) !== -1) return TIPO_COLORS[k];
    }
    return DEFAULT_COLOR;
  }

  function getStatusClass(estado) {
    if (!estado) return 'status-inactiva';
    var e = estado.toLowerCase();
    if (e.indexOf('activ') !== -1 && e.indexOf('select') === -1) return 'status-activa';
    if (e.indexOf('select') !== -1) return 'status-selectiva';
    if (e.indexOf('hist') !== -1) return 'status-historica';
    return 'status-inactiva';
  }

  function esc(s) {
    return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function trunc(s, n) {
    if (!s) return '';
    s = s.toString();
    return s.length > n ? s.slice(0, n) + '…' : s;
  }

  function buildCard(c) {
    var stripe = getStripe(c.tipo_piedra);
    var statusClass = getStatusClass(c.estado_operativo);
    var statusLabel = c.estado_operativo || 'Desconocido';
    var flag = getFlag(c.pais);
    var mats = c.materiales ? trunc(c.materiales, 72) : '';
    var locStr = [c.localizacion, c.pais].filter(Boolean).join(', ');
    var propsHtml = '';
    if (c.anio_inicio) propsHtml += '<div class="card-prop"><span class="cp-label">Fundada</span><span class="cp-value">' + esc(c.anio_inicio) + '</span></div>';
    if (c.produccion_anual) propsHtml += '<div class="card-prop"><span class="cp-label">Producción</span><span class="cp-value">' + esc(trunc(c.produccion_anual, 18)) + '</span></div>';
    var verBtn = c.slug ? '<a class="card-ver-btn" href="/cantera.html?id=' + esc(c.slug) + '">Ver ficha →</a>' : '';
    return '<div class="cantera-card">' +
      '<div class="card-stripe" style="background:' + stripe + '"></div>' +
      '<div class="card-body">' +
        '<div class="card-top">' +
          '<span class="card-tipo">' + esc(c.tipo_piedra || 'Piedra natural') + '</span>' +
          '<span class="status-badge ' + statusClass + '">' + esc(statusLabel) + '</span>' +
        '</div>' +
        '<div class="card-nombre">' + esc(c.nombre || 'Sin nombre') + '</div>' +
        (locStr ? '<div class="card-loc"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>' + esc(locStr) + '</div>' : '') +
        (mats ? '<div class="card-materiales">' + esc(mats) + '</div>' : '') +
        (propsHtml ? '<div class="card-props">' + propsHtml + '</div>' : '') +
      '</div>' +
      '<div class="card-footer">' +
        '<div class="card-pais"><span class="card-flag">' + flag + '</span><span>' + esc(c.pais || '') + '</span></div>' +
        verBtn +
      '</div>' +
    '</div>';
  }

  function renderGrid(list) {
    var container = document.getElementById('gridContainer');
    if (!list.length) {
      container.innerHTML = '<div class="empty-state">' +
        '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>' +
        '<p>Sin resultados para esta búsqueda</p>' +
        '<small>Prueba con otros filtros o términos</small>' +
        '</div>';
      return;
    }
    var html = '<div class="cards-grid">';
    for (var i = 0; i < list.length; i++) html += buildCard(list[i]);
    html += '</div>';
    container.innerHTML = html;
  }

  function applyFilters() {
    var q = searchQuery.trim().toLowerCase();
    var fc = activeFilters.continente, ft = activeFilters.tipo, fe = activeFilters.estado;
    var result = DB.filter(function(c) {
      if (fc && (c.continente || '').indexOf(fc) === -1) return false;
      if (ft && (c.tipo_piedra || '').indexOf(ft) === -1) return false;
      if (fe) {
        if (getStatusClass(c.estado_operativo) !== 'status-' + fe.toLowerCase()) return false;
      }
      if (q) {
        var hay = [c.nombre,c.pais,c.localizacion,c.continente,c.tipo_piedra,
                   c.materiales,c.color_principal,c.proyectos_clave,
                   c.empresa_propietaria,c.datos_historicos].join(' ').toLowerCase();
        if (hay.indexOf(q) === -1) return false;
      }
      return true;
    });
    renderGrid(result);
    document.getElementById('resultsCount').textContent =
      result.length === DB.length ? DB.length + ' canteras' : result.length + ' de ' + DB.length;
  }

  document.getElementById('searchInput').addEventListener('input', function() {
    searchQuery = this.value; applyFilters();
  });

  document.querySelectorAll('.filter-chip').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var group = this.dataset.group, val = this.dataset.val;
      if (activeFilters[group] === val) {
        activeFilters[group] = null; this.classList.remove('active');
      } else {
        document.querySelectorAll('[data-group="' + group + '"]').forEach(function(b) { b.classList.remove('active'); });
        activeFilters[group] = val; this.classList.add('active');
      }
      applyFilters();
    });
  });

  document.getElementById('clearFilters').addEventListener('click', function() {
    activeFilters = { continente: null, tipo: null, estado: null };
    searchQuery = '';
    document.getElementById('searchInput').value = '';
    document.querySelectorAll('.filter-chip').forEach(function(b) { b.classList.remove('active'); });
    applyFilters();
  });

  function renderPlaceholders() {
    var PLACEHOLDERS = [
      { nombre:'Cantera de Macael', tipo_piedra:'Mármol', localizacion:'Macael, Almería', pais:'España', estado_operativo:'Activa', anio_inicio:'1850', produccion_anual:'250.000 t/año', slug:'cantera-macael' },
      { nombre:'Cava dei Tirreni', tipo_piedra:'Travertino', localizacion:'Guidonia, Lazio', pais:'Italia', estado_operativo:'Activa', anio_inicio:'1920', produccion_anual:'180.000 t/año', slug:'cava-dei-tirreni' },
      { nombre:'Afyon Iscehisar', tipo_piedra:'Mármol', localizacion:'Iscehisar, Afyon', pais:'Turquía', estado_operativo:'Activa', anio_inicio:'1975', produccion_anual:'320.000 t/año', slug:'afyon-iscehisar' },
      { nombre:'Rajasthan Pink Quarry', tipo_piedra:'Granito', localizacion:'Jalore, Rajasthan', pais:'India', estado_operativo:'Activa', anio_inicio:'1990', produccion_anual:'420.000 t/año', slug:'rajasthan-pink' },
      { nombre:'Vila Viçosa', tipo_piedra:'Mármol', localizacion:'Vila Viçosa, Alentejo', pais:'Portugal', estado_operativo:'Activa', anio_inicio:'1910', produccion_anual:'95.000 t/año', slug:'vila-vicosa' },
      { nombre:'Carrara Fantiscritti', tipo_piedra:'Mármol', localizacion:'Carrara, Toscana', pais:'Italia', estado_operativo:'Activa', anio_inicio:'1870', produccion_anual:'500.000 t/año', slug:'carrara-fantiscritti' }
    ];
    document.getElementById('statCanteras').textContent = '200+';
    document.getElementById('statPaises').textContent = '40+';
    var html = '<div class="cards-grid">';
    PLACEHOLDERS.forEach(function(c) { html += buildCard(c); });
    html += '</div><div style="text-align:center;padding:40px 0 20px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--ink-4);">Datos de muestra</div>';
    document.getElementById('gridContainer').innerHTML = html;
  }

  (function loadCanteras() {
    fetch(SB_URL + '/rest/v1/canteras?select=*&order=nombre.asc&limit=500', {
      headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY, 'Accept': 'application/json' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!Array.isArray(data)) {
        document.getElementById('gridContainer').innerHTML = '<div class="empty-state"><p>Error al cargar canteras</p></div>';
        return;
      }
      DB = data.filter(function(c) { return c.nombre; });
      if (DB.length === 0) { renderPlaceholders(); return; }
      document.getElementById('statCanteras').textContent = DB.length;
      var paises = {};
      DB.forEach(function(c) { if (c.pais) paises[c.pais] = 1; });
      document.getElementById('statPaises').textContent = Object.keys(paises).length;
      applyFilters();
    })
    .catch(function() {
      document.getElementById('gridContainer').innerHTML = '<div class="empty-state"><p>No se pudo conectar a la base de datos</p></div>';
    });
  })();

  (function loadAd() {
    var today = new Date().toISOString().slice(0, 10);
    fetch(SB_URL + '/rest/v1/anuncios?espacio_codigo=eq.CANTERAS-TOP&activo=eq.true&select=imagen_url,url_destino,texto_alt,fecha_inicio,fecha_fin&limit=5', {
      headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!Array.isArray(data) || !data.length) return;
      var valid = data.filter(function(a) {
        if (a.fecha_inicio && a.fecha_inicio > today) return false;
        if (a.fecha_fin   && a.fecha_fin   < today) return false;
        return true;
      });
      if (!valid.length) return;
      var ad = valid[0];
      var slot = document.getElementById('heroAdSlot');
      if (!slot) return;
      var href = ad.url_destino ? (ad.url_destino.startsWith('http') ? ad.url_destino : 'https://' + ad.url_destino) : '#';
      slot.innerHTML = '<a class="ad-link" href="' + href + '" target="_blank" rel="noopener"><img src="' + (ad.imagen_url||'') + '" alt="' + (ad.texto_alt||'Publicidad') + '" loading="lazy"></a>';
    })
    .catch(function() {});
  })();
  </script>
</Page>
