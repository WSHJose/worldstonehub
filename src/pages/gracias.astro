---
import Base from '../layouts/Base.astro';

const LOGO_SVG = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 310 48" style="height:36px;width:auto;display:block;" aria-label="World Stone Hub">
  <text x="0" y="30" font-family="'Cormorant Garamond','Cormorant',Georgia,serif" font-weight="300" font-size="18" letter-spacing="6" fill="#1A1410">WORLD STONE</text>
  <line x1="208" y1="7" x2="208" y2="41" stroke="#A67C52" stroke-width="0.75" opacity="0.65"/>
  <text x="220" y="34" font-family="'Cormorant Garamond','Cormorant',Georgia,serif" font-weight="300" font-style="italic" font-size="30" letter-spacing="0.5" fill="#A67C52">Hub</text>
</svg>`;
---

<Base
  title="Solicitud recibida · World Stone Hub"
  description="Hemos recibido tu solicitud de alta en World Stone Hub. En breve revisaremos tu información y la publicaremos en el directorio."
  noIndex={true}
  bodyClass="gracias-body"
>
  <style slot="head">
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html {
      font-size: 16px;
      background: #f8f7f5;
    }
    .gracias-body {
      font-family: 'Instrument Sans', sans-serif;
      color: #1a1917;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAV ── */
    .gracias-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 800;
      padding: 16px 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #ffffff;
      border-bottom: 1px solid #e2e0dc;
    }
    .nav-back {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #8a8784;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: color 0.2s;
    }
    .nav-back::before {
      content: '←';
      font-size: 14px;
    }
    .nav-back:hover {
      color: #4a4845;
    }

    /* ── MAIN ── */
    .gracias-main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 100px 24px 60px;
    }
    .card {
      background: #ffffff;
      border: 1px solid #e2e0dc;
      padding: 64px 56px;
      max-width: 600px;
      width: 100%;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #a67c52, #c4a05a);
    }

    /* Check animado */
    .check-ring {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      border: 1px solid rgba(74, 138, 90, 0.35);
      background: rgba(74, 138, 90, 0.07);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 36px;
      animation: ringPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }
    .check-ring svg {
      width: 36px;
      height: 36px;
    }
    @keyframes ringPop {
      from {
        transform: scale(0);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }
    @keyframes drawCheck {
      to {
        stroke-dashoffset: 0;
      }
    }

    .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: #a67c52;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .eyebrow::before,
    .eyebrow::after {
      content: '';
      width: 28px;
      height: 1px;
      background: #a67c52;
      opacity: 0.5;
    }

    .title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 5vw, 54px);
      font-weight: 300;
      line-height: 1.05;
      color: #1a1917;
      margin-bottom: 16px;
    }
    .title em {
      color: #a67c52;
      font-style: italic;
    }

    .subtitle {
      font-size: 14px;
      color: #8a8784;
      line-height: 1.85;
      max-width: 420px;
      margin: 0 auto 40px;
    }
    .subtitle strong {
      color: #4a4845;
    }

    .divider {
      height: 1px;
      background: #e8e6e2;
      margin: 0 0 36px;
    }

    .steps {
      display: flex;
      flex-direction: column;
      gap: 14px;
      text-align: left;
      margin-bottom: 40px;
    }
    .step-item {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 16px 20px;
      background: #f8f7f5;
      border: 1px solid #eeece9;
    }
    .step-num {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 2px;
      color: #a67c52;
      flex-shrink: 0;
      padding-top: 2px;
    }
    .step-txt {
      font-size: 12px;
      color: #4a4845;
      line-height: 1.65;
    }
    .step-txt strong {
      color: #1a1917;
      display: block;
      margin-bottom: 2px;
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .actions {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-gold {
      padding: 13px 32px;
      background: #a67c52;
      color: #ffffff;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-decoration: none;
      font-weight: 500;
      transition: background 0.2s;
      border: none;
      cursor: pointer;
    }
    .btn-gold:hover {
      background: #8b6a40;
    }
    .btn-out {
      padding: 13px 28px;
      background: transparent;
      color: #4a4845;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-decoration: none;
      font-weight: 400;
      border: 1px solid #c8c5bf;
      transition:
        border-color 0.2s,
        color 0.2s;
    }
    .btn-out:hover {
      border-color: #a67c52;
      color: #a67c52;
    }

    /* ── FOOTER ── */
    .gracias-footer {
      background: #111110;
      color: #6a6764;
      padding: 28px 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }
    .gracias-footer a {
      color: #6a6764;
      text-decoration: none;
      transition: color 0.2s;
    }
    .gracias-footer a:hover {
      color: #a67c52;
    }

    @media (max-width: 640px) {
      .gracias-nav {
        padding: 14px 20px;
      }
      .card {
        padding: 48px 24px;
      }
      .gracias-footer {
        padding: 24px 20px;
        flex-direction: column;
        gap: 12px;
        text-align: center;
      }
    }
  </style>

  <!-- NAV -->
  <nav class="gracias-nav">
    <a href="/index.html" class="logo" set:html={LOGO_SVG} />
    <a href="/index.html" class="nav-back">Volver al inicio</a>
  </nav>

  <!-- CONTENIDO -->
  <main class="gracias-main">
    <div class="card">
      <div class="check-ring">
        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="18" cy="18" r="17" stroke="rgba(74,138,90,0.4)" stroke-width="1"></circle>
          <polyline
            points="10,18 16,24 26,13"
            stroke="#4a8a5a"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-dasharray="24"
            stroke-dashoffset="24"
            style="animation:drawCheck 0.5s 0.4s ease forwards;"></polyline>
        </svg>
      </div>

      <div class="eyebrow">Solicitud recibida</div>

      <h1 class="title">Tu ficha está<br /><em>en revisión</em></h1>

      <p class="subtitle">
        Hemos recibido tu solicitud de alta en World Stone Hub.<br />
        Revisaremos tu información y la publicaremos en el directorio<br />
        en un plazo de <strong>24–48 horas</strong>.
      </p>

      <div class="divider"></div>

      <div class="steps">
        <div class="step-item">
          <span class="step-num">01</span>
          <div class="step-txt">
            <strong>Solicitud registrada</strong>
            Tus datos han quedado guardados en nuestro sistema. Recibirás un email de confirmación en
            breve.
          </div>
        </div>
        <div class="step-item">
          <span class="step-num">02</span>
          <div class="step-txt">
            <strong>Revisión editorial</strong>
            Nuestro equipo verifica que la información sea correcta y coherente con el directorio.
          </div>
        </div>
        <div class="step-item">
          <span class="step-num">03</span>
          <div class="step-txt">
            <strong>Publicación en el directorio</strong>
            Una vez aprobada, tu ficha será visible para todos los profesionales del sector de la piedra.
          </div>
        </div>
      </div>

      <div class="actions">
        <a href="/panel.html" class="btn-gold">Ir a mi panel</a>
        <a href="/proveedores.html" class="btn-out">Ver el directorio</a>
        <a href="/index.html" class="btn-out">Volver al inicio</a>
      </div>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="gracias-footer">
    <span>© 2026 World Stone Hub</span>
    <div style="display:flex;gap:24px;">
      <a href="/legal.html">Privacidad</a>
      <a href="/legal.html">Términos</a>
      <a href="/contacto.html">Contacto</a>
    </div>
  </footer>

  <!-- Supabase + auto-activación -->
  <script>
    import { supabase as db } from '@services/http/config';
    (function () {
      db.auth.getSession().then(function (r) {
        var session = r.data && r.data.session;
        if (!session || !session.user) return;

        var userId = session.user.id;
        db.from('proveedores')
          .select('id, estado, plan')
          .eq('user_id', userId)
          .single()
          .then(function (res) {
            if (!res.data) return;
            var empresa = res.data;
            if (empresa.estado === 'pendiente') {
              db.from('proveedores')
                .update({ estado: 'activo', activo: true, plan_activo: true })
                .eq('id', empresa.id)
                .then(function (upd) {
                  if (!upd.error) {
                    var subtitle = document.querySelector('.subtitle');
                    if (subtitle)
                      subtitle.innerHTML =
                        'Tu empresa ya está activa en el directorio.<br>Puedes acceder a tu panel para completar tu perfil en cualquier momento.';
                    var step2 = document.querySelector('.step-item:nth-child(2) .step-txt');
                    if (step2)
                      step2.innerHTML =
                        '<strong>Empresa verificada</strong>Tu ficha ya es visible en el directorio y en todas las categorías correspondientes.';
                    var step3 = document.querySelector('.step-item:nth-child(3) .step-txt');
                    if (step3)
                      step3.innerHTML =
                        '<strong>Publicada en el directorio</strong>Los profesionales del sector ya pueden encontrarte. Accede a tu panel para optimizar tu perfil.';
                    var eyebrow = document.querySelector('.eyebrow');
                    if (eyebrow) eyebrow.textContent = 'Empresa activa';
                    var title = document.querySelector('.title');
                    if (title) title.innerHTML = 'Tu ficha ya está<br><em>publicada</em>';
                  }
                });
            }
          });
      });
    })();
  </script>
  <script is:inline src="/i18n.js"></script>
</Base>
