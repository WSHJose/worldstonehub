---
import Page from '../layouts/Page.astro';
---

<Page
  title="Proponer Cantera — World Stone Hub"
  description="Añade una cantera al directorio global de World Stone Hub. Tu propuesta será revisada y publicada en 24-48h."
  noIndex={true}
>
  <style slot="head">
    .page {
      margin-top: 64px;
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
      padding: 48px 24px 80px;
    }
    .page-eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }
    .page-title {
      font-family: var(--font-disp);
      font-size: 2.4rem;
      font-weight: 300;
      line-height: 1.1;
      margin-bottom: 12px;
    }
    .page-desc {
      font-size: 0.85rem;
      color: var(--ink-muted);
      line-height: 1.7;
      margin-bottom: 32px;
    }
    .notice {
      background: var(--gold-lt);
      border: 1px solid #e8d5c0;
      border-left: 3px solid var(--gold);
      padding: 14px 18px;
      font-size: 0.8rem;
      color: var(--ink-mid);
      margin-bottom: 32px;
      border-radius: 2px;
    }
    .auth-gate {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 48px;
      text-align: center;
      border-radius: 2px;
    }
    .auth-gate-icon {
      font-size: 2rem;
      margin-bottom: 16px;
      opacity: 0.3;
    }
    .auth-gate-title {
      font-family: var(--font-disp);
      font-size: 1.4rem;
      margin-bottom: 8px;
    }
    .auth-gate-desc {
      font-size: 0.82rem;
      color: var(--ink-muted);
      margin-bottom: 24px;
    }
    .btn {
      display: inline-block;
      padding: 12px 28px;
      background: var(--ink);
      color: white;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 2px;
      cursor: pointer;
      border: none;
      font-family: var(--font-head);
      transition: background 0.2s;
    }
    .btn:hover {
      background: var(--gold);
    }
    .btn.outline {
      background: transparent;
      color: var(--ink);
      border: 1px solid var(--border-mid);
    }
    .btn.outline:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .btn.gold {
      background: var(--gold);
    }
    .btn.gold:hover {
      background: #8a6340;
    }
    .form-card {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 40px;
      border-radius: 2px;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }
    .form-section {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .form-section-title {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-faint);
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-group.full {
      grid-column: 1/-1;
    }
    label {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-muted);
    }
    input,
    select,
    textarea {
      padding: 10px 14px;
      border: 1px solid var(--border);
      background: var(--bg-soft);
      font-family: var(--font-head);
      font-size: 0.82rem;
      color: var(--ink);
      border-radius: 2px;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--gold);
      background: var(--bg);
    }
    textarea {
      resize: vertical;
      min-height: 80px;
    }
    .autocomplete-wrap {
      position: relative;
    }
    .autocomplete-input-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 8px 12px;
      border: 1px solid var(--border);
      background: var(--bg-soft);
      border-radius: 2px;
      min-height: 44px;
      cursor: text;
      transition: border-color 0.2s;
    }
    .autocomplete-input-wrap:focus-within {
      border-color: var(--gold);
      background: var(--bg);
    }
    .autocomplete-input-wrap input {
      border: none;
      background: transparent;
      padding: 2px 4px;
      flex: 1;
      min-width: 140px;
      font-size: 0.82rem;
    }
    .autocomplete-input-wrap input:focus {
      outline: none;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 10px;
      background: var(--ink);
      color: white;
      font-size: 0.68rem;
      border-radius: 2px;
    }
    .chip-remove {
      cursor: pointer;
      opacity: 0.6;
      font-size: 0.8rem;
    }
    .chip-remove:hover {
      opacity: 1;
    }
    .autocomplete-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border: 1px solid var(--border);
      max-height: 220px;
      overflow-y: auto;
      z-index: 50;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }
    .autocomplete-dropdown.open {
      display: block;
    }
    .autocomplete-item {
      padding: 10px 16px;
      cursor: pointer;
      font-size: 0.8rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border);
    }
    .autocomplete-item:last-child {
      border-bottom: none;
    }
    .autocomplete-item:hover,
    .autocomplete-item.active {
      background: var(--gold-lt);
    }
    .autocomplete-item-sub {
      font-size: 0.7rem;
      color: var(--ink-muted);
    }
    .form-actions {
      display: flex;
      gap: 12px;
      align-items: center;
      padding-top: 8px;
      border-top: 1px solid var(--border);
    }
    .form-status {
      font-size: 0.78rem;
      padding: 12px 16px;
      border-radius: 2px;
      display: none;
      margin-top: 8px;
    }
    .form-status.success {
      background: var(--gold-lt);
      color: var(--green);
      border: 1px solid rgba(166, 124, 82, 0.25);
      display: block;
    }
    .form-status.error {
      background: #fce4e4;
      color: #c62828;
      border: 1px solid #ffcdd2;
      display: block;
    }
    .spinner {
      width: 20px;
      height: 20px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: inline-block;
    }
    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
  </style>

  <div class="page">
    <div class="page-eyebrow">Directorio · Contribuir</div>
    <h1 class="page-title">Proponer una cantera</h1>
    <p class="page-desc">
      A&ntilde;ade una cantera al directorio global de World Stone Hub. Tu propuesta ser&aacute;
      revisada y publicada en 24-48h.
    </p>

    <div id="authGate" style="display:none">
      <div class="auth-gate">
        <div class="auth-gate-icon">&#9671;</div>
        <div class="auth-gate-title">Acceso requerido</div>
        <div class="auth-gate-desc">Debes tener una cuenta activa para proponer canteras.</div>
        <a href="/panel" class="btn">Acceder a mi panel</a>
      </div>
    </div>

    <div id="formWrap" style="display:none">
      <div class="notice">
        &#9200; Tu propuesta quedar&aacute; en estado <strong>pendiente</strong> hasta revisi&oacute;n
        manual. Recibir&aacute;s confirmaci&oacute;n por email.
      </div>
      <div class="form-card">
        <div class="form-section">
          <div class="form-section-title">Datos de la cantera</div>
          <div class="form-row">
            <div class="form-group full">
              <label>Nombre de la cantera *</label>
              <input id="f-nombre" type="text" placeholder="Ej: Cava Fantiscritti" />
            </div>
            <div class="form-group">
              <label>Pa&iacute;s *</label>
              <input id="f-pais" type="text" placeholder="Ej: Italia" />
            </div>
            <div class="form-group">
              <label>Continente</label>
              <select id="f-continente">
                <option value="">— Selecciona —</option>
                <option>Europa</option><option>Asia</option><option>&Aacute;frica</option>
                <option>Am&eacute;rica</option><option>Europa / Asia</option><option
                  >Ocean&iacute;a</option
                >
              </select>
            </div>
            <div class="form-group full">
              <label>Localizaci&oacute;n / Zona</label>
              <input id="f-loc" type="text" placeholder="Ej: Carrara, Alpi Apuane, Toscana" />
            </div>
            <div class="form-group">
              <label>Tipo de piedra *</label>
              <select id="f-tipo">
                <option value="">— Selecciona —</option>
                <option>M&aacute;rmol</option><option>Granito</option><option>Cuarcita</option>
                <option>Travertino</option><option>Caliza</option><option>Pizarra</option>
                <option>Basalto</option><option>Arenisca</option><option>Gneis</option><option
                  >Otro</option
                >
              </select>
            </div>
            <div class="form-group">
              <label>Color principal</label>
              <input id="f-color" type="text" placeholder="Ej: Blanco / gris" />
            </div>
            <div class="form-group">
              <label>Estado operativo</label>
              <select id="f-estado">
                <option value="Activa">Activa</option>
                <option value="Inactiva">Inactiva / Agotada</option>
              </select>
            </div>
            <div class="form-group">
              <label>A&ntilde;o / Era de inicio</label>
              <input id="f-anio" type="text" placeholder="Ej: 1892 o Siglo I a.C." />
            </div>
            <div class="form-group">
              <label>Producci&oacute;n anual estimada</label>
              <input id="f-prod" type="text" placeholder="Ej: ~50.000 m³/año" />
            </div>
            <div class="form-group">
              <label>Empresa propietaria</label>
              <input id="f-empresa" type="text" placeholder="Ej: Varias privadas" />
            </div>
            <div class="form-group full">
              <label>Materiales extra&iacute;dos (texto libre)</label>
              <input
                id="f-materiales"
                type="text"
                placeholder="Ej: Bianco Carrara C/CD, Bianco Venatino"
              />
            </div>
            <div class="form-group full">
              <label>Proyectos / Monumentos clave</label>
              <input id="f-proyectos" type="text" placeholder="Ej: Coliseo Romano, Panteón" />
            </div>
            <div class="form-group full">
              <label>Descripci&oacute;n / Historia</label>
              <textarea
                id="f-desc"
                placeholder="Información adicional, datos históricos, curiosidades…"></textarea>
            </div>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-title">Materiales del cat&aacute;logo vinculados (opcional)</div>
          <p style="font-size:.78rem;color:var(--ink-muted);margin-bottom:4px">
            Vincula esta cantera con materiales ya existentes en el cat&aacute;logo.
          </p>
          <div class="form-group">
            <label>Buscar y a&ntilde;adir materiales</label>
            <div class="autocomplete-wrap" id="materialesWrap">
              <div
                class="autocomplete-input-wrap"
                id="materialesChips"
                onclick="document.getElementById('materialesInput').focus()"
              >
                <input
                  id="materialesInput"
                  type="text"
                  placeholder="Escribe para buscar materiales…"
                  autocomplete="off"
                />
              </div>
              <div class="autocomplete-dropdown" id="materialesDropdown"></div>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button class="btn gold" id="submitBtn" onclick="submitForm()">Enviar propuesta</button>
          <a href="/canteras" class="btn outline">Cancelar</a>
          <div class="spinner" id="spinner" style="display:none"></div>
        </div>
        <div class="form-status" id="formStatus"></div>
      </div>
    </div>
  </div>

  <script slot="scripts" is:inline>
    (function () {
      var SB_URL = 'https://whcptmdapnavcxcszwwk.supabase.co';
      var SB_KEY = 'sb_publishable_CsE_EOAwQSJgKDC2eEcBOA_UztVp7gO';
      var db = supabase.createClient(SB_URL, SB_KEY);
      var session = null,
        materialesSeleccionados = [],
        todosMateriales = [];

      db.auth.getSession().then(function (r) {
        session = r.data && r.data.session;
        if (session) {
          document.getElementById('formWrap').style.display = 'block';
          cargarMateriales();
        } else document.getElementById('authGate').style.display = 'block';
      });

      function cargarMateriales() {
        db.from('materiales')
          .select('id,slug,nombre_comercial,categoria,origen_pais')
          .order('nombre_comercial')
          .then(function (r) {
            todosMateriales = r.data || [];
          });
      }

      var inp = document.getElementById('materialesInput');
      var dd = document.getElementById('materialesDropdown');

      inp.addEventListener('input', function () {
        var q = inp.value.toLowerCase().trim();
        if (!q) {
          dd.classList.remove('open');
          return;
        }
        var matches = todosMateriales
          .filter(function (m) {
            return (
              m.nombre_comercial.toLowerCase().includes(q) ||
              (m.categoria || '').toLowerCase().includes(q) ||
              (m.origen_pais || '').toLowerCase().includes(q)
            );
          })
          .slice(0, 8);
        if (!matches.length) {
          dd.classList.remove('open');
          return;
        }
        dd.innerHTML = matches
          .map(function (m) {
            var sel = materialesSeleccionados.some(function (s) {
              return s.id === m.id;
            });
            return (
              '<div class="autocomplete-item' +
              (sel ? ' active' : '') +
              '" data-id="' +
              m.id +
              '" data-slug="' +
              m.slug +
              '" data-nombre="' +
              m.nombre_comercial.replace(/"/g, '&quot;') +
              '">' +
              '<span>' +
              m.nombre_comercial +
              '</span>' +
              '<span class="autocomplete-item-sub">' +
              (m.categoria || '') +
              ' \u00b7 ' +
              (m.origen_pais || '') +
              '</span>' +
              '</div>'
            );
          })
          .join('');
        dd.classList.add('open');
        dd.querySelectorAll('.autocomplete-item').forEach(function (el) {
          el.addEventListener('click', function () {
            var id = el.getAttribute('data-id');
            if (
              !materialesSeleccionados.some(function (s) {
                return s.id === id;
              })
            ) {
              materialesSeleccionados.push({
                id: id,
                slug: el.getAttribute('data-slug'),
                nombre: el.getAttribute('data-nombre'),
              });
              renderChips();
            }
            inp.value = '';
            dd.classList.remove('open');
          });
        });
      });

      document.addEventListener('click', function (e) {
        if (!document.getElementById('materialesWrap').contains(e.target))
          dd.classList.remove('open');
      });

      function renderChips() {
        var chips = document.getElementById('materialesChips');
        chips.querySelectorAll('.chip').forEach(function (c) {
          c.remove();
        });
        materialesSeleccionados.forEach(function (m) {
          var chip = document.createElement('span');
          chip.className = 'chip';
          chip.innerHTML = m.nombre + '<span class="chip-remove" data-id="' + m.id + '">×</span>';
          chip.querySelector('.chip-remove').addEventListener('click', function (e) {
            e.stopPropagation();
            materialesSeleccionados = materialesSeleccionados.filter(function (s) {
              return s.id !== m.id;
            });
            renderChips();
          });
          chips.insertBefore(chip, inp);
        });
      }

      window.submitForm = function () {
        var nombre = document.getElementById('f-nombre').value.trim();
        var pais = document.getElementById('f-pais').value.trim();
        var tipo = document.getElementById('f-tipo').value;
        if (!nombre || !pais || !tipo) {
          showStatus('Por favor completa nombre, pa\u00eds y tipo de piedra.', 'error');
          return;
        }
        if (!session) {
          showStatus('Sesi\u00f3n caducada. Recarga la p\u00e1gina.', 'error');
          return;
        }

        document.getElementById('submitBtn').disabled = true;
        document.getElementById('spinner').style.display = 'inline-block';

        var payload = {
          user_id: session.user.id,
          nombre: nombre,
          pais: pais,
          continente: document.getElementById('f-continente').value || null,
          localizacion: document.getElementById('f-loc').value.trim() || null,
          tipo_piedra: tipo,
          color_principal: document.getElementById('f-color').value.trim() || null,
          estado_operativo: document.getElementById('f-estado').value,
          anio_inicio: document.getElementById('f-anio').value.trim() || null,
          produccion_anual: document.getElementById('f-prod').value.trim() || null,
          empresa_propietaria: document.getElementById('f-empresa').value.trim() || null,
          materiales_texto: document.getElementById('f-materiales').value.trim() || null,
          descripcion_libre: document.getElementById('f-desc').value.trim() || null,
          materiales_vinculados: materialesSeleccionados.map(function (m) {
            return m.slug;
          }),
          estado: 'pendiente',
        };

        db.from('propuestas_canteras')
          .insert(payload)
          .then(function (r) {
            document.getElementById('spinner').style.display = 'none';
            document.getElementById('submitBtn').disabled = false;
            if (r.error) {
              showStatus('Error: ' + r.error.message, 'error');
              return;
            }
            showStatus('\u2713 Propuesta enviada. La revisaremos en 24-48h.', 'success');
            document.querySelector('.form-card').style.opacity = '.5';
            document.querySelector('.form-card').style.pointerEvents = 'none';
          });
      };

      function showStatus(msg, type) {
        var el = document.getElementById('formStatus');
        el.textContent = msg;
        el.className = 'form-status ' + type;
      }
    })();
  </script>
</Page>
