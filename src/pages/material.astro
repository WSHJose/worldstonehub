  <script>
    import {
      getBySlug,
      getContributions,
      getProveedores,
    } from '@contexts/materials/services/http/materialsHttp';
    import { supabase } from '@services/http/config';
    (function () {
      var db = supabase;

      function esc(s) {
        if (!s) return '';
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }
      function arr(v) {
        if (!v) return [];
        if (Array.isArray(v)) return v;
        if (typeof v === 'string') {
          var s = v.trim();
          if (s.charAt(0) === '[') {
            try {
              var p = JSON.parse(s);
              if (Array.isArray(p)) return p;
            } catch (e) {}
          }
          return [v];
        }
        return [v];
      }
      function el(id) {
        return document.getElementById(id);
      }
      function show(id) {
        var e = el(id);
        if (e) e.style.display = '';
      }
      function hide(id) {
        var e = el(id);
        if (e) e.style.display = 'none';
      }
      function getRegionDisplay(v) {
        var items = arr(v);
        if (!items.length) return '';
        var r = String(items[0]).trim();
        var m = r.match(/\(([^)]+)\)/);
        if (m) return m[1].trim();
        return r;
      }

      var FLAG_CODES = {
        España: 'es',
        Italy: 'it',
        Italia: 'it',
        Portugal: 'pt',
        Grecia: 'gr',
        Turquía: 'tr',
        Turkey: 'tr',
        Francia: 'fr',
        Alemania: 'de',
        Germany: 'de',
        Austria: 'at',
        Bélgica: 'be',
        Suecia: 'se',
        India: 'in',
        China: 'cn',
        Brasil: 'br',
        Brazil: 'br',
        'Estados Unidos': 'us',
        México: 'mx',
        Australia: 'au',
        Sudáfrica: 'za',
        'South Africa': 'za',
        Marruecos: 'ma',
        Egipto: 'eg',
        Irán: 'ir',
        Iran: 'ir',
        Pakistán: 'pk',
        Pakistan: 'pk',
        Vietnam: 'vn',
        Zimbabwe: 'zw',
        Zimbabue: 'zw',
        Finlandia: 'fi',
        Finland: 'fi',
        Israel: 'il',
        Croacia: 'hr',
        Croatia: 'hr',
        'Arabia Saudita': 'sa',
        'Reino Unido': 'gb',
        'United Kingdom': 'gb',
        Canadá: 'ca',
        Canada: 'ca',
        Spain: 'es',
      };
      function getFlag(pais) {
        if (!pais) return '';
        var code = FLAG_CODES[pais];
        if (!code) {
          var pl = pais.toLowerCase();
          for (var k in FLAG_CODES) {
            if (k.toLowerCase() === pl) {
              code = FLAG_CODES[k];
              break;
            }
          }
        }
        if (!code) return '';
        return (
          '<img src="https://flagicons.lipis.dev/flags/1x1/' +
          code +
          '.svg" width="16" height="16" alt="' +
          esc(pais) +
          '" style="border-radius:2px;display:inline-block;vertical-align:middle;flex-shrink:0" loading="lazy" onerror="this.style.display=\'none\'">'
        );
      }
      var CAT_COLORS = {
        marmol: '#C9B99A',
        mármol: '#C9B99A',
        granito: '#7A8A7A',
        caliza: '#D4C5A9',
        travertino: '#C8A96E',
        cuarcita: '#9EAAB8',
        arenisca: '#C4956A',
        pizarra: '#6B7280',
        onix: '#A67C52',
        ónix: '#A67C52',
        basalto: '#4A4540',
        porfido: '#7A6A5A',
      };
      function getCatColor(cat) {
        return CAT_COLORS[(cat || '').toLowerCase()] || '#A8A098';
      }
      var ACABADOS_ES = {
        Polished: 'Pulido',
        Honed: 'Apomazado',
        Brushed: 'Cepillado',
        'Bush Hammered': 'Abujardado',
        Tumbled: 'Envejecido',
        Sandblasted: 'Chorreado arena',
        Flamed: 'Flameado',
        Leathered: 'Cuero',
        Split: 'Partido',
        'Machine Cut': 'Corte máquina',
        'Acid Washing': 'Lavado ácido',
        Grooved: 'Estriado',
        Hammered: 'Martillado',
      };
      function tradAcabado(a) {
        return ACABADOS_ES[a] || a;
      }
      var USOS_ES = {
        flooring: 'Suelos',
        countertops: 'Encimeras',
        'wall applications': 'Revestimiento pared',
        exterior: 'Exterior',
        interior: 'Interior',
        stairs: 'Escaleras',
        facades: 'Fachadas',
        pool: 'Piscina',
        paving: 'Pavimento exterior',
        monuments: 'Monumentos',
        bathroom: 'Baños',
        kitchen: 'Cocina',
        ornamental: 'Decoración',
      };
      function tradUso(u) {
        var low = u.toLowerCase().trim();
        for (var k in USOS_ES) {
          if (low.indexOf(k) !== -1) return USOS_ES[k];
        }
        return u.charAt(0).toUpperCase() + u.slice(1).toLowerCase();
      }
      var APP_ICONS = {
        baño: '◉',
        suelo: '◻',
        encimera: '⬡',
        pared: '▭',
        fachada: '▮',
        escalera: '◈',
        piscina: '◎',
        decoraci: '◇',
        mobiliario: '▷',
        exterior: '◼',
        interior: '◻',
        cocina: '⬡',
        contract: '◆',
        urbanismo: '◐',
      };
      function getAppIcon(txt) {
        var low = txt.toLowerCase();
        for (var k in APP_ICONS) {
          if (low.indexOf(k) !== -1) return APP_ICONS[k];
        }
        return '·';
      }
      var RESIST_MAP = {
        'Muy alta': 90,
        Alta: 75,
        'Media-Alta': 65,
        Media: 50,
        'Baja-Media': 30,
        Baja: 20,
      };
      function resistPct(r) {
        if (!r) return 0;
        for (var k in RESIST_MAP) {
          if (r.toLowerCase().indexOf(k.toLowerCase()) !== -1) return RESIST_MAP[k];
        }
        return 50;
      }

      var params = new URLSearchParams(window.location.search);
      var slug = params.get('id') || '';
      if (!slug) {
        show404();
        return;
      }

      getBySlug(slug).then(function (m) {
        if (!m) {
          show404();
          return;
        }
        renderFicha(m);
        loadAdyacentes(m);
      });

      function renderFicha(m) {
        var catColor = getCatColor(m.categoria);
        var paises = arr(m.origen_pais),
          altNames = arr(m.nombres_alternativos),
          acabados = arr(m.acabados_disponibles);
        var usos = arr(m.usos_recomendados),
          tags = arr(m.tags_busqueda),
          t = m.propiedades_tecnicas || {};
        var regionStr = getRegionDisplay(m.origen_region),
          galeria = arr(m.imagenes_galeria);
        var apps_txt = arr(m.aplicaciones_recomendadas_txt),
          consejos = arr(m.consejos_instalacion),
          props_txt = arr(m.propiedades_tecnicas_texto);
        var catDisplay = (m.categoria || '').charAt(0).toUpperCase() + (m.categoria || '').slice(1);

        document.title = esc(m.nombre_comercial) + ' — Ficha Técnica | World Stone Hub';
        document
          .querySelector('meta[name="description"]')
          .setAttribute(
            'content',
            m.nombre_comercial +
              ' — ficha técnica completa: descripción, propiedades, aplicaciones, instalación y proveedores especializados.'
          );

        el('bc-cat').textContent = catDisplay;
        el('bc-cat').href = 'materiales.html?cat=' + esc(m.categoria);
        el('bc-nombre').textContent = m.nombre_comercial;
        el('hero-tipo-badge').textContent = catDisplay;
        el('hero-tipo-badge').style.borderColor = catColor;
        el('hero-tipo-badge').style.color = catColor;
        if (m.orden_catalogo)
          el('hero-orden').textContent =
            'Nº ' + String(m.orden_catalogo).padStart(2, '0') + ' / 50';
        el('hero-nombre').textContent = m.nombre_comercial;
        if (altNames.length) el('hero-alt').textContent = altNames.slice(0, 4).join(' · ');
        else hide('hero-alt');

        var COLOR_HEX = {
          Blanco: '#f5f5f0',
          'Blanco con venas grises': '#e8e8e8',
          Negro: '#1a1a1a',
          Beige: '#d4b896',
          'Crema beige uniforme': '#e8d8b8',
          Rojo: '#c0392b',
          Verde: '#4a7c59',
          Azul: '#3a6fa8',
          Gris: '#9a9a9a',
          Marrón: '#8B5E3C',
          Dorado: '#c4922a',
          Crema: '#e8dcc8',
          'Beige/crema': '#e0d0a0',
          'Negro con venas blancas': '#1a1a1a',
        };
        var metaHtml = '';
        if (paises.length)
          metaHtml +=
            '<div class="hero-meta-cell"><div class="hero-meta-label">País de origen</div><div class="hero-meta-value">' +
            paises
              .map(function (p) {
                return getFlag(p) + esc(p);
              })
              .join(', ') +
            '</div></div>';
        if (regionStr)
          metaHtml +=
            '<div class="hero-meta-cell"><div class="hero-meta-label">Región</div><div class="hero-meta-value">' +
            esc(regionStr) +
            '</div></div>';
        if (m.color_principal) {
          var hex = COLOR_HEX[m.color_principal] || '#ccc';
          var swatch =
            '<span style="display:inline-block;width:13px;height:13px;border-radius:50%;background:' +
            hex +
            ';border:1px solid rgba(0,0,0,.15);flex-shrink:0"></span>';
          metaHtml +=
            '<div class="hero-meta-cell"><div class="hero-meta-label">Color principal</div><div class="hero-meta-value" style="gap:7px;">' +
            swatch +
            esc(m.color_principal) +
            '</div></div>';
        }
        el('hero-meta-grid').innerHTML = metaHtml;

        var precio = m.precio_orientativo;
        if (precio)
          el('hero-precio-wrap').innerHTML =
            '<div class="hero-precio-row"><div><div class="precio-val">' +
            esc(precio) +
            ' €/m²</div><div class="precio-label">precio orientativo ex-obras</div></div></div>';

        var certs = m.certificaciones_txt || '';
        if (certs) {
          var certList = certs
            .split(',')
            .map(function (c) {
              return c.trim();
            })
            .filter(Boolean);
          el('hero-certs').innerHTML = certList
            .map(function (c) {
              return '<span class="cert-pill">' + esc(c) + '</span>';
            })
            .join('');
        }

        var mainImgEl = el('hero-main-img');
        if (m.imagen_url_principal) {
          mainImgEl.innerHTML =
            '<img src="' +
            esc(m.imagen_url_principal) +
            '" alt="' +
            esc(m.nombre_comercial) +
            '" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease;">';
          mainImgEl.style.cursor = 'zoom-in';
        } else {
          el('hero-placeholder-letter').textContent = m.nombre_comercial.charAt(0);
          el('hero-placeholder-text').textContent = m.categoria || '';
          el('hero-placeholder').style.background = catColor + '25';
        }

        if (galeria.length) {
          var stripEl = el('hero-gallery-strip');
          stripEl.style.display = 'flex';
          var allImgs = (m.imagen_url_principal ? [m.imagen_url_principal] : []).concat(galeria);
          stripEl.innerHTML = allImgs
            .map(function (imgUrl, idx) {
              return (
                '<div class="gallery-thumb' +
                (idx === 0 ? ' active' : '') +
                '" onclick="switchImg(this,\'' +
                esc(imgUrl) +
                "','" +
                esc(m.nombre_comercial) +
                '\')">' +
                '<img src="' +
                esc(imgUrl) +
                '" alt="Imagen ' +
                (idx + 1) +
                ' de ' +
                esc(m.nombre_comercial) +
                '" loading="lazy"></div>'
              );
            })
            .join('');
          if (allImgs.length > 1)
            mainImgEl.innerHTML +=
              '<span class="gallery-count">' + allImgs.length + ' fotos</span>';
        }

        if (m.descripcion_general) {
          var sentences = m.descripcion_general.split('. ');
          var chunkSize = Math.ceil(sentences.length / 3);
          var paras = [];
          for (var i = 0; i < sentences.length; i += chunkSize) {
            var chunk = sentences
              .slice(i, i + chunkSize)
              .join('. ')
              .trim();
            if (chunk && !chunk.endsWith('.')) chunk += '.';
            if (chunk) paras.push(chunk);
          }
          el('descripcion-texto').innerHTML = paras
            .map(function (p) {
              return '<p>' + esc(p) + '</p>';
            })
            .join('');
          show('sec-descripcion');
        }

        var propsRows = '';
        function propRow(label, val, unit) {
          if (val === null || val === undefined || val === '') return '';
          return (
            '<div class="prop-row"><span class="prop-label">' +
            label +
            '</span><span class="prop-val">' +
            esc(String(val)) +
            (unit || '') +
            '</span></div>'
          );
        }
        propsRows += propRow('Densidad', t.densidad_kg_m3, ' kg/m³');
        propsRows += propRow('Absorción agua', t.absorcion_agua_pct, '%');
        propsRows += propRow('Resist. compresión', t.resistencia_compresion_mpa, ' MPa');
        propsRows += propRow('Resist. flexión', t.resistencia_flexion_mpa, ' MPa');
        propsRows += propRow('Dureza Mohs', t.dureza_mohs);
        propsRows += propRow('Resist. helada', t.resistencia_helada);
        propsRows += propRow('Coef. fricción', t.coeficiente_friccion);
        if (m.resistencia_desgaste_txt)
          propsRows += propRow('Resist. desgaste', m.resistencia_desgaste_txt);
        var propsDetalleHtml = '';
        if (props_txt.length)
          propsDetalleHtml =
            '<ul class="tech-detail-list">' +
            props_txt
              .map(function (p) {
                return (
                  '<li class="tech-detail-item"><span class="tech-detail-bullet"></span><span>' +
                  esc(p) +
                  '</span></li>'
                );
              })
              .join('') +
            '</ul>';
        if (propsRows || propsDetalleHtml) {
          if (propsRows) el('props-grid').innerHTML = propsRows;
          else el('props-grid').style.display = 'none';
          if (propsDetalleHtml) el('props-detalle').innerHTML = propsDetalleHtml;
          show('sec-props');
        }

        var appsToShow = apps_txt.length
          ? apps_txt
          : usos.map(function (u) {
              return tradUso(u);
            });
        if (appsToShow.length) {
          el('apps-grid').innerHTML = appsToShow
            .slice(0, 10)
            .map(function (a) {
              var icon = getAppIcon(a);
              return (
                '<div class="app-card"><span class="app-icon">' +
                icon +
                '</span><span>' +
                esc(a) +
                '</span></div>'
              );
            })
            .join('');
          show('sec-apps');
        }

        if (acabados.length) {
          el('acabados-wrap').innerHTML = acabados
            .map(function (a) {
              return '<span class="acabado-chip">' + esc(tradAcabado(a)) + '</span>';
            })
            .join('');
          show('sec-acabados');
        }
        if (m.formatos_disponibles) {
          var fmts = m.formatos_disponibles
            .split(',')
            .map(function (f) {
              return f.trim();
            })
            .filter(Boolean);
          el('formatos-row').innerHTML = fmts
            .map(function (f) {
              return '<span class="formato-pill">' + esc(f) + '</span>';
            })
            .join('');
          show('sec-formatos');
        }
        if (consejos.length) {
          el('consejos-list').innerHTML = consejos
            .map(function (c, idx) {
              return (
                '<li class="consejo-item"><span class="consejo-num">' +
                String(idx + 1).padStart(2, '0') +
                '</span><span class="consejo-text">' +
                esc(c) +
                '</span></li>'
              );
            })
            .join('');
          show('sec-consejos');
        }
        if (m.perfil_comercial) {
          el('perfil-block').textContent = m.perfil_comercial;
          show('sec-perfil');
        }
        if (m.principales_compradores) {
          var buyers = m.principales_compradores
            .split(',')
            .map(function (b) {
              return b.trim();
            })
            .filter(Boolean);
          el('compradores-row').innerHTML = buyers
            .map(function (b) {
              return '<span class="comprador-tag">' + getFlag(b) + esc(b) + '</span>';
            })
            .join('');
          show('sec-compradores');
        }
        if (m.observaciones_editoriales) {
          el('obs-text').textContent = m.observaciones_editoriales;
          show('sec-obs');
        }
        var filteredTags = tags
          .filter(function (t) {
            return t && t.length > 2 && isNaN(t);
          })
          .slice(0, 20);
        if (filteredTags.length) {
          el('tags-wrap').innerHTML = filteredTags
            .map(function (t) {
              return (
                '<a href="materiales.html?q=' +
                encodeURIComponent(t) +
                '" class="tag-link">' +
                esc(t) +
                '</a>'
              );
            })
            .join('');
          show('sec-tags');
        }

        el('cta-proveedores').innerHTML =
          '<div class="cta-card-title">¿Buscas <em style="color:var(--gold);font-style:italic;">' +
          esc(m.nombre_comercial) +
          '</em>?</div><div class="cta-card-desc">Accede al directorio de proveedores especializados verificados para este material en nuestra red global.</div><a href="proveedores.html?material=' +
          esc(slug) +
          '" class="cta-btn">Ver proveedores →</a><a href="registro.html" class="cta-btn-sec">¿Eres proveedor? Publica tu empresa →</a>';
        el('sb-origen').innerHTML =
          '<div class="sb-card-title">Origen</div>' +
          paises
            .map(function (p) {
              return '<div class="origen-pais">' + getFlag(p) + esc(p) + '</div>';
            })
            .join('') +
          (regionStr ? '<div class="origen-region">' + esc(regionStr) + '</div>' : '');
        if (precio) {
          el('sb-precio').innerHTML =
            '<div class="sb-card-title">Precio orientativo</div><div class="sb-precio">' +
            esc(precio) +
            '</div><div class="sb-precio-unit">€ por m² · ex-obra · orientativo</div>';
          show('sb-precio');
        }
        if (m.resistencia_desgaste_txt) {
          var pct = resistPct(m.resistencia_desgaste_txt);
          el('sb-resistencia').innerHTML =
            '<div class="sb-card-title">Resistencia al desgaste</div><div class="resist-label">' +
            esc(m.resistencia_desgaste_txt) +
            '</div><div class="resist-bar"><div class="resist-bar-fill" style="width:' +
            pct +
            '%;background:' +
            catColor +
            '"></div></div>';
          show('sb-resistencia');
        }
        el('sb-categoria').innerHTML =
          '<div class="sb-card-title">Tipo de roca</div><div class="sb-cat-name">' +
          esc(catDisplay) +
          '</div><div class="sb-cat-bar" style="background:' +
          catColor +
          '50;"><div style="height:100%;width:60%;background:' +
          catColor +
          ';border-radius:2px;"></div></div>' +
          (altNames.length
            ? '<div style="margin-top:12px;font-size:.72rem;color:var(--ink-4);line-height:1.8;">' +
              altNames.slice(0, 5).map(esc).join('<br>') +
              '</div>'
            : '');
        if (certs) {
          var certList2 = certs
            .split(',')
            .map(function (c) {
              return c.trim();
            })
            .filter(Boolean);
          el('sb-certs').innerHTML =
            '<div class="sb-card-title">Certificaciones</div><div class="cert-grid">' +
            certList2
              .map(function (c) {
                return '<span class="cert-badge">' + esc(c) + '</span>';
              })
              .join('') +
            '</div>';
          show('sb-certs');
        }

        getContributions(slug).then(function (contribs) {
          if (!contribs.length) return;
          var counts = {};
          contribs.forEach(function (c) {
            counts[c.tipo_contribucion] = (counts[c.tipo_contribucion] || 0) + 1;
          });
          var items = [];
          if (counts['foto'] || counts['imagen'])
            items.push(
              '\uD83D\uDCF7 ' +
                ((counts['foto'] || 0) + (counts['imagen'] || 0)) +
                ' foto' +
                ((counts['foto'] || 0) + (counts['imagen'] || 0) !== 1 ? 's' : '')
            );
          if (counts['dato'] || counts['datos']) items.push('\uD83D\uDCCA datos verificados');
          if (counts['precio']) items.push('\uD83D\uDCB6 precio actualizado');
          if (counts['descripcion'] || counts['texto']) items.push('\uD83D\uDCDD descripción');
          if (!items.length) return;
          var html =
            '<div class="sb-community-card"><div class="sb-community-title">Contenido aportado</div><div class="sb-community-items">' +
            items
              .map(function (i) {
                return '<span class="sb-community-item">' + i + '</span>';
              })
              .join('<span class="sb-community-item" style="color:var(--border2)">·</span>') +
            '</div></div>';
          el('sb-community-contrib').innerHTML = html;
          show('sb-community-contrib');
        });

        getProveedores(slug).then(function (provs) {
          var r = { data: provs, error: null };
          if (!r.data || !r.data.length) {
            return db
              .from('proveedores')
              .select('nombre_empresa,slug,plan,pais,ciudad')
              .eq('plan_activo', true)
              .eq('estado', 'activo')
              .contains('materiales', [slug])
              .order('plan', { ascending: false })
              .limit(5)
              .then(function (rf) {
                if (!rf.data || !rf.data.length) return;
                var rows = rf.data
                  .map(function (p) {
                    var loc = [p.pais, p.ciudad].filter(Boolean).join(' \u00B7 ');
                    return (
                      '<a href="proveedor.html?id=' +
                      esc(p.slug) +
                      '" class="esp-company-row"><span class="esp-company-name">' +
                      esc(p.nombre_empresa) +
                      '</span>' +
                      (loc ? '<span class="esp-company-loc">' + esc(loc) + '</span>' : '') +
                      '</a>'
                    );
                  })
                  .join('');
                el('sb-empresas').innerHTML =
                  '<div class="sb-card-title">Proveedores especializados</div>' +
                  rows +
                  '<a href="proveedores.html?material=' +
                  esc(slug) +
                  '" class="esp-ver-todos">Ver todos en directorio \u2192</a>';
                show('sb-empresas');
                var sidebar = el('ficha-sidebar');
                sidebar.insertBefore(el('sb-empresas'), el('cta-proveedores').nextElementSibling);
              });
          }
          if (!r.data || !r.data.length) return;
          var elite = r.data
            .filter(function (p) {
              return p.plan === 'elite';
            })
            .slice(0, 2);
          var merit = r.data.filter(function (p) {
            return p.plan !== 'elite';
          });
          var html = '<div class="sb-card-title">Proveedores especializados</div>';
          if (elite.length) {
            html += '<div class="sb-elite-header">Socios \u00C9lite</div>';
            html += elite
              .map(function (p) {
                var loc = [p.pais, p.ciudad].filter(Boolean).join(' \u00B7 ');
                return (
                  '<a href="proveedor.html?id=' +
                  esc(p.slug) +
                  '" class="sb-elite-row"><span class="sb-elite-name">' +
                  esc(p.nombre_empresa) +
                  '</span>' +
                  (loc ? '<span class="sb-elite-meta">' + esc(loc) + '</span>' : '') +
                  '</a>'
                );
              })
              .join('');
          }
          var meritWithContrib = merit.filter(function (p) {
            return (
              p.contribuciones &&
              (Array.isArray(p.contribuciones)
                ? p.contribuciones.length
                : Object.keys(p.contribuciones).length)
            );
          });
          if (meritWithContrib.length) {
            html += '<div class="sb-contrib-header">Contribuidores activos</div>';
            html += meritWithContrib
              .map(function (p) {
                var badges = '';
                if (Array.isArray(p.contribuciones)) {
                  var bMap = {};
                  p.contribuciones.forEach(function (c) {
                    if (typeof c === 'string') {
                      bMap[c] = (bMap[c] || 0) + 1;
                    } else if (c && c.tipo) {
                      bMap[c.tipo] = (bMap[c.tipo] || 0) + (c.count || 1);
                    }
                  });
                  if (bMap['foto'] || bMap['imagen'])
                    badges +=
                      '<span class="sb-merit-badge">\uD83D\uDCF7 ' +
                      ((bMap['foto'] || 0) + (bMap['imagen'] || 0)) +
                      ' foto' +
                      ((bMap['foto'] || 0) + (bMap['imagen'] || 0) !== 1 ? 's' : '') +
                      '</span>';
                  if (bMap['dato'] || bMap['datos'])
                    badges += '<span class="sb-merit-badge">\uD83D\uDCCA datos</span>';
                  if (bMap['precio'])
                    badges += '<span class="sb-merit-badge">\uD83D\uDCB6 precio</span>';
                }
                return (
                  '<div class="sb-merit-row"><a href="proveedor.html?id=' +
                  esc(p.slug) +
                  '" class="sb-merit-name">' +
                  esc(p.nombre_empresa) +
                  '</a>' +
                  (badges ? '<div class="sb-merit-badges">' + badges + '</div>' : '') +
                  '</div>'
                );
              })
              .join('');
          }
          html +=
            '<a href="proveedores.html?material=' +
            esc(slug) +
            '" class="esp-ver-todos">Ver todos en directorio \u2192</a>';
          el('sb-empresas').innerHTML = html;
          show('sb-empresas');
          var sidebar = el('ficha-sidebar');
          sidebar.insertBefore(el('sb-empresas'), el('cta-proveedores').nextElementSibling);
        });

        el('stateLoading').style.display = 'none';
        el('fichaContent').style.display = 'block';
      }

      window.switchImg = function (thumbEl, imgUrl, nombre) {
        var strip = el('hero-gallery-strip');
        strip.querySelectorAll('.gallery-thumb').forEach(function (t) {
          t.classList.remove('active');
        });
        thumbEl.classList.add('active');
        var mainImg = el('hero-main-img');
        var imgTag = mainImg.querySelector('img');
        if (imgTag) {
          imgTag.style.opacity = '0';
          imgTag.src = imgUrl;
          imgTag.alt = nombre;
          imgTag.onload = function () {
            imgTag.style.opacity = '1';
            imgTag.style.transition = 'opacity .3s';
          };
        }
      };

      function loadAdyacentes(m) {
        db.from('materiales')
          .select('slug,nombre_comercial')
          .lt('id', m.id)
          .order('id', { ascending: false })
          .limit(1)
          .then(function (r) {
            if (r.data && r.data.length) {
              var prev = r.data[0];
              el('nav-prev').href = 'material.html?id=' + esc(prev.slug);
              el('nav-prev-name').textContent = prev.nombre_comercial;
              el('nav-prev').style.display = 'flex';
            }
          });
        db.from('materiales')
          .select('slug,nombre_comercial')
          .gt('id', m.id)
          .order('id', { ascending: true })
          .limit(1)
          .then(function (r) {
            if (r.data && r.data.length) {
              var next = r.data[0];
              el('nav-next').href = 'material.html?id=' + esc(next.slug);
              el('nav-next-name').textContent = next.nombre_comercial;
              el('nav-next').style.display = 'flex';
            }
          });
      }

      function show404() {
        el('stateLoading').style.display = 'none';
        el('state404').style.display = 'flex';
        document.title = 'Material no encontrado | World Stone Hub';
      }
    })();
  </script>
</Page>
