---
// Redirect page — keeps backward compatibility for old ?id=slug URLs.
// All material detail pages have moved to /materiales/[slug].
import Page from '../layouts/Page.astro';
---

<Page title="Redirigiendo… | World Stone Hub" noIndex={true} activePage="materiales">
  <script is:inline>
    var params = new URLSearchParams(window.location.search);
    var slug = params.get('id') || '';
    window.location.replace(slug ? '/materiales/' + slug : '/materiales');
  </script>
</Page>
