---
import Page from '../layouts/Page.astro';
---

<Page
  title="Cargando material… | World Stone Hub"
  description="Ficha técnica de material de piedra natural en World Stone Hub. Propiedades físicas, acabados disponibles, formatos, origen y proyectos de referencia."
  activePage="materiales"
>
  <style slot="head">
    body {
      background: var(--bg);
    }

    /* ── ESTADOS ── */
    .state-screen {
      margin-top: 64px;
      min-height: calc(100vh - 64px);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
    }
    .loading-spinner {
      width: 32px;
      height: 32px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
    .loading-text {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-4);
    }
    .not-found {
      text-align: center;
    }
    .not-found-num {
      font-family: var(--font-disp);
      font-size: 7rem;
      color: var(--border2);
      line-height: 1;
    }
    .not-found-title {
      font-family: var(--font-disp);
      font-size: 2rem;
      margin: 12px 0 8px;
    }
    .not-found-desc {
      color: var(--ink-4);
      font-size: 0.88rem;
      margin-bottom: 28px;
    }
    .not-found-btn {
      display: inline-block;
      background: var(--gold);
      color: white;
      padding: 12px 28px;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: var(--radius);
    }

    /* ── BREADCRUMB ── */
    .breadcrumb {
      margin-top: 64px;
      padding: 14px 48px;
      background: var(--bg-soft);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      color: var(--ink-4);
    }
    .breadcrumb a {
      color: var(--ink-4);
      transition: color 0.2s;
    }
    .breadcrumb a:hover {
      color: var(--gold);
    }
    .breadcrumb .sep {
      opacity: 0.4;
    }
    .breadcrumb .current {
      color: var(--ink);
    }

    /* ── HERO ── */
    .ficha-hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 520px;
      border-bottom: 1px solid var(--border);
    }
    .hero-left {
      padding: 56px 56px 52px;
      background: var(--bg-soft);
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 1px solid var(--border);
    }
    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }
    .hero-tipo-badge {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-family: var(--font-mono);
      color: var(--gold);
      border: 1px solid currentColor;
      padding: 4px 10px;
      border-radius: 2px;
    }
    .hero-orden {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--ink-4);
      letter-spacing: 0.1em;
    }
    .ficha-nombre {
      font-family: var(--font-disp);
      font-size: clamp(2.4rem, 4.5vw, 3.8rem);
      font-weight: 300;
      line-height: 1.08;
      letter-spacing: -0.01em;
      margin-bottom: 6px;
    }
    .ficha-alt {
      font-size: 0.75rem;
      color: var(--ink-4);
      letter-spacing: 0.05em;
      margin-bottom: 32px;
      font-family: var(--font-mono);
    }
    .hero-meta-grid {
      display: grid;
      grid-template-columns: repeat(3, auto);
      gap: 0;
      margin-bottom: 32px;
      border: 1px solid var(--border);
      background: var(--border);
      width: fit-content;
    }
    .hero-meta-cell {
      background: var(--bg-soft);
      padding: 12px 20px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .hero-meta-label {
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-4);
    }
    .hero-meta-value {
      font-size: 0.82rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .precio-val {
      font-family: var(--font-mono);
      font-size: 1.1rem;
      color: var(--gold);
      font-weight: 400;
      letter-spacing: 0.02em;
    }
    .precio-label {
      font-size: 0.65rem;
      color: var(--ink-4);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .hero-precio-row {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .hero-certs {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 16px;
    }
    .cert-pill {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      padding: 3px 9px;
      border: 1px solid var(--border2);
      border-radius: 2px;
      color: var(--ink-2);
    }
    .hero-right {
      position: relative;
      overflow: hidden;
      background: var(--ink);
      display: flex;
      flex-direction: column;
    }
    .hero-main-img {
      flex: 1;
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }
    .hero-main-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease;
    }
    .hero-main-img:hover img {
      transform: scale(1.03);
    }
    .hero-placeholder {
      width: 100%;
      height: 100%;
      min-height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
    }
    .hero-placeholder-letter {
      font-family: var(--font-disp);
      font-size: 6rem;
      font-weight: 300;
      opacity: 0.15;
      line-height: 1;
    }
    .hero-placeholder-text {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.4;
      color: white;
    }
    .hero-gallery-strip {
      display: flex;
      gap: 3px;
      padding: 3px;
      background: rgba(0, 0, 0, 0.3);
      flex-shrink: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .hero-gallery-strip::-webkit-scrollbar {
      display: none;
    }
    .gallery-thumb {
      width: 64px;
      height: 64px;
      flex-shrink: 0;
      overflow: hidden;
      cursor: pointer;
      opacity: 0.6;
      transition: opacity 0.2s;
      position: relative;
      border: 2px solid transparent;
    }
    .gallery-thumb:hover,
    .gallery-thumb.active {
      opacity: 1;
      border-color: var(--gold);
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .gallery-count {
      position: absolute;
      top: 8px;
      right: 8px;
      background: rgba(0, 0, 0, 0.65);
      color: white;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      padding: 3px 7px;
      border-radius: 2px;
      letter-spacing: 0.06em;
    }

    /* ── LAYOUT ── */
    .ficha-layout {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 0;
      padding: 0;
    }
    .ficha-main {
      padding: 64px 56px;
      border-right: 1px solid var(--border);
    }
    .section-label {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: var(--font-mono);
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .descripcion-texto {
      font-family: var(--font-disp);
      font-size: 1.08rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--ink-2);
      margin-bottom: 48px;
    }
    .descripcion-texto p {
      margin-bottom: 1.1em;
    }
    .props-section {
      margin-bottom: 52px;
    }
    .props-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }
    .prop-row {
      background: var(--bg);
      padding: 14px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.15s;
    }
    .prop-row:hover {
      background: var(--bg-soft);
    }
    .prop-label {
      font-size: 0.72rem;
      color: var(--ink-4);
    }
    .prop-val {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--ink);
    }
    .tech-detail-list {
      list-style: none;
      margin-bottom: 48px;
    }
    .tech-detail-item {
      display: flex;
      gap: 14px;
      padding: 13px 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.85rem;
      line-height: 1.6;
      color: var(--ink-2);
    }
    .tech-detail-item:first-child {
      border-top: 1px solid var(--border);
    }
    .tech-detail-bullet {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
      margin-top: 8px;
    }
    .apps-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 48px;
    }
    .app-card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      padding: 14px 16px;
      border-radius: var(--radius);
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.82rem;
      color: var(--ink-2);
      line-height: 1.5;
      transition:
        border-color 0.2s,
        background 0.2s;
    }
    .app-card:hover {
      border-color: var(--gold);
      background: #f5efea;
    }
    .app-icon {
      color: var(--gold);
      font-size: 0.85rem;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .acabados-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 48px;
    }
    .acabado-chip {
      padding: 6px 14px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 0.75rem;
      letter-spacing: 0.04em;
      color: var(--ink-2);
      transition:
        border-color 0.2s,
        color 0.2s;
    }
    .acabado-chip:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    .formatos-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 48px;
    }
    .formato-pill {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      padding: 5px 12px;
      background: var(--ink);
      color: rgba(255, 255, 255, 0.8);
      border-radius: 2px;
      letter-spacing: 0.04em;
    }
    .consejos-list {
      list-style: none;
      margin-bottom: 48px;
    }
    .consejo-item {
      display: flex;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
    }
    .consejo-item:first-child {
      border-top: 1px solid var(--border);
    }
    .consejo-num {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--gold);
      flex-shrink: 0;
      min-width: 24px;
      padding-top: 3px;
      opacity: 0.7;
    }
    .consejo-text {
      font-size: 0.85rem;
      color: var(--ink-2);
      line-height: 1.65;
    }
    .perfil-block {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-left: 3px solid var(--gold);
      padding: 24px 28px;
      margin-bottom: 48px;
      font-size: 0.88rem;
      color: var(--ink-2);
      line-height: 1.75;
    }
    .compradores-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 48px;
    }
    .comprador-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      font-size: 0.73rem;
      color: var(--ink-2);
      border-radius: 2px;
    }
    .obs-block {
      background: linear-gradient(135deg, #f5efea, var(--bg-soft));
      border: 1px solid var(--border2);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 48px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }
    .obs-icon {
      color: var(--gold);
      font-size: 1rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .obs-text {
      font-size: 0.83rem;
      color: var(--ink-2);
      line-height: 1.65;
    }
    .tags-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .tag-link {
      display: inline-block;
      padding: 4px 10px;
      border: 1px solid var(--border);
      font-size: 0.68rem;
      color: var(--ink-4);
      border-radius: 2px;
      transition:
        border-color 0.2s,
        color 0.2s;
    }
    .tag-link:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    /* ── SIDEBAR ── */
    .ficha-sidebar {
      padding: 40px 32px;
    }
    .cta-card {
      background: var(--ink);
      color: white;
      padding: 28px 24px;
      border-radius: var(--radius);
      margin-bottom: 20px;
    }
    .cta-card-title {
      font-family: var(--font-disp);
      font-size: 1.2rem;
      color: white;
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .cta-card-desc {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.55);
      margin-bottom: 20px;
      line-height: 1.6;
    }
    .cta-btn {
      display: block;
      background: var(--gold);
      color: white;
      padding: 12px 20px;
      text-align: center;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: var(--radius);
      transition: opacity 0.2s;
      margin-bottom: 8px;
    }
    .cta-btn:hover {
      opacity: 0.85;
    }
    .cta-btn-sec {
      display: block;
      text-align: center;
      margin-top: 4px;
      font-size: 0.7rem;
      color: rgba(255, 255, 255, 0.4);
      transition: color 0.2s;
    }
    .cta-btn-sec:hover {
      color: rgba(255, 255, 255, 0.7);
    }
    .sb-card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      padding: 20px;
      margin-bottom: 16px;
      border-radius: var(--radius);
    }
    .sb-card-title {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-4);
      font-family: var(--font-mono);
      margin-bottom: 14px;
    }
    .origen-pais {
      font-family: var(--font-disp);
      font-size: 1.25rem;
      font-weight: 300;
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 4px;
      line-height: 1.3;
    }
    .origen-region {
      font-size: 0.73rem;
      color: var(--ink-4);
      font-family: var(--font-mono);
      letter-spacing: 0.04em;
    }
    .sb-precio {
      font-family: var(--font-mono);
      font-size: 1.5rem;
      color: var(--gold);
      letter-spacing: 0.03em;
      font-weight: 300;
    }
    .sb-precio-unit {
      font-size: 0.62rem;
      color: var(--ink-4);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 2px;
      font-family: var(--font-mono);
    }
    .sb-cat-name {
      font-size: 0.88rem;
      color: var(--ink);
      font-weight: 500;
      text-transform: capitalize;
      margin-bottom: 4px;
    }
    .sb-cat-bar {
      height: 3px;
      border-radius: 2px;
      margin-top: 8px;
    }
    .cert-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .cert-badge {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.06em;
      padding: 4px 10px;
      border: 1px solid var(--border2);
      border-radius: 2px;
      color: var(--ink-2);
    }
    .esp-company-row {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      transition: color 0.2s;
    }
    .esp-company-row:last-of-type {
      border-bottom: none;
    }
    .esp-company-row:hover .esp-company-name {
      color: var(--gold);
    }
    .esp-company-name {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--ink);
      transition: color 0.2s;
    }
    .esp-company-loc {
      font-size: 0.72rem;
      color: var(--ink-4);
      font-family: var(--font-mono);
    }
    .esp-ver-todos {
      display: block;
      margin-top: 14px;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: var(--font-mono);
      transition: opacity 0.2s;
    }
    .esp-ver-todos:hover {
      opacity: 0.7;
    }
    .sb-elite-header {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: var(--font-mono);
      margin-bottom: 10px;
      margin-top: 4px;
    }
    .sb-contrib-header {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-4);
      font-family: var(--font-mono);
      margin: 14px 0 10px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
    }
    .sb-elite-row {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 10px 12px;
      border: 1px solid rgba(166, 124, 82, 0.3);
      border-radius: var(--radius);
      margin-bottom: 8px;
      background: #f5efea;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .sb-elite-row:hover {
      border-color: var(--gold);
    }
    .sb-elite-name {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--ink);
    }
    .sb-elite-meta {
      font-size: 0.7rem;
      color: var(--ink-4);
      font-family: var(--font-mono);
    }
    .sb-merit-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
    }
    .sb-merit-row:last-of-type {
      border-bottom: none;
    }
    .sb-merit-name {
      font-size: 0.83rem;
      color: var(--ink);
    }
    .sb-merit-badges {
      display: flex;
      gap: 4px;
    }
    .sb-merit-badge {
      font-size: 0.62rem;
      padding: 2px 6px;
      background: var(--bg-mid);
      border: 1px solid var(--border);
      border-radius: 2px;
      color: var(--ink-4);
      white-space: nowrap;
    }
    .sb-community-card {
      background: linear-gradient(135deg, rgba(166, 124, 82, 0.08), var(--bg-soft));
      border: 1px solid rgba(166, 124, 82, 0.25);
      padding: 16px 20px;
      border-radius: var(--radius);
      margin-bottom: 16px;
    }
    .sb-community-title {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: var(--font-mono);
      margin-bottom: 10px;
    }
    .sb-community-items {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sb-community-item {
      font-size: 0.75rem;
      color: var(--ink-2);
    }
    .resist-bar-wrap {
      margin-top: 6px;
    }
    .resist-label {
      font-size: 0.68rem;
      color: var(--ink-4);
      margin-bottom: 6px;
    }
    .resist-bar {
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
    }
    .resist-bar-fill {
      height: 100%;
      border-radius: 2px;
      background: var(--gold);
      transition: width 0.6s ease;
    }

    /* ── NAV PREV/NEXT ── */
    .ficha-nav-row {
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 56px;
    }
    .ficha-nav-prev,
    .ficha-nav-next {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 28px 0;
      color: var(--ink-4);
      transition: color 0.2s;
      max-width: 44%;
    }
    .ficha-nav-prev:hover,
    .ficha-nav-next:hover {
