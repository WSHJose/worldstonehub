---
import Page from '../layouts/Page.astro';
---

<Page
  title="Levantina — Distribuidor de Piedra Natural | World Stone Hub"
  description="Levantina S.L. - Distribuidor mayorista especializado en mármoles, granitos y cuarcitas de origen español."
>
  <style slot="head">
    .header {
      margin-top: 64px;
      background: linear-gradient(135deg, #1a1917 0%, #2a2622 100%);
      color: #fff;
      padding: 60px 48px;
    }
    .header-title {
      font-family: var(--font-disp);
      font-size: 2.5rem;
      font-weight: 600;
      margin-bottom: 16px;
    }
    .header-desc {
      font-size: 1.1rem;
      max-width: 600px;
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.7;
    }

    .content {
      max-width: 900px;
      margin: 0 auto;
      padding: 60px 48px;
    }
    .section {
      margin-bottom: 60px;
    }
    .section-title {
      font-size: 1.8rem;
      font-weight: 600;
      margin-bottom: 24px;
      color: var(--ink);
    }
    .section-text {
      font-size: 1rem;
      color: var(--ink-mid);
      line-height: 1.8;
      margin-bottom: 16px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px;
    }
    .card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      padding: 24px;
      border-radius: 8px;
    }
    .card h3 {
      font-weight: 600;
      margin-bottom: 12px;
    }
    .card p {
      font-size: 0.95rem;
      color: var(--ink-mid);
    }

    .btn {
      display: inline-block;
      background: var(--gold);
      color: white;
      padding: 12px 28px;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 600;
      margin-top: 16px;
    }
    .btn:hover {
      opacity: 0.9;
    }
  </style>

  <div class="header">
    <h1 class="header-title">Levantina</h1>
    <p class="header-desc">
      Distribuidor mayorista de mármoles, granitos y cuarcitas desde 1981. Especialización en
      materiales de origen español.
    </p>
  </div>

  <div class="content">
    <section class="section">
      <h2 class="section-title">Sobre Levantina</h2>
      <p class="section-text">
        Con más de 40 años en la industria, Levantina es un referente en distribución de piedra
        natural de alta calidad. Contamos con almacenes en Madrid, Barcelona y Valencia, y
        suministramos a más de 500 proyectos al año.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">Especialidades</h2>
      <div class="grid">
        <div class="card">
          <h3>Mármoles españoles</h3>
          <p>Macael, Alicante, Emperador, Crema Marfil y más variedades de origen nacional.</p>
        </div>
        <div class="card">
          <h3>Granitos</h3>
          <p>Rosas y negros de Galicia, así como importaciones de Brasil e India.</p>
        </div>
        <div class="card">
          <h3>Cuarcitas</h3>
          <p>Quartzites de Brasil, Portugal y España para aplicaciones exigentes.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Contacto</h2>
      <p class="section-text">
        <strong>Email:</strong> info@levantina-dist.es<br />
        <strong>Teléfono:</strong> +34 91 000 0000<br />
        <strong>Dirección:</strong> Calle de la Piedra, 123 · 28001 Madrid
      </p>
      <a href="https://levantina-dist.es" class="btn">Visitar web</a>
    </section>
  </div>
</Page>
