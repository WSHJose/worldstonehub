---
import Page from '../layouts/Page.astro';
---

<Page title="Perfil de empresa — World Stone Hub" activePage="directorio">
  <style slot="head">
    /* LOADING STATE */
    #loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 80vh;
      gap: 20px;
      margin-top: 64px;
    }
    .loading-spinner {
      width: 40px;
      height: 40px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
    .loading-text {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
    }

    /* ERROR STATE */
    #error-state {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 80vh;
      text-align: center;
      padding: 40px;
      margin-top: 64px;
    }
    .error-num {
      font-family: var(--font-disp);
      font-size: 120px;
      font-weight: 300;
      color: var(--border2);
      line-height: 1;
    }
    .error-title {
      font-family: var(--font-disp);
      font-size: 32px;
      font-weight: 300;
      margin: 12px 0;
    }
    .error-title em {
      font-style: italic;
      color: var(--gold);
    }
    .error-desc {
      font-size: 14px;
      color: var(--ink-4);
      margin-bottom: 32px;
    }
    .error-btn {
      background: var(--ink);
      color: #f8f7f5;
      padding: 12px 28px;
      text-decoration: none;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
    }

    /* PROFILE — hidden until loaded */
    #profile {
      display: none;
    }

    /* BREADCRUMB */
    .breadcrumb {
      padding: 88px 60px 0;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--ink-4);
    }
    .breadcrumb a {
      color: var(--ink-4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .breadcrumb a:hover {
      color: var(--gold);
    }
    .breadcrumb span {
      opacity: 0.4;
    }

    /* PROFILE HERO */
    .profile-hero {
      padding: 32px 60px 48px;
      display: flex;
      align-items: flex-start;
      gap: 48px;
      background: #fff;
      border-bottom: 1px solid var(--border);
    }
    .profile-logo-wrap {
      flex-shrink: 0;
      width: 120px;
      height: 120px;
      border: 1px solid var(--border);
      background: var(--bg-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .profile-logo-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 8px;
    }
    .profile-logo-initials {
      font-family: var(--font-disp);
      font-size: 48px;
      font-weight: 300;
      color: var(--ink-4);
      font-style: italic;
    }
    .profile-meta {
      flex: 1;
      min-width: 0;
    }
    .profile-badges {
      display: flex;
      gap: 8px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }
    .badge {
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      padding: 4px 10px;
      border: 1px solid;
      font-weight: 500;
    }
    .badge-plan-free {
      color: var(--ink-4);
      border-color: var(--border2);
    }
    .badge-plan-presencia {
      color: #7a6242;
      border-color: #c9a96e;
      background: #fdf8f0;
    }
    .badge-plan-profesional {
      color: #4a5a3a;
      border-color: #8aaa60;
      background: #f4f8ee;
    }
    .badge-plan-elite {
      color: var(--ink);
      border-color: var(--gold);
      background: var(--gold-lt);
    }
    .badge-verificado {
      color: #fff;
      background: var(--gold);
      border-color: var(--gold);
    }
    .badge-sector {
      color: var(--ink-2);
      border-color: var(--border2);
      background: var(--bg-soft);
    }
    .profile-name {
      font-family: var(--font-disp);
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 300;
      line-height: 1;
      letter-spacing: -1px;
      margin-bottom: 10px;
    }
    .profile-tipo {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ink-4);
      margin-bottom: 16px;
    }
    .profile-location {
      font-size: 13px;
      color: var(--ink-4);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .profile-location svg {
      flex-shrink: 0;
    }
    .profile-actions {
      display: flex;
      gap: 12px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .btn-contact {
      background: var(--ink);
      color: #f8f7f5;
      padding: 12px 24px;
      text-decoration: none;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: background 0.25s;
      border: none;
      cursor: pointer;
    }
    .btn-contact:hover {
      background: var(--gold);
    }
    .btn-web {
      border: 1px solid var(--border2);
      color: var(--ink-2);
      padding: 12px 24px;
      text-decoration: none;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: all 0.25s;
    }
    .btn-web:hover {
      border-color: var(--ink);
      color: var(--ink);
    }
    .profile-stats-row {
      margin-left: auto;
      text-align: right;
      flex-shrink: 0;
    }
    .profile-stat-n {
      font-family: var(--font-disp);
      font-size: 32px;
      font-weight: 300;
      color: var(--ink);
    }
    .profile-stat-l {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ink-4);
      margin-top: 2px;
    }
    .profile-founded {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--ink-4);
      letter-spacing: 1px;
      margin-top: 8px;
    }

    /* PROFILE LAYOUT */
    .profile-body {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 0;
      align-items: start;
    }
    .profile-main {
      padding: 48px 60px;
      border-right: 1px solid var(--border);
    }
    .profile-sidebar {
      padding: 40px 36px;
      position: sticky;
      top: 80px;
    }

    /* SECTIONS */
    .section-title {
      font-family: var(--font-disp);
      font-size: 22px;
      font-weight: 400;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-title svg {
      color: var(--gold);
    }
    .profile-desc {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.9;
      color: var(--ink-2);
      margin-bottom: 40px;
    }

    /* TAGS */
    .tags-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 40px;
    }
    .tag {
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 6px 14px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      color: var(--ink-2);
      transition: all 0.2s;
    }
    .tag:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    /* GALLERY */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 40px;
    }
    .gallery-img {
      aspect-ratio: 4/3;
      object-fit: cover;
      width: 100%;
      display: block;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .gallery-img:hover {
      opacity: 0.85;
    }

    /* LOCKED CONTENT */
    .locked-block {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      padding: 32px;
      text-align: center;
      margin-bottom: 40px;
    }
    .locked-icon {
      font-size: 28px;
      margin-bottom: 12px;
      opacity: 0.35;
    }
    .locked-title {
      font-family: var(--font-disp);
      font-size: 20px;
      font-weight: 300;
      margin-bottom: 8px;
    }
    .locked-title em {
      font-style: italic;
      color: var(--gold);
    }
    .locked-desc {
      font-size: 13px;
      color: var(--ink-4);
      margin-bottom: 20px;
      line-height: 1.6;
    }
    .locked-cta {
      display: inline-block;
      background: var(--gold);
      color: #fff;
      padding: 10px 24px;
      text-decoration: none;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      transition: background 0.2s;
    }
    .locked-cta:hover {
      background: var(--ink);
    }

    /* SIDEBAR */
    .sidebar-block {
      margin-bottom: 32px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .sidebar-block:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }
    .sidebar-label {
      font-size: 9px;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: var(--ink-4);
      margin-bottom: 12px;
    }
    .sidebar-value {
      font-size: 14px;
      color: var(--ink-2);
      font-weight: 400;
    }
    .sidebar-link {
      font-size: 13px;
      color: var(--gold);
      text-decoration: none;
      word-break: break-all;
    }
    .sidebar-link:hover {
      text-decoration: underline;
    }
    .social-links {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .social-link {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--ink-4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .social-link:hover {
      color: var(--gold);
    }
    .social-link svg {
      flex-shrink: 0;
    }

    /* UPGRADE CARD */
    .upgrade-card {
      background: var(--ink);
      padding: 24px;
      margin-bottom: 32px;
    }
    .upgrade-card-title {
      font-family: var(--font-disp);
      font-size: 20px;
      font-weight: 300;
      color: #f0ead8;
      margin-bottom: 8px;
    }
    .upgrade-card-title em {
      font-style: italic;
      color: var(--gold);
    }
    .upgrade-card-desc {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.4);
      line-height: 1.6;
      margin-bottom: 16px;
    }
    .upgrade-card-btn {
      display: block;
      background: var(--gold);
      color: #fff;
      padding: 10px;
      text-align: center;
      text-decoration: none;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: background 0.2s;
    }
    .upgrade-card-btn:hover {
      background: #c49060;
    }

    /* SIMILAR COMPANIES */
    .similar-grid {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .similar-card {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      text-decoration: none;
      transition: border-color 0.2s;
    }
    .similar-card:hover {
      border-color: var(--gold);
    }
    .similar-initials {
      width: 36px;
      height: 36px;
      background: var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-disp);
      font-size: 18px;
      color: var(--ink-4);
      flex-shrink: 0;
    }
    .similar-name {
      font-size: 13px;
      color: var(--ink);
      font-weight: 500;
    }
    .similar-pais {
      font-size: 11px;
      color: var(--ink-4);
      margin-top: 1px;
    }

    /* LIGHTBOX */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.92);
      z-index: 9999;
      align-items: center;
      justify-content: center;
    }
    .lightbox.open {
      display: flex;
    }
    .lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
    }
    .lightbox-close {
      position: absolute;
      top: 24px;
      right: 32px;
      font-size: 32px;
      color: rgba(255, 255, 255, 0.5);
      cursor: pointer;
      transition: color 0.2s;
      line-height: 1;
      background: none;
      border: none;
    }
    .lightbox-close:hover {
      color: #fff;
    }

    @media (max-width: 900px) {
      .breadcrumb {
        padding: 80px 24px 0;
      }
      .profile-hero {
        flex-direction: column;
        padding: 24px 24px 36px;
        gap: 24px;
      }
      .profile-stats-row {
        margin-left: 0;
      }
      .profile-body {
        grid-template-columns: 1fr;
      }
      .profile-main {
        padding: 32px 24px;
        border-right: none;
      }
      .profile-sidebar {
        padding: 24px;
        border-top: 1px solid var(--border);
      }
      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <!-- LOADING -->
  <div id="loading">
    <div class="loading-spinner"></div>
    <div class="loading-text">Cargando perfil</div>
  </div>

  <!-- ERROR -->
  <div id="error-state">
    <div class="error-num">404</div>
    <h2 class="error-title">Empresa <em>no encontrada</em></h2>
    <p class="error-desc">Esta empresa no existe o ha sido eliminada del directorio.</p>
    <a href="/proveedores.html" class="error-btn">Ver directorio completo</a>
  </div>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close-btn">×</button>
    <img id="lightbox-img" src="" alt="" />
  </div>

  <!-- PROFILE (rendered by JS) -->
  <div id="profile"></div>

  <script>
    import {
      getBySlug as getProveedorBySlug,
      getRelated,
    } from '@contexts/proveedores/services/http/proveedoresHttp';
    import { supabase } from '@services/http/config';
    (function () {
      var db = supabase;

      // ── HELPERS ────────────────────────────────────────────────────────────────
      function esc(s) {
        return s
          ? String(s)
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;')
          : '';
      }
      function planLabel(p) {
        var m = {
          free: 'Free',
          presencia: 'Presencia',
          profesional: 'Profesional',
          elite: 'Élite',
        };
        return m[p] || p || 'Free';
      }
      function planBadgeClass(p) {
        var m = {
          free: 'badge-plan-free',
          presencia: 'badge-plan-presencia',
          profesional: 'badge-plan-profesional',
          elite: 'badge-plan-elite',
        };
        return m[p] || 'badge-plan-free';
      }
      function planLevel(p) {
        return { free: 0, presencia: 1, profesional: 2, elite: 3 }[p] || 0;
      }

      // ── GET SLUG FROM URL ──────────────────────────────────────────────────────
      var params = new URLSearchParams(window.location.search);
      var slug = params.get('id') || params.get('slug');
      if (!slug) {
        showError();
        return;
      }

      // ── LIGHTBOX ───────────────────────────────────────────────────────────────
      function openLightbox(src) {
        document.getElementById('lightbox-img').src = src;
        document.getElementById('lightbox').classList.add('open');
      }
      function closeLightbox() {
        document.getElementById('lightbox').classList.remove('open');
        document.getElementById('lightbox-img').src = '';
      }
      document.getElementById('lightbox-close-btn').addEventListener('click', closeLightbox);
      document.getElementById('lightbox').addEventListener('click', function (e) {
        if (e.target === this) closeLightbox();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeLightbox();
      });

      // ── FETCH PROVEEDOR ────────────────────────────────────────────────────────
      getProveedorBySlug(slug)
        .then(function (p) {
          if (!p) {
            showError();
            return;
          }

          document.title = esc(p.nombre_empresa) + ' — World Stone Hub';

          registrarVisita(p.id, p.plan);

          var sector0 = (p.sector && p.sector[0]) || p.tipo_empresa || null;
          var similarPromise = sector0 ? getRelated(sector0, slug) : Promise.resolve([]);

          similarPromise.then(function (similar) {
            renderProfile(p, similar || []);
          });
        })
        .catch(function () {
          showError();
        });

      // ── REGISTER VISIT ─────────────────────────────────────────────────────────
      function registrarVisita(proveedorId, plan) {
        try {
          var sesion = sessionStorage.getItem('wsh_sid');
          if (!sesion) {
            sesion = 'sid_' + Math.random().toString(36).slice(2, 11);
            sessionStorage.setItem('wsh_sid', sesion);
          }
          supabase
            .from('eventos')
            .insert({
              tipo: 'perfil_visita',
              proveedor_id: proveedorId,
              sesion_id: sesion,
              referrer: document.referrer || null,
              dispositivo: /Mobi|Android/i.test(navigator.userAgent) ? 'mobile' : 'desktop',
            })
            .then(function () {})
            .catch(function () {});
        } catch (e) {}
      }

      // ── RENDER PROFILE ─────────────────────────────────────────────────────────
      function renderProfile(p, similar) {
        if (p.estado !== 'activo') {
          var banner = document.createElement('div');
          banner.style.cssText =
            'background:#A67C52;color:#fff;text-align:center;padding:12px 20px;font-size:14px;position:sticky;top:0;z-index:999;';
          banner.textContent =
            'Tu perfil está pendiente de activación. Solo tú puedes verlo por ahora.';
          document.body.insertBefore(banner, document.body.firstChild);
        }

        var nivel = planLevel(p.plan);
        var hasLogo = p.logo_url && nivel >= 1;
        var hasDesc = p.descripcion && nivel >= 1;
        var hasContact = nivel >= 1;
        var hasGallery = p.fotos && p.fotos.length && nivel >= 2;
        var hasMateriales = p.materiales && p.materiales.length && nivel >= 1;
        var hasCert = p.certificaciones && p.certificaciones.length && nivel >= 2;
        var hasVerificado = p.verificado && nivel >= 3;

        // BADGES
        var badges =
          '<span class="badge ' + planBadgeClass(p.plan) + '">' + planLabel(p.plan) + '</span>';
        if (hasVerificado) badges += '<span class="badge badge-verificado">✓ Verificado</span>';
        if (p.tipo_empresa)
          badges += '<span class="badge badge-sector">' + esc(p.tipo_empresa) + '</span>';
        if (p.sector && p.sector.length > 1)
          p.sector.slice(1, 3).forEach(function (s) {
            badges += '<span class="badge badge-sector">' + esc(s) + '</span>';
          });

        // LOGO / INITIALS
        var logoHtml = hasLogo
          ? '<img src="' + esc(p.logo_url) + '" alt="Logo ' + esc(p.nombre_empresa) + '">'
          : '<span class="profile-logo-initials">' +
            esc((p.nombre_empresa || '?').charAt(0)) +
            '</span>';

        // LOCATION
        var locationParts = [p.ciudad, p.pais].filter(Boolean);
        var locationHtml = locationParts.length
          ? '<div class="profile-location"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="5" r="2.5" stroke="#8a8784" stroke-width="1.2"/><path d="M6 1C3.79 1 2 2.79 2 5c0 3 4 7 4 7s4-4 4-7c0-2.21-1.79-4-4-4z" stroke="#8a8784" stroke-width="1.2" fill="none"/></svg>' +
            locationParts.map(esc).join(', ') +
            '</div>'
          : '';

        var foundedHtml = p.ano_fundacion
          ? '<div class="profile-founded">Est. ' +
            p.ano_fundacion +
            (p.num_empleados ? ' · ' + esc(p.num_empleados) + ' empleados' : '') +
            '</div>'
          : '';

        // DESCRIPTION
        var descHtml = '';
        if (hasDesc) {
          descHtml =
            '<div class="section-title"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="3" width="14" height="10" stroke="#A67C52" stroke-width="1.2" rx="1"/><line x1="4" y1="6" x2="12" y2="6" stroke="#A67C52" stroke-width="1.2"/><line x1="4" y1="8.5" x2="10" y2="8.5" stroke="#A67C52" stroke-width="1.2"/></svg>Sobre la empresa</div>';
          descHtml += '<p class="profile-desc">' + esc(p.descripcion) + '</p>';
        } else if (nivel === 0) {
          descHtml =
            '<div class="locked-block"><div class="locked-icon">🔒</div><div class="locked-title">Descripción <em>no disponible</em></div><div class="locked-desc">Esta empresa está en el plan gratuito. Actualiza a Presencia para mostrar tu descripción, datos de contacto, materiales y más.</div><a href="/registro.html" class="locked-cta">Ver planes</a></div>';
        }

        // MATERIALES
        var matsHtml = '';
        if (hasMateriales) {
          matsHtml =
            '<div class="section-title"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" stroke="#A67C52" stroke-width="1.2" rx="0.5"/><rect x="9" y="1" width="6" height="6" stroke="#A67C52" stroke-width="1.2" rx="0.5"/><rect x="1" y="9" width="6" height="6" stroke="#A67C52" stroke-width="1.2" rx="0.5"/><rect x="9" y="9" width="6" height="6" stroke="#A67C52" stroke-width="1.2" rx="0.5"/></svg>Materiales y productos</div>';
          matsHtml +=
            '<div class="tags-wrap">' +
            p.materiales
              .map(function (m) {
                return '<span class="tag">' + esc(m) + '</span>';
              })
              .join('') +
            '</div>';
        }

        // CERTIFICACIONES
        var certHtml = '';
        if (hasCert) {
          certHtml =
            '<div class="section-title"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="7" r="5" stroke="#A67C52" stroke-width="1.2"/><path d="M5 14l3-2 3 2v-4" stroke="#A67C52" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 7l1.5 1.5L10 5.5" stroke="#A67C52" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>Certificaciones</div>';
          certHtml +=
            '<div class="tags-wrap">' +
            p.certificaciones
              .map(function (c) {
                return '<span class="tag">' + esc(c) + '</span>';
              })
              .join('') +
            '</div>';
        }

        // GALLERY
        var galleryHtml = '';
        if (hasGallery) {
          galleryHtml =
            '<div class="section-title"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="2" width="14" height="12" stroke="#A67C52" stroke-width="1.2" rx="1"/><circle cx="5.5" cy="6" r="1.5" stroke="#A67C52" stroke-width="1.2"/><path d="M1 11l4-3 3 3 2-2 5 3" stroke="#A67C52" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>Galería de imágenes</div>';
          galleryHtml +=
            '<div class="gallery-grid">' +
            p.fotos
              .slice(0, 6)
              .map(function (f, i) {
                return (
                  '<img class="gallery-img" src="' +
                  esc(f) +
                  '" alt="Foto ' +
                  (i + 1) +
                  ' de ' +
                  esc(p.nombre_empresa) +
                  '" loading="lazy" data-lightbox-src="' +
                  esc(f) +
                  '">'
                );
              })
              .join('') +
            '</div>';
        } else if (nivel >= 1 && nivel < 2) {
          galleryHtml =
            '<div class="locked-block"><div class="locked-icon">📷</div><div class="locked-title">Galería disponible en <em>Profesional</em></div><div class="locked-desc">Añade hasta 12 fotos de tu empresa, instalaciones y productos para destacar frente a la competencia.</div><a href="/registro.html" class="locked-cta">Actualizar plan</a></div>';
        }

        // SIDEBAR — contact
        var contactHtml = '';
        if (hasContact) {
          if (p.email_contacto)
            contactHtml +=
              '<div class="sidebar-block"><div class="sidebar-label">Email</div><a class="sidebar-link" href="mailto:' +
              esc(p.email_contacto) +
              '">' +
              esc(p.email_contacto) +
              '</a></div>';
          if (p.telefono)
            contactHtml +=
              '<div class="sidebar-block"><div class="sidebar-label">Teléfono</div><a class="sidebar-link" href="tel:' +
              esc(p.telefono) +
              '">' +
              esc(p.telefono) +
              '</a></div>';
          if (p.website)
            contactHtml +=
              '<div class="sidebar-block"><div class="sidebar-label">Web</div><a class="sidebar-link" href="' +
              esc(p.website) +
              '" target="_blank" rel="noopener">' +
              esc(p.website.replace(/^https?:\/\//, '')) +
              '</a></div>';
        }

        // SIDEBAR — social
        var socialHtml = '';
        if (p.redes_sociales && nivel >= 1) {
          var redes =
            typeof p.redes_sociales === 'string' ? JSON.parse(p.redes_sociales) : p.redes_sociales;
          var socialItems = [];
          if (redes.linkedin)
            socialItems.push(
              '<a class="social-link" href="' +
                esc(redes.linkedin) +
                '" target="_blank" rel="noopener"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>LinkedIn</a>'
            );
          if (redes.instagram)
            socialItems.push(
              '<a class="social-link" href="' +
                esc(redes.instagram) +
                '" target="_blank" rel="noopener"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>Instagram</a>'
            );
          if (redes.youtube)
            socialItems.push(
              '<a class="social-link" href="' +
                esc(redes.youtube) +
                '" target="_blank" rel="noopener"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" stroke="currentColor" fill="none"/></svg>YouTube</a>'
            );
          if (socialItems.length)
            socialHtml =
              '<div class="sidebar-block"><div class="sidebar-label">Redes sociales</div><div class="social-links">' +
              socialItems.join('') +
              '</div></div>';
        }

        // SIDEBAR — similar
        var similarHtml = '';
        if (similar && similar.length) {
          similarHtml =
            '<div class="sidebar-block"><div class="sidebar-label">Empresas similares</div><div class="similar-grid">';
          similar.forEach(function (s) {
            similarHtml += '<a class="similar-card" href="/proveedor.html?id=' + esc(s.slug) + '">';
            similarHtml +=
              '<div class="similar-initials">' +
              esc((s.nombre_empresa || '?').charAt(0)) +
              '</div>';
            similarHtml +=
              '<div><div class="similar-name">' +
              esc(s.nombre_empresa) +
              '</div><div class="similar-pais">' +
              esc(s.pais || '') +
              '</div></div>';
            similarHtml += '</a>';
          });
          similarHtml += '</div></div>';
        }

        // UPGRADE CARD
        var upgradeHtml =
          nivel < 3
            ? '<div class="upgrade-card"><div class="upgrade-card-title">¿Eres el <em>titular</em>?</div><div class="upgrade-card-desc">Mejora tu perfil para mostrar galería, vídeos, catálogo PDF y estadísticas de visitas.</div><a href="/registro.html" class="upgrade-card-btn">Ver planes</a></div>'
            : '';

        // ACTIONS
        var actionsHtml = '';
        if (hasContact && p.email_contacto)
          actionsHtml +=
            '<a href="mailto:' + esc(p.email_contacto) + '" class="btn-contact">Contactar</a>';
        if (p.website && nivel >= 1)
          actionsHtml +=
            '<a href="' +
            esc(p.website) +
            '" target="_blank" rel="noopener" class="btn-web">Ver web →</a>';

        // ASSEMBLE
        var html = '';
        html +=
          '<div class="breadcrumb"><a href="/proveedores.html">Directorio</a><span>·</span><span>' +
          esc(p.nombre_empresa) +
          '</span></div>';
        html += '<div class="profile-hero">';
        html += '<div class="profile-logo-wrap">' + logoHtml + '</div>';
        html += '<div class="profile-meta">';
        html += '<div class="profile-badges">' + badges + '</div>';
        html += '<h1 class="profile-name">' + esc(p.nombre_empresa) + '</h1>';
        if (p.tipo_empresa) html += '<div class="profile-tipo">' + esc(p.tipo_empresa) + '</div>';
        html += locationHtml;
        html += foundedHtml;
        if (actionsHtml) html += '<div class="profile-actions">' + actionsHtml + '</div>';
        html += '</div>';
        if (p.ano_fundacion) {
          html += '<div class="profile-stats-row">';
          html +=
            '<div class="profile-stat-n">' +
            p.ano_fundacion +
            '</div><div class="profile-stat-l">Año fundación</div>';
          html += '</div>';
        }
        html += '</div>';

        html += '<div class="profile-body">';
        html +=
          '<div class="profile-main">' + descHtml + matsHtml + certHtml + galleryHtml + '</div>';
        html +=
          '<div class="profile-sidebar">' +
          upgradeHtml +
          contactHtml +
          socialHtml +
          similarHtml +
          '</div>';
        html += '</div>';

        document.getElementById('loading').style.display = 'none';
        var profileEl = document.getElementById('profile');
        profileEl.innerHTML = html;
        profileEl.style.display = 'block';

        // Bind lightbox to gallery images
        profileEl.querySelectorAll('[data-lightbox-src]').forEach(function (img) {
          img.addEventListener('click', function () {
            openLightbox(this.dataset.lightboxSrc);
          });
        });
      }

      function showError() {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('error-state').style.display = 'flex';
      }
    })();
  </script>
</Page>
